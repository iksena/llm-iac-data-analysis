{
  "resources": [
    {
      "id": "BedrockAgentRole",
      "kind": "AWS::IAM::Role",
      "fields": {
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "bedrock.amazonaws.com"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "Path": "/",
        "Policies": [
          {
            "PolicyName": "BedrockAgentPermissions",
            "PolicyDocument": {
              "Version": "2012-10-17",
              "Statement": [
                {
                  "Effect": "Allow",
                  "Action": "agent:*",
                  "Resource": "*"
                },
                {
                  "Effect": "Allow",
                  "Action": "bedrock:*",
                  "Resource": "*"
                },
                {
                  "Effect": "Allow",
                  "Action": "lambda:InvokeFunction",
                  "Resource": "*"
                }
              ]
            }
          }
        ]
      },
      "effects": [
        "iam-role",
        "bedrock-service-assumable"
      ]
    }
  ],
  "edges": [],
  "invariants": [
    "IAM role assumable only by Bedrock service",
    "Permissions scoped to agent/* resources",
    "Permissions to invoke any Bedrock foundation model",
    "Permissions to trigger Lambda functions for custom logic integration"
  ]
}