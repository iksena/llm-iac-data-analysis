{
  "resources": [
    {
      "id": "PetShopLambda",
      "kind": "AWS::Lambda::Function",
      "fields": {
        "Handler": "index.handler",
        "Runtime": "nodejs18.x",
        "Code": {
          "ZipFile": "exports.handler = async (event) => { return { pets: [ { id: '1', name: 'Max', type: 'Dog' }, { id: '2', name: 'Bella', type: 'Cat' }, { id: '3', name: 'Charlie', type: 'Bird' } ] }; };"
        },
        "Timeout": 10,
        "MemorySize": 128,
        "Role": {
          "Ref": "LambdaExecutionRole"
        }
      },
      "effects": [
        "lambda-function"
      ]
    },
    {
      "id": "LambdaExecutionRole",
      "kind": "AWS::IAM::Role",
      "fields": {
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "lambda.amazonaws.com"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "ManagedPolicyArns": [
          {
            "Fn::Join": [
              ":",
              [
                "arn",
                {
                  "Ref": "AWS::Partition"
                },
                "iam",
                "aws",
                "policy",
                "service-role",
                "AWSLambdaBasicExecutionRole"
              ]
            ]
          }
        ]
      },
      "effects": [
        "iam-role"
      ]
    },
    {
      "id": "PetShopAPI",
      "kind": "AWS::AppSync::GraphQLApi",
      "fields": {
        "Name": "PetShopAPI",
        "AuthenticationType": "API_KEY",
        "ApiKeyConfig": {
          "ApiKeyExpirationDays": 365
        }
      },
      "effects": [
        "graphql-api",
        "public-read"
      ]
    },
    {
      "id": "PetShopLambdaDataSource",
      "kind": "AWS::AppSync::DataSource",
      "fields": {
        "ApiId": {
          "Ref": "PetShopAPI"
        },
        "Name": "PetShopLambdaDataSource",
        "Type": "AWS_LAMBDA",
        "ServiceRoleArn": {
          "Fn::GetAtt": [
            "AppSyncLambdaRole",
            "Arn"
          ]
        },
        "LambdaConfig": {
          "LambdaFunctionArn": {
            "Fn::GetAtt": [
              "PetShopLambda",
              "Arn"
            ]
          }
        }
      },
      "effects": [
        "data-source"
      ]
    },
    {
      "id": "AppSyncLambdaRole",
      "kind": "AWS::IAM::Role",
      "fields": {
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "appsync.amazonaws.com"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "Policies": [
          {
            "PolicyName": "InvokeLambdaPolicy",
            "PolicyDocument": {
              "Version": "2012-10-17",
              "Statement": [
                {
                  "Effect": "Allow",
                  "Action": [
                    "lambda:InvokeFunction"
                  ],
                  "Resource": {
                    "Fn::GetAtt": [
                      "PetShopLambda",
                      "Arn"
                    ]
                  }
                }
              ]
            }
          }
        ]
      },
      "effects": [
        "iam-role"
      ]
    },
    {
      "id": "PetQueryResolver",
      "kind": "AWS::AppSync::Resolver",
      "fields": {
        "ApiId": {
          "Ref": "PetShopAPI"
        },
        "TypeName": "Query",
        "FieldName": "getPets",
        "DataSourceName": {
          "Fn::GetAtt": [
            "PetShopLambdaDataSource",
            "Name"
          ]
        },
        "RequestMappingTemplate": "{\n  \"version\": \"2017-02-28\",\n  \"operation\": \"Invoke\",\n  \"payload\": {}\n}",
        "ResponseMappingTemplate": "{\n  #set($pets = $ctx.result.pets)\n  #return($pets)\n}"
      },
      "effects": [
        "graphql-resolver"
      ]
    },
    {
      "id": "PetShopSchema",
      "kind": "AWS::AppSync::GraphQLSchema",
      "fields": {
        "ApiId": {
          "Ref": "PetShopAPI"
        },
        "Definition": "type Pet { id: ID!, name: String!, type: String! } type Query { getPets: [Pet!]! }"
      },
      "effects": [
        "graphql-schema"
      ]
    }
  ],
  "edges": [
    {
      "type": "depends",
      "from": "PetShopLambda",
      "to": "LambdaExecutionRole"
    },
    {
      "type": "depends",
      "from": "PetShopLambdaDataSource",
      "to": "PetShopAPI"
    },
    {
      "type": "depends",
      "from": "PetShopLambdaDataSource",
      "to": "AppSyncLambdaRole"
    },
    {
      "type": "depends",
      "from": "PetShopLambdaDataSource",
      "to": "PetShopLambda"
    },
    {
      "type": "depends",
      "from": "AppSyncLambdaRole",
      "to": "PetShopLambda"
    },
    {
      "type": "depends",
      "from": "PetQueryResolver",
      "to": "PetShopAPI"
    },
    {
      "type": "depends",
      "from": "PetQueryResolver",
      "to": "PetShopLambdaDataSource"
    },
    {
      "type": "depends",
      "from": "PetShopSchema",
      "to": "PetShopAPI"
    }
  ],
  "invariants": [
    "Lambda execution role must have AWSLambdaBasicExecutionRole managed policy",
    "AppSync role must have lambda:InvokeFunction permission for the Lambda function",
    "API_KEY authentication allows anonymous access",
    "Resolver mapping templates must transform Lambda output to GraphQL schema format"
  ]
}