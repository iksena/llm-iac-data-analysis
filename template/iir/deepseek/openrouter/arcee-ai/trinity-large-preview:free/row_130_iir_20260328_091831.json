{
  "resources": [
    {
      "id": "IAMPasswordPolicy",
      "kind": "AWS::IAM::AccountPasswordPolicy",
      "fields": {
        "MinimumPasswordLength": 14,
        "RequireLowercaseCharacters": true,
        "RequireUppercaseCharacters": true,
        "RequireNumbers": true,
        "RequireSymbols": true,
        "AllowUsersToChangePassword": true,
        "MaxPasswordAge": 90,
        "PasswordReusePrevention": 24
      },
      "effects": [
        "encrypted",
        "versioned"
      ]
    },
    {
      "id": "PasswordPolicyLambda",
      "kind": "AWS::Lambda::Function",
      "fields": {
        "Runtime": "nodejs18.x",
        "Handler": "index.handler",
        "Role": "IAMRoleForLambda",
        "Code": {
          "ZipFile": "exports.handler = async (event) => { /* Lambda code to manage IAM password policy */ };"
        }
      },
      "effects": [
        "encrypted"
      ]
    },
    {
      "id": "IAMRoleForLambda",
      "kind": "AWS::IAM::Role",
      "fields": {
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "lambda.amazonaws.com"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "ManagedPolicyArns": [
          "arn:aws:iam::aws:policy/service-role/AWSLambdaBasicExecutionRole"
        ]
      },
      "effects": [
        "encrypted"
      ]
    },
    {
      "id": "PermissionBoundaryPolicy",
      "kind": "AWS::IAM::ManagedPolicy",
      "fields": {
        "PolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Action": "*",
              "Resource": "*"
            }
          ]
        }
      },
      "effects": [
        "encrypted"
      ]
    }
  ],
  "edges": [
    {
      "type": "depends",
      "from": "PasswordPolicyLambda",
      "to": "IAMRoleForLambda"
    },
    {
      "type": "connects",
      "from": "PasswordPolicyLambda",
      "to": "IAMPasswordPolicy",
      "proto": "https",
      "port": 443
    }
  ],
  "invariants": [
    "IAM password policy must enforce strong authentication",
    "Lambda function must have permissions to modify IAM settings",
    "Password policy must be configurable via parameters",
    "Self-service password changes must be enabled",
    "Password reuse prevention must be enforced"
  ]
}