{
  "resources": [
    {
      "id": "VPC",
      "kind": "AWS::EC2::VPC",
      "fields": {
        "CidrBlock": "10.0.0.0/16",
        "EnableDnsSupport": true,
        "EnableDnsHostnames": true
      },
      "effects": [
        "vpc"
      ]
    },
    {
      "id": "PublicSubnet",
      "kind": "AWS::EC2::Subnet",
      "fields": {
        "VpcId": "VPC",
        "CidrBlock": "10.0.1.0/24",
        "MapPublicIpOnLaunch": true
      },
      "effects": [
        "public"
      ]
    },
    {
      "id": "InternetGateway",
      "kind": "AWS::EC2::InternetGateway",
      "fields": {},
      "effects": [
        "internet"
      ]
    },
    {
      "id": "VPCGatewayAttachment",
      "kind": "AWS::EC2::VPCGatewayAttachment",
      "fields": {
        "VpcId": "VPC",
        "InternetGatewayId": "InternetGateway"
      },
      "effects": [
        "internet"
      ]
    },
    {
      "id": "RouteTable",
      "kind": "AWS::EC2::RouteTable",
      "fields": {
        "VpcId": "VPC"
      },
      "effects": [
        "routing"
      ]
    },
    {
      "id": "Route",
      "kind": "AWS::EC2::Route",
      "fields": {
        "RouteTableId": "RouteTable",
        "DestinationCidrBlock": "0.0.0.0/0",
        "GatewayId": "InternetGateway"
      },
      "effects": [
        "routing"
      ]
    },
    {
      "id": "SubnetRouteTableAssociation",
      "kind": "AWS::EC2::SubnetRouteTableAssociation",
      "fields": {
        "SubnetId": "PublicSubnet",
        "RouteTableId": "RouteTable"
      },
      "effects": [
        "routing"
      ]
    },
    {
      "id": "SecurityGroup",
      "kind": "AWS::EC2::SecurityGroup",
      "fields": {
        "GroupDescription": "Allow HTTP and SSH",
        "VpcId": "VPC",
        "SecurityGroupIngress": [
          {
            "IpProtocol": "tcp",
            "FromPort": 80,
            "ToPort": 80,
            "CidrIp": "0.0.0.0/0"
          },
          {
            "IpProtocol": "tcp",
            "FromPort": 22,
            "ToPort": 22,
            "CidrIp": "0.0.0.0/0"
          }
        ],
        "SecurityGroupEgress": [
          {
            "IpProtocol": "-1",
            "FromPort": -1,
            "ToPort": -1,
            "CidrIp": "0.0.0.0/0"
          }
        ]
      },
      "effects": [
        "security"
      ]
    },
    {
      "id": "IAMRole",
      "kind": "AWS::IAM::Role",
      "fields": {
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "ec2.amazonaws.com"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "ManagedPolicyArns": [
          "arn:aws:iam::aws:policy/AmazonS3FullAccess",
          "arn:aws:iam::aws:policy/AmazonDynamoDBFullAccess"
        ]
      },
      "effects": [
        "iam",
        "s3-full-access",
        "dynamodb-full-access"
      ]
    },
    {
      "id": "InstanceProfile",
      "kind": "AWS::IAM::InstanceProfile",
      "fields": {
        "Roles": [
          "IAMRole"
        ]
      },
      "effects": [
        "iam"
      ]
    },
    {
      "id": "EC2Instance",
      "kind": "AWS::EC2::Instance",
      "fields": {
        "ImageId": "ami-0c55b159cbfafe0f0",
        "InstanceType": "t2.micro",
        "SubnetId": "PublicSubnet",
        "SecurityGroupIds": [
          "SecurityGroup"
        ],
        "IamInstanceProfile": "InstanceProfile",
        "UserData": "UserData",
        "KeyName": "my-key-pair"
      },
      "effects": [
        "ec2",
        "apache",
        "php",
        "aws-sdk",
        "bootstrapped"
      ]
    },
    {
      "id": "S3Bucket",
      "kind": "AWS::S3::Bucket",
      "fields": {
        "BucketName": "static-assets-bucket"
      },
      "effects": [
        "s3",
        "static-assets"
      ]
    },
    {
      "id": "DynamoDBTable",
      "kind": "AWS::DynamoDB::Table",
      "fields": {
        "TableName": "AWS-Services",
        "KeySchema": [
          {
            "AttributeName": "ServiceId",
            "KeyType": "HASH"
          },
          {
            "AttributeName": "ServiceName",
            "KeyType": "RANGE"
          }
        ],
        "AttributeDefinitions": [
          {
            "AttributeName": "ServiceId",
            "AttributeType": "S"
          },
          {
            "AttributeName": "ServiceName",
            "AttributeType": "S"
          }
        ],
        "BillingMode": "PAY_PER_REQUEST"
      },
      "effects": [
        "dynamodb",
        "composite-keys"
      ]
    }
  ],
  "edges": [
    {
      "type": "depends",
      "from": "PublicSubnet",
      "to": "VPC"
    },
    {
      "type": "depends",
      "from": "VPCGatewayAttachment",
      "to": "VPC"
    },
    {
      "type": "depends",
      "from": "VPCGatewayAttachment",
      "to": "InternetGateway"
    },
    {
      "type": "depends",
      "from": "RouteTable",
      "to": "VPC"
    },
    {
      "type": "depends",
      "from": "Route",
      "to": "RouteTable"
    },
    {
      "type": "depends",
      "from": "Route",
      "to": "InternetGateway"
    },
    {
      "type": "depends",
      "from": "SubnetRouteTableAssociation",
      "to": "PublicSubnet"
    },
    {
      "type": "depends",
      "from": "SubnetRouteTableAssociation",
      "to": "RouteTable"
    },
    {
      "type": "depends",
      "from": "SecurityGroup",
      "to": "VPC"
    },
    {
      "type": "depends",
      "from": "InstanceProfile",
      "to": "IAMRole"
    },
    {
      "type": "depends",
      "from": "EC2Instance",
      "to": "PublicSubnet"
    },
    {
      "type": "depends",
      "from": "EC2Instance",
      "to": "SecurityGroup"
    },
    {
      "type": "depends",
      "from": "EC2Instance",
      "to": "InstanceProfile"
    },
    {
      "type": "depends",
      "from": "EC2Instance",
      "to": "S3Bucket"
    },
    {
      "type": "depends",
      "from": "EC2Instance",
      "to": "DynamoDBTable"
    }
  ],
  "invariants": [
    "EC2 instance must have IAM role with S3 and DynamoDB full access",
    "DynamoDB table must use composite keys (ServiceId as HASH, ServiceName as RANGE)",
    "S3 bucket must be accessible for static asset storage",
    "EC2 instance must be in public subnet with internet access",
    "Apache/PHP and AWS SDK must be installed via UserData",
    "Application files must be preloaded and configured dynamically",
    "DynamoDB data must be populated from JSON files during bootstrapping"
  ]
}