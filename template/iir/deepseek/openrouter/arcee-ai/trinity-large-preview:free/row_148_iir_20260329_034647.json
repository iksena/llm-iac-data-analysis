    {
      "id": "SecurityGroup",
      "kind": "AWS::EC2::SecurityGroup",
      "fields": {
        "GroupDescription": "Jenkins Security Group",
        "VpcId": "VPC",
        "SecurityGroupIngress": [
          {
            "IpProtocol": "tcp",
            "FromPort": 22,
            "ToPort": 22,
            "CidrIp": "0.0.0.0/0"
          },
          {
            "IpProtocol": "tcp",
            "FromPort": 8080,
            "ToPort": 8080,
            "CidrIp": "0.0.0.0/0"
          }
        ],
        "SecurityGroupEgress": [
