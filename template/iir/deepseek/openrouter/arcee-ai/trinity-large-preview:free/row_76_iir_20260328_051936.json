{
  "resources": [
    {
      "id": "SecurityAdminRole",
      "kind": "AWS::IAM::Role",
      "fields": {
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "AWS": "arn:aws:iam::123456789012:root"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "ManagedPolicyArns": [
          "arn:aws:iam::aws:policy/AWSReadOnlyAccess"
        ],
        "Policies": [
          {
            "PolicyName": "FISFullAccess",
            "PolicyDocument": {
              "Version": "2012-10-17",
              "Statement": [
                {
                  "Effect": "Allow",
                  "Action": "fis:*",
                  "Resource": "*"
                }
              ]
            }
          },
          {
            "PolicyName": "RolePassing",
            "PolicyDocument": {
              "Version": "2012-10-17",
              "Statement": [
                {
                  "Effect": "Allow",
                  "Action": "iam:PassRole",
                  "Resource": [
                    "arn:aws:iam::123456789012:role/FISWorkshop*",
                    "arn:aws:iam::aws:role/aws-service-role/*"
                  ]
                }
              ]
            }
          },
          {
            "PolicyName": "ServiceLinkedRoles",
            "PolicyDocument": {
              "Version": "2012-10-17",
              "Statement": [
                {
                  "Effect": "Allow",
                  "Action": "iam:CreateServiceLinkedRole",
                  "Resource": "*"
                }
              ]
            }
          }
        ]
      },
      "effects": [
        "full-fis-access",
        "role-passing",
        "service-linked-role-creation"
      ]
    },
    {
      "id": "AdminRole",
      "kind": "AWS::IAM::Role",
      "fields": {
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "AWS": "arn:aws:iam::123456789012:root"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "ManagedPolicyArns": [
          "arn:aws:iam::aws:policy/AWSReadOnlyAccess"
        ],
        "Policies": [
          {
            "PolicyName": "FISLimitedAccess",
            "PolicyDocument": {
              "Version": "2012-10-17",
              "Statement": [
                {
                  "Effect": "Allow",
                  "Action": "fis:*",
                  "Resource": "*"
                },
                {
                  "Effect": "Deny",
                  "Action": "fis:*",
                  "Resource": "*",
                  "Condition": {
                    "StringEquals": {
                      "aws:ResourceTag/environment": "prod"
                    }
                  }
                }
              ]
            }
          },
          {
            "PolicyName": "RolePassing",
            "PolicyDocument": {
              "Version": "2012-10-17",
              "Statement": [
                {
                  "Effect": "Allow",
                  "Action": "iam:PassRole",
                  "Resource": [
                    "arn:aws:iam::123456789012:role/FISWorkshop*",
                    "arn:aws:iam::aws:role/aws-service-role/*"
                  ]
                }
              ]
            }
          }
        ]
      },
      "effects": [
        "limited-fis-access",
        "role-passing",
        "prod-environment-denied"
      ]
    },
    {
      "id": "UserRole",
      "kind": "AWS::IAM::Role",
      "fields": {
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "AWS": "arn:aws:iam::123456789012:root"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "ManagedPolicyArns": [
          "arn:aws:iam::aws:policy/AWSReadOnlyAccess"
        ],
        "Policies": [
          {
            "PolicyName": "FISUserActions",
            "PolicyDocument": {
              "Version": "2012-10-17",
              "Statement": [
                {
                  "Effect": "Allow",
                  "Action": [
                    "fis:StartExperiment",
                    "fis:StopExperiment",
                    "fis:Get*",
                    "fis:List*",
                    "fis:TagResource"
                  ],
                  "Resource": "*"
                },
                {
                  "Effect": "Deny",
                  "Action": "fis:*",
                  "Resource": "*",
                  "Condition": {
                    "StringEquals": {
                      "aws:ResourceTag/environment": "prod"
                    }
                  }
                }
              ]
            }
          }
        ]
      },
      "effects": [
        "read-only-aws",
        "limited-fis-actions",
        "prod-environment-denied"
      ]
    },
    {
      "id": "NonUserRole",
      "kind": "AWS::IAM::Role",
      "fields": {
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "AWS": "arn:aws:iam::123456789012:root"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "ManagedPolicyArns": [
          "arn:aws:iam::aws:policy/AWSReadOnlyAccess"
        ],
        "Policies": [
          {
            "PolicyName": "FISDenyAll",
            "PolicyDocument": {
              "Version": "2012-10-17",
              "Statement": [
                {
                  "Effect": "Deny",
                  "Action": "fis:*",
                  "Resource": "*"
                }
              ]
            }
          }
        ]
      },
      "effects": [
        "read-only-aws",
        "fis-denied"
      ]
    }
  ],
  "edges": [],
  "invariants": [
    "Security Admins have full FIS access with role-passing and service-linked role creation",
    "Admins have FIS access but are denied production environment resources",
    "Users can only start/stop experiments and view resources, with production access blocked",
    "Non-Users have read-only AWS access with all FIS actions explicitly denied",
    "All roles include AWS ReadOnlyAccess as foundational permissions",
    "Role-passing is conditional on workshop-specific and service-linked roles"
  ]
}