{
  "resources": [
    {
      "id": "AuroraCluster",
      "kind": "AWS::RDS::DBCluster",
      "fields": {
        "Engine": "aurora-mysql",
        "EngineMode": "provisioned",
        "EngineVersion": "5.7.mysql_aurora.2.07.2",
        "DBClusterParameterGroupName": "default.aurora-mysql5.7",
        "MasterUsername": "admin",
        "MasterUserPassword": "password",
        "Port": 3306,
        "BackupRetentionPeriod": 1,
        "PreferredBackupWindow": "07:00-08:00",
        "PreferredMaintenanceWindow": "mon:03:00-mon:04:00",
        "EnableHttpEndpoint": true,
        "EnableIAMDatabaseAuthentication": true,
        "DeletionProtection": true,
        "EnableCloudwatchLogsExports": [
          "error"
        ]
      },
      "effects": [
        "encrypted",
        "multi-az",
        "cloudwatch-logs"
      ]
    },
    {
      "id": "AuroraInstance1",
      "kind": "AWS::RDS::DBInstance",
      "fields": {
        "DBInstanceClass": "db.t3.large",
        "Engine": "aurora-mysql",
        "DBClusterIdentifier": "AuroraCluster",
        "PubliclyAccessible": true,
        "DBSubnetGroupName": "AuroraSubnetGroup",
        "DBParameterGroupName": "default.aurora-mysql5.7",
        "AvailabilityZone": "us-east-1a"
      },
      "effects": [
        "publicly-accessible"
      ]
    },
    {
      "id": "AuroraInstance2",
      "kind": "AWS::RDS::DBInstance",
      "fields": {
        "DBInstanceClass": "db.t3.large",
        "Engine": "aurora-mysql",
        "DBClusterIdentifier": "AuroraCluster",
        "PubliclyAccessible": true,
        "DBSubnetGroupName": "AuroraSubnetGroup",
        "DBParameterGroupName": "default.aurora-mysql5.7",
        "AvailabilityZone": "us-east-1b"
      },
      "effects": [
        "publicly-accessible"
      ]
    },
    {
      "id": "AuroraSubnetGroup",
      "kind": "AWS::RDS::DBSubnetGroup",
      "fields": {
        "DBSubnetGroupDescription": "Subnets for Aurora cluster",
        "SubnetIds": [
          "subnet-12345678",
          "subnet-87654321"
        ]
      },
      "effects": [
        "multi-az"
      ]
    }
  ],
  "edges": [
    {
      "type": "depends",
      "from": "AuroraInstance1",
      "to": "AuroraCluster"
    },
    {
      "type": "depends",
      "from": "AuroraInstance2",
      "to": "AuroraCluster"
    },
    {
      "type": "depends",
      "from": "AuroraInstance1",
      "to": "AuroraSubnetGroup"
    },
    {
      "type": "depends",
      "from": "AuroraInstance2",
      "to": "AuroraSubnetGroup"
    }
  ],
  "invariants": [
    "Aurora cluster must be multi-AZ with two instances",
    "Error logs must be exported to CloudWatch",
    "Instances must be publicly accessible",
    "Encryption must be enabled",
    "Instances must be in different availability zones"
  ]
}