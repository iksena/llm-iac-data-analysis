{
  "resources": [
    {
      "id": "KinesisStream",
      "kind": "AWS::Kinesis::Stream",
      "fields": {
        "Name": "RealTimeDataStream",
        "ShardCount": 1,
        "Tags": [
          {
            "Key": "Environment",
            "Value": "production"
          }
        ]
      },
      "effects": [
        "encrypted"
      ]
    },
    {
      "id": "ReadAlarm",
      "kind": "AWS::CloudWatch::Alarm",
      "fields": {
        "AlarmName": "KinesisReadThroughputAlarm",
        "AlarmDescription": "Alarm when Kinesis read throughput exceeds threshold",
        "Namespace": "AWS/Kinesis",
        "MetricName": "ReadProvisionedThroughputExceeded",
        "Statistic": "Sum",
        "Period": 300,
        "EvaluationPeriods": 1,
        "Threshold": 1000000,
        "ComparisonOperator": "GreaterThanThreshold",
        "AlarmActions": [
          {
            "Ref": "AlarmTopic"
          }
        ],
        "Dimensions": [
          {
            "Name": "StreamName",
            "Value": {
              "Ref": "KinesisStream"
            }
          }
        ]
      },
      "effects": []
    },
    {
      "id": "WriteAlarm",
      "kind": "AWS::CloudWatch::Alarm",
      "fields": {
        "AlarmName": "KinesisWriteThroughputAlarm",
        "AlarmDescription": "Alarm when Kinesis write throughput exceeds threshold",
        "Namespace": "AWS/Kinesis",
        "MetricName": "WriteProvisionedThroughputExceeded",
        "Statistic": "Sum",
        "Period": 300,
        "EvaluationPeriods": 1,
        "Threshold": 1000000,
        "ComparisonOperator": "GreaterThanThreshold",
        "AlarmActions": [
          {
            "Ref": "AlarmTopic"
          }
        ],
        "Dimensions": [
          {
            "Name": "StreamName",
            "Value": {
              "Ref": "KinesisStream"
            }
          }
        ]
      },
      "effects": []
    },
    {
      "id": "AlarmTopic",
      "kind": "AWS::SNS::Topic",
      "fields": {
        "DisplayName": "KinesisThroughputAlarms"
      },
      "effects": []
    }
  ],
  "edges": [
    {
      "type": "depends",
      "from": "ReadAlarm",
      "to": "KinesisStream"
    },
    {
      "type": "depends",
      "from": "WriteAlarm",
      "to": "KinesisStream"
    },
    {
      "type": "depends",
      "from": "ReadAlarm",
      "to": "AlarmTopic"
    },
    {
      "type": "depends",
      "from": "WriteAlarm",
      "to": "AlarmTopic"
    }
  ],
  "invariants": [
    "Kinesis Data Stream must be encrypted at rest",
    "Alarms must trigger notifications for both read and write throughput exceeding",
    "Stream must have at least one shard for data ingestion"
  ]
}