{
  "resources": [
    {
      "id": "EventBus",
      "kind": "AWS::EventBridge::EventBus",
      "fields": {
        "Name": "CustomEventBus"
      },
      "effects": [
        "public-read"
      ]
    },
    {
      "id": "MongoDBConnection",
      "kind": "AWS::EventBridge::Connection",
      "fields": {
        "AuthorizationType": "API_KEY",
        "ApiKeyAuthParameters": {
          "ApiKeyName": "test_name",
          "ApiKeyValue": "test_value"
        }
      },
      "effects": [
        "encrypted"
      ]
    },
    {
      "id": "MongoDBApiDestination",
      "kind": "AWS::EventBridge::ApiDestination",
      "fields": {
        "ConnectionArn": "test_value",
        "InvocationEndpoint": "www.testanu.com",
        "HttpMethod": "POST"
      },
      "effects": [
        "public-read"
      ]
    },
    {
      "id": "EventBridgeRole",
      "kind": "AWS::IAM::Role",
      "fields": {
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "events.amazonaws.com"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "Policies": [
          {
            "PolicyName": "InvokeMongoDB",
            "PolicyDocument": {
              "Version": "2012-10-17",
              "Statement": [
                {
                  "Effect": "Allow",
                  "Action": "execute-api:Invoke",
                  "Resource": "arn:aws:execute-api:*:*:*"
                }
              ]
            }
          }
        ]
      },
      "effects": [
        "encrypted"
      ]
    },
    {
      "id": "DeadLetterQueue",
      "kind": "AWS::SQS::Queue",
      "fields": {
        "VisibilityTimeout": 300
      },
      "effects": [
        "encrypted"
      ]
    }
  ],
  "edges": [
    {
      "type": "depends",
      "from": "MongoDBConnection",
      "to": "MongoDBApiDestination"
    },
    {
      "type": "depends",
      "from": "EventBridgeRole",
      "to": "MongoDBApiDestination"
    },
    {
      "type": "depends",
      "from": "DeadLetterQueue",
      "to": "MongoDBApiDestination"
    }
  ],
  "invariants": [
    "EventBridge must have IAM permissions to invoke MongoDB API endpoint",
    "MongoDB API key authentication must be securely stored",
    "Dead-letter queue must be configured for fault tolerance"
  ]
}