{
  "resources": [
    {
      "id": "SecurityHubControlManagerLambda",
      "kind": "AWS::Lambda::Function",
      "fields": {
        "Handler": "index.handler",
        "Runtime": "nodejs18.x",
        "Code": {
          "ZipFile": "exports.handler = async (event) => { /* Lambda logic here */ };"
        },
        "Timeout": 300,
        "MemorySize": 128,
        "Environment": {
          "Variables": {
            "DISABLE_CIS_140_CONTROLS": "false",
            "DISABLE_FOUNDATIONAL_BEST_PRACTICES": "false"
          }
        }
      },
      "effects": [
        "encrypted"
      ]
    },
    {
      "id": "SecurityHubControlManagerRole",
      "kind": "AWS::IAM::Role",
      "fields": {
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "lambda.amazonaws.com"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "Policies": [
          {
            "PolicyName": "SecurityHubControlManagerPolicy",
            "PolicyDocument": {
              "Version": "2012-10-17",
              "Statement": [
                {
                  "Effect": "Allow",
                  "Action": [
                    "securityhub:UpdateSecurityHubConfiguration",
                    "securityhub:DescribeStandardsControls",
                    "securityhub:BatchUpdateStandardsControls"
                  ],
                  "Resource": "*"
                }
              ]
            }
          }
        ]
      },
      "effects": [
        "encrypted"
      ]
    },
    {
      "id": "SecurityHubControlManagerLogGroup",
      "kind": "AWS::Logs::LogGroup",
      "fields": {
        "RetentionInDays": 30
      },
      "effects": [
        "encrypted"
      ]
    },
    {
      "id": "SecurityHubControlManagerPermissionBoundary",
      "kind": "AWS::IAM::ManagedPolicy",
      "fields": {
        "PolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Action": "*",
              "Resource": "*"
            }
          ]
        }
      },
      "effects": [
        "encrypted"
      ]
    }
  ],
  "edges": [
    {
      "type": "depends",
      "from": "SecurityHubControlManagerLambda",
      "to": "SecurityHubControlManagerRole"
    },
    {
      "type": "depends",
      "from": "SecurityHubControlManagerLambda",
      "to": "SecurityHubControlManagerLogGroup"
    },
    {
      "type": "connects",
      "from": "SecurityHubControlManagerLambda",
      "to": "SecurityHubControlManagerLogGroup",
      "proto": "https",
      "port": 443
    }
  ],
  "invariants": [
    "Lambda function must have IAM permissions to update Security Hub controls",
    "CloudWatch Logs retention policy must be configurable",
    "IAM role must support optional permissions boundary",
    "Security Hub controls must be selectively disabled based on user parameters"
  ]
}