{
  "resources": [
    {
      "id": "CustomEventBus",
      "kind": "AWS::EventBridge::EventBus",
      "fields": {
        "Name": "CustomEventBus"
      },
      "effects": [
        "custom-events"
      ]
    },
    {
      "id": "WebhookConnection",
      "kind": "AWS::EventBridge::Connection",
      "fields": {
        "Name": "WebhookConnection",
        "AuthorizationType": "API_KEY",
        "ApiKeyAuthParameters": {
          "ApiKeyName": "x-api-key",
          "ApiKey": "your-api-key-here"
        }
      },
      "effects": [
        "api-key-secured"
      ]
    },
    {
      "id": "WebhookAPIEndpoint",
      "kind": "AWS::EventBridge::ApiDestination",
      "fields": {
        "Name": "WebhookAPIEndpoint",
        "ConnectionArn": "arn:aws:events::connection/WebhookConnection",
        "InvocationEndpoint": "https://webhook.site/testtest",
        "HttpMethod": "POST"
      },
      "effects": [
        "https-endpoint",
        "webhook-site"
      ]
    }
  ],
  "edges": [
    {
      "type": "depends",
      "from": "WebhookConnection",
      "to": "WebhookAPIEndpoint"
    }
  ],
  "invariants": [
    "EventBridge event bus must route custom events to external HTTPS endpoint",
    "API key authentication required for secure connection",
    "Connection must be established before API destination can be created"
  ]
}