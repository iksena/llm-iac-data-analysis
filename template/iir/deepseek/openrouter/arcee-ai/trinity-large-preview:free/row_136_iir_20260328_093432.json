{
  "resources": [
    {
      "id": "IAMRoleWithBoundary",
      "kind": "AWS::IAM::Role",
      "fields": {
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "AWS": "arn:aws:iam::123456789012:root"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "PermissionsBoundary": {
          "Fn::If": [
            "EnableBoundaryEnforcement",
            {
              "Ref": "PermissionBoundaryPolicy"
            },
            "null"
          ]
        },
        "Policies": [
          {
            "PolicyName": "IAMFullAccessWithBoundary",
            "PolicyDocument": {
              "Version": "2012-10-17",
              "Statement": [
                {
                  "Effect": "Allow",
                  "Action": [
                    "iam:CreateRole",
                    "iam:DeleteRole",
                    "iam:UpdateRole",
                    "iam:AttachRolePolicy",
                    "iam:DetachRolePolicy",
                    "iam:PutRolePolicy",
                    "iam:DeleteRolePolicy",
                    "iam:CreatePolicy",
                    "iam:DeletePolicy",
                    "iam:CreatePolicyVersion",
                    "iam:DeletePolicyVersion",
                    "iam:SetDefaultPolicyVersion"
                  ],
                  "Resource": "*"
                }
              ]
            }
          }
        ]
      },
      "effects": [
        "encrypted",
        "versioned"
      ]
    },
    {
      "id": "IAMRoleWithoutBoundary",
      "kind": "AWS::IAM::Role",
      "fields": {
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "AWS": "arn:aws:iam::123456789012:root"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "Policies": [
          {
            "PolicyName": "IAMFullAccess",
            "PolicyDocument": {
              "Version": "2012-10-17",
              "Statement": [
                {
                  "Effect": "Allow",
                  "Action": [
                    "iam:*"
                  ],
                  "Resource": "*"
                }
              ]
            }
          }
        ]
      },
      "effects": [
        "encrypted",
        "versioned"
      ]
    },
    {
      "id": "PermissionBoundaryPolicy",
      "kind": "AWS::IAM::ManagedPolicy",
      "fields": {
        "PolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Action": [
                "s3:*"
              ],
              "Resource": "*"
            },
            {
              "Effect": "Allow",
              "Action": [
                "iam:Get*",
                "iam:List*"
              ],
              "Resource": "*"
            },
            {
              "Effect": "Deny",
              "Action": [
                "iam:CreateRole",
                "iam:DeleteRole",
                "iam:UpdateRole",
                "iam:AttachRolePolicy",
                "iam:DetachRolePolicy",
                "iam:PutRolePolicy",
                "iam:DeleteRolePolicy",
                "iam:CreatePolicy",
                "iam:DeletePolicy",
                "iam:CreatePolicyVersion",
                "iam:DeletePolicyVersion",
                "iam:SetDefaultPolicyVersion"
              ],
              "Resource": "*"
            }
          ]
        }
      },
      "effects": [
        "encrypted",
        "versioned"
      ]
    },
    {
      "id": "IAMPolicyValidation",
      "kind": "AWS::IAM::Policy",
      "fields": {
        "PolicyName": "IAMPolicyValidation",
        "PolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Action": [
                "iam:CreateRole",
                "iam:DeleteRole",
                "iam:UpdateRole",
                "iam:AttachRolePolicy",
                "iam:DetachRolePolicy",
                "iam:PutRolePolicy",
                "iam:DeleteRolePolicy",
                "iam:CreatePolicy",
                "iam:DeletePolicy",
                "iam:CreatePolicyVersion",
                "iam:DeletePolicyVersion",
                "iam:SetDefaultPolicyVersion"
              ],
              "Resource": "arn:aws:iam::123456789012:role/MyTeam*"
            },
            {
              "Effect": "Deny",
              "Action": [
                "iam:CreateRole",
                "iam:DeleteRole",
                "iam:UpdateRole",
                "iam:AttachRolePolicy",
                "iam:DetachRolePolicy",
                "iam:PutRolePolicy",
                "iam:DeleteRolePolicy",
                "iam:CreatePolicy",
                "iam:DeletePolicy",
                "iam:CreatePolicyVersion",
                "iam:DeletePolicyVersion",
                "iam:SetDefaultPolicyVersion"
              ],
              "Resource": "*"
            }
          ]
        }
      },
      "effects": [
        "encrypted",
        "versioned"
      ]
    },
    {
      "id": "IAMTagValidation",
      "kind": "AWS::IAM::Policy",
      "fields": {
        "PolicyName": "IAMTagValidation",
        "PolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Action": [
                "iam:CreateRole",
                "iam:DeleteRole",
                "iam:UpdateRole",
                "iam:AttachRolePolicy",
                "iam:DetachRolePolicy",
                "iam:PutRolePolicy",
                "iam:DeleteRolePolicy",
                "iam:CreatePolicy",
                "iam:DeletePolicy",
                "iam:CreatePolicyVersion",
                "iam:DeletePolicyVersion",
                "iam:SetDefaultPolicyVersion"
              ],
              "Resource": "*",
              "Condition": {
                "StringEquals": {
                  "iam:ResourceTag/Owner": "MyTeam"
                }
              }
            },
            {
              "Effect": "Deny",
              "Action": [
                "iam:CreateRole",
                "iam:DeleteRole",
                "iam:UpdateRole",
                "iam:AttachRolePolicy",
                "iam:DetachRolePolicy",
                "iam:PutRolePolicy",
                "iam:DeleteRolePolicy",
                "iam:CreatePolicy",
                "iam:DeletePolicy",
                "iam:CreatePolicyVersion",
                "iam:DeletePolicyVersion",
                "iam:SetDefaultPolicyVersion"
              ],
              "Resource": "*"
            }
          ]
        }
      },
      "effects": [
        "encrypted",
        "versioned"
      ]
    }
  ],
  "edges": [
    {
      "type": "depends",
      "from": "IAMRoleWithBoundary",
      "to": "PermissionBoundaryPolicy"
    },
    {
      "type": "depends",
      "from": "IAMPolicyValidation",
      "to": "IAMRoleWithBoundary"
    },
    {
      "type": "depends",
      "from": "IAMTagValidation",
      "to": "IAMRoleWithBoundary"
    }
  ],
  "invariants": [
    "IAM resources must have Owner tag",
    "IAM resources must follow MyTeam* naming prefix",
    "Permission boundary restricts to S3 and read-only IAM operations",
    "Toggle parameter controls strict boundary enforcement"
  ]
}