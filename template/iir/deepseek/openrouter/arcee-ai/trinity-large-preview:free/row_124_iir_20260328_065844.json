{
  "resources": [
    {
      "id": "MusicTable",
      "kind": "AWS::DynamoDB::Table",
      "fields": {
        "TableName": "Music",
        "KeySchema": [
          {
            "AttributeName": "Artist",
            "KeyType": "HASH"
          },
          {
            "AttributeName": "SongTitle",
            "KeyType": "RANGE"
          }
        ],
        "AttributeDefinitions": [
          {
            "AttributeName": "Artist",
            "AttributeType": "S"
          },
          {
            "AttributeName": "SongTitle",
            "AttributeType": "S"
          }
        ],
        "ProvisionedThroughput": {
          "ReadCapacityUnits": 5,
          "WriteCapacityUnits": 5
        },
        "GlobalSecondaryIndexes": [
          {
            "IndexName": "Artist-Index",
            "KeySchema": [
              {
                "AttributeName": "Artist",
                "KeyType": "HASH"
              }
            ],
            "Projection": {
              "ProjectionType": "ALL"
            },
            "ProvisionedThroughput": {
              "ReadCapacityUnits": 5,
              "WriteCapacityUnits": 5
            }
          }
        ]
      },
      "effects": [
        "encrypted"
      ]
    },
    {
      "id": "DynamoDBIAMRole",
      "kind": "AWS::IAM::Role",
      "fields": {
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "apigateway.amazonaws.com"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "Policies": [
          {
            "PolicyName": "DynamoDBAccess",
            "PolicyDocument": {
              "Version": "2012-10-17",
              "Statement": [
                {
                  "Effect": "Allow",
                  "Action": [
                    "dynamodb:PutItem",
                    "dynamodb:GetItem",
                    "dynamodb:Query",
                    "dynamodb:Scan"
                  ],
                  "Resource": {
                    "Fn::GetAtt": [
                      "MusicTable",
                      "Arn"
                    ]
                  }
                }
              ]
            }
          }
        ]
      },
      "effects": [
        "least-privilege"
      ]
    },
    {
      "id": "MusicAPI",
      "kind": "AWS::ApiGateway::RestApi",
      "fields": {
        "Name": "MusicAPI",
        "Description": "API for managing music data"
      },
      "effects": [
        "secured"
      ]
    },
    {
      "id": "MusicResource",
      "kind": "AWS::ApiGateway::Resource",
      "fields": {
        "ParentId": {
          "Fn::GetAtt": [
            "MusicAPI",
            "RootResourceId"
          ]
        },
        "PathPart": "music",
        "RestApiId": {
          "Ref": "MusicAPI"
        }
      },
      "effects": [
        "public-endpoint"
      ]
    },
    {
      "id": "PostMethod",
      "kind": "AWS::ApiGateway::Method",
      "fields": {
        "HttpMethod": "POST",
        "ResourceId": {
          "Ref": "MusicResource"
        },
        "RestApiId": {
          "Ref": "MusicAPI"
        },
        "AuthorizationType": "AWS_IAM",
        "ApiKeyRequired": true,
        "Integration": {
          "Type": "AWS",
          "IntegrationHttpMethod": "POST",
          "Uri": {
            "Fn::Join": [
              "",
              [
                "arn:aws:apigateway:",
                {
                  "Ref": "AWS::Region"
                },
                ":dynamodb:action/PutItem"
              ]
            ]
          },
          "Credentials": {
            "Fn::GetAtt": [
              "DynamoDBIAMRole",
              "Arn"
            ]
          },
          "RequestParameters": {
            "integration.request.header.Content-Type": "'application/x-amz-json-1.0'"
          },
          "RequestTemplates": {
            "application/json": {
              "Fn::Join": [
                "",
                [
                  "{\n",
                  "  \"TableName\": \"Music\",\n",
                  "  \"Item\": {\n",
                  "    \"Artist\": { \"S\": $input.json('$.artist') },\n",
                  "    \"SongTitle\": { \"S\": $input.json('$.songTitle') },\n",
                  "    \"Album\": { \"S\": $input.json('$.album') }\n",
                  "  }\n",
                  "}\n"
                ]
              ]
            }
          },
          "IntegrationResponses": [
            {
              "StatusCode": 200,
              "ResponseTemplates": {
                "application/json": "{\n  \"status\": \"success\"\n}"
              }
            }
          ]
        }
      },
      "effects": [
        "crud-create"
      ]
    },
    {
      "id": "GetMethod",
      "kind": "AWS::ApiGateway::Method",
      "fields": {
        "HttpMethod": "GET",
        "ResourceId": {
          "Ref": "MusicResource"
        },
        "RestApiId": {
          "Ref": "MusicAPI"
        },
        "AuthorizationType": "AWS_IAM",
        "ApiKeyRequired": true,
        "RequestParameters": {
          "method.request.querystring.artist": true
        },
        "Integration": {
          "Type": "AWS",
          "IntegrationHttpMethod": "POST",
          "Uri": {
            "Fn::Join": [
              "",
              [
                "arn:aws:apigateway:",
                {
                  "Ref": "AWS::Region"
                },
                ":dynamodb:action/Query"
              ]
            ]
          },
          "Credentials": {
            "Fn::GetAtt": [
              "DynamoDBIAMRole",
              "Arn"
            ]
          },
          "RequestParameters": {
            "integration.request.header.Content-Type": "'application/x-amz-json-1.0'",
            "integration.request.header.X-Amz-Target": "'DynamoDB_20120810.Query'"
          },
          "RequestTemplates": {
            "application/json": {
              "Fn::Join": [
                "",
                [
                  "{\n",
                  "  \"TableName\": \"Music\",\n",
                  "  \"IndexName\": \"Artist-Index\",\n",
                  "  \"KeyConditionExpression\": \"Artist = :artist\",\n",
                  "  \"ExpressionAttributeValues\": {\n",
                  "    \":artist\": { \"S\": \"$input.params('artist')\" }\n",
                  "  }\n",
                  "}\n"
                ]
              ]
            }
          },
          "IntegrationResponses": [
            {
              "StatusCode": 200,
              "ResponseTemplates": {
                "application/json": "#set($inputRoot = $input.path('$'))\n{\n  \"items\": [\n    #foreach($item in $inputRoot.Items)\n      {\n        \"artist\": \"$item.Artist.S\",\n        \"songTitle\": \"$item.SongTitle.S\",\n        \"album\": \"$item.Album.S\"\n      }#if($foreach.hasNext),#end\n    #end\n  ]\n}"
              }
            }
          ]
        }
      },
      "effects": [
        "crud-read"
      ]
    },
    {
      "id": "APIKey",
      "kind": "AWS::ApiGateway::ApiKey",
      "fields": {
        "Name": "MusicAPIAccessKey",
        "Description": "API key for Music API access"
      },
      "effects": [
        "secured"
      ]
    },
    {
      "id": "UsagePlan",
      "kind": "AWS::ApiGateway::UsagePlan",
      "fields": {
        "Name": "MusicAPIUsagePlan",
        "Description": "Usage plan with rate limiting",
        "ApiStages": [
          {
            "ApiId": {
              "Ref": "MusicAPI"
            },
            "Stage": {
              "Ref": "Deployment"
            }
          }
        ],
        "Throttle": {
          "BurstLimit": 100,
          "RateLimit": 50
        },
        "Quota": {
          "Limit": 1000,
          "Period": "MONTH"
        }
      },
      "effects": [
        "rate-limited"
      ]
    },
    {
      "id": "UsagePlanKey",
      "kind": "AWS::ApiGateway::UsagePlanKey",
      "fields": {
        "KeyId": {
          "Ref": "APIKey"
        },
        "KeyType": "API_KEY",
        "UsagePlanId": {
          "Ref": "UsagePlan"
        }
      },
      "effects": [
        "secured"
      ]
    },
    {
      "id": "Deployment",
      "kind": "AWS::ApiGateway::Deployment",
      "fields": {
        "RestApiId": {
          "Ref": "MusicAPI"
        },
        "Description": "Deployment of Music API"
      },
      "effects": [
        "public-endpoint"
      ]
    },
    {
      "id": "Stage",
      "kind": "AWS::ApiGateway::Stage",
      "fields": {
        "DeploymentId": {
          "Ref": "Deployment"
        },
        "RestApiId": {
          "Ref": "MusicAPI"
        },
        "StageName": "prod",
        "Description": "Production stage for Music API"
      },
      "effects": [
        "public-endpoint"
      ]
    }
  ],
  "edges": [
    {
      "type": "depends",
      "from": "DynamoDBIAMRole",
      "to": "MusicTable"
    },
    {
      "type": "depends",
      "from": "MusicResource",
      "to": "MusicAPI"
    },
    {
      "type": "depends",
      "from": "PostMethod",
      "to": "MusicResource"
    },
    {
      "type": "depends",
      "from": "GetMethod",
      "to": "MusicResource"
    },
    {
      "type": "depends",
      "from": "PostMethod",
      "to": "DynamoDBIAMRole"
    },
    {
      "type": "depends",
      "from": "GetMethod",
      "to": "DynamoDBIAMRole"
    },
    {
      "type": "depends",
      "from": "UsagePlan",
      "to": "Deployment"
    },
    {
      "type": "depends",
      "from": "UsagePlanKey",
      "to": "APIKey"
    },
    {
      "type": "depends",
      "from": "UsagePlanKey",
      "to": "UsagePlan"
    },
    {
      "type": "depends",
      "from": "Stage",
      "to": "Deployment"
    }
  ],
  "invariants": [
    "DynamoDB table must be encrypted at rest",
    "API Gateway must use IAM role for DynamoDB access",
    "API key authentication required for all endpoints",
    "Rate limiting and quota enforced via usage plan",
    "Global secondary index required for artist-based queries"
  ]
}