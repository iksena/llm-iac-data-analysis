{
  "resources": [
    {
      "id": "EC2Instance",
      "kind": "AWS::EC2::Instance",
      "fields": {
        "ImageId": "ami-0c55b159cbfafe0f0",
        "InstanceType": "t3.micro",
        "IamInstanceProfile": {
          "Ref": "InstanceProfile"
        },
        "Tags": [
          {
            "Key": "Name",
            "Value": "NginxInstance"
          },
          {
            "Key": "InstallNginx",
            "Value": "true"
          }
        ]
      },
      "effects": [
        "encrypted",
        "monitored"
      ]
    },
    {
      "id": "InstanceRole",
      "kind": "AWS::IAM::Role",
      "fields": {
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "ec2.amazonaws.com"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "ManagedPolicyArns": [
          {
            "Ref": "AWS::SSMManagedInstanceCore"
          }
        ]
      },
      "effects": [
        "ssm-access"
      ]
    },
    {
      "id": "InstanceProfile",
      "kind": "AWS::IAM::InstanceProfile",
      "fields": {
        "Roles": [
          {
            "Ref": "InstanceRole"
          }
        ]
      },
      "effects": [
        "ssm-access"
      ]
    },
    {
      "id": "S3Bucket",
      "kind": "AWS::S3::Bucket",
      "fields": {
        "BucketName": "nginx-logs-bucket",
        "AccessControl": "Private",
        "VersioningConfiguration": {
          "Status": "Enabled"
        }
      },
      "effects": [
        "encrypted",
        "versioned"
      ]
    },
    {
      "id": "S3BucketPolicy",
      "kind": "AWS::S3::BucketPolicy",
      "fields": {
        "Bucket": {
          "Ref": "S3Bucket"
        },
        "PolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "AWS": {
                  "Fn::GetAtt": [
                    "InstanceRole",
                    "Arn"
                  ]
                }
              },
              "Action": [
                "s3:PutObject",
                "s3:GetObject",
                "s3:ListBucket"
              ],
              "Resource": [
                {
                  "Fn::GetAtt": [
                    "S3Bucket",
                    "Arn"
                  ]
                },
                {
                  "Fn::Join": [
                    "",
                    [
                      {
                        "Fn::GetAtt": [
                          "S3Bucket",
                          "Arn"
                        ]
                      },
                      "/*"
                    ]
                  ]
                }
              ]
            }
          ]
        }
      },
      "effects": [
        "s3-access"
      ]
    },
    {
      "id": "SSMAssociation",
      "kind": "AWS::SSM::Association",
      "fields": {
        "Name": "AWS-ConfigureS3Bucket",
        "Targets": [
          {
            "Key": "tag:InstallNginx",
            "Values": [
              "true"
            ]
          }
        ],
        "Parameters": {
          "installNginx": [
            "true"
          ],
          "s3BucketName": [
            {
              "Ref": "S3Bucket"
            }
          ]
        },
        "ScheduleExpression": "rate(1 hour)"
      },
      "effects": [
        "auto-config"
      ]
    },
    {
      "id": "CloudWatchAlarm",
      "kind": "AWS::CloudWatch::Alarm",
      "fields": {
        "AlarmName": "HighCPUUtilization",
        "ComparisonOperator": "GreaterThanThreshold",
        "EvaluationPeriods": 1,
        "MetricName": "CPUUtilization",
        "Namespace": "AWS/EC2",
        "Period": 300,
        "Statistic": "Average",
        "Threshold": 80,
        "AlarmActions": [],
        "Dimensions": [
          {
            "Name": "InstanceId",
            "Value": {
              "Ref": "EC2Instance"
            }
          }
        ]
      },
      "effects": [
        "monitored"
      ]
    }
  ],
  "edges": [
    {
      "type": "depends",
      "from": "InstanceProfile",
      "to": "InstanceRole"
    },
    {
      "type": "depends",
      "from": "EC2Instance",
      "to": "InstanceProfile"
    },
    {
      "type": "depends",
      "from": "S3BucketPolicy",
      "to": "S3Bucket"
    },
    {
      "type": "depends",
      "from": "SSMAssociation",
      "to": "EC2Instance"
    },
    {
      "type": "depends",
      "from": "SSMAssociation",
      "to": "S3Bucket"
    },
    {
      "type": "depends",
      "from": "CloudWatchAlarm",
      "to": "EC2Instance"
    }
  ],
  "invariants": [
    "EC2 instance must have SSM permissions",
    "Nginx installation must be tag-driven",
    "Logs must be centralized in S3",
    "Instance must be monitored via CloudWatch",
    "S3 bucket must be encrypted and versioned"
  ]
}