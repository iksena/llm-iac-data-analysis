{
  "resources": [
    {
      "id": "WebServerLaunchTemplate",
      "kind": "AWS::EC2::LaunchTemplate",
      "fields": {
        "LaunchTemplateName": "WebServerLaunchTemplate",
        "LaunchTemplateData": {
          "IamInstanceProfile": {
            "Arn": "arn:aws:iam::123456789012:instance-profile/EC2SSMRole"
          },
          "UserData": {
            "Fn::Base64": {
              "Fn::Join": [
                "",
                [
                  "#!/bin/bash\n",
                  "yum update -y\n",
                  "yum install -y httpd\n",
                  "systemctl start httpd\n",
                  "systemctl enable httpd\n",
                  "echo '<html><body><h1>Web Server Instance ID: ",
                  {
                    "Ref": "AWS::InstanceId"
                  },
                  "</h1></body></html>' > /var/www/html/index.html\n"
                ]
              ]
            }
          }
        }
      },
      "effects": [
        "encrypted"
      ]
    },
    {
      "id": "WebServerAutoScalingGroup",
      "kind": "AWS::AutoScaling::AutoScalingGroup",
      "fields": {
        "VPCZoneIdentifier": [
          {
            "Ref": "PublicSubnet1"
          },
          {
            "Ref": "PublicSubnet2"
          }
        ],
        "LaunchTemplate": {
          "LaunchTemplateId": {
            "Ref": "WebServerLaunchTemplate"
          },
          "Version": {
            "Fn::GetAtt": [
              "WebServerLaunchTemplate",
              "LatestVersionNumber"
            ]
          }
        },
        "MinSize": "2",
        "MaxSize": "4",
        "DesiredCapacity": "2"
      },
      "effects": [
        "encrypted"
      ]
    },
    {
      "id": "WebServerTargetGroup",
      "kind": "AWS::ElasticLoadBalancingV2::TargetGroup",
      "fields": {
        "HealthCheckIntervalSeconds": 30,
        "HealthCheckPath": "/",
        "HealthCheckProtocol": "HTTP",
        "HealthCheckTimeoutSeconds": 5,
        "HealthyThresholdCount": 2,
        "Matcher": {
          "HttpCode": "200"
        },
        "Name": "WebServerTargetGroup",
        "Port": 80,
        "Protocol": "HTTP",
        "TargetType": "instance",
        "UnhealthyThresholdCount": 2,
        "VpcId": {
          "Ref": "VPC"
        }
      },
      "effects": [
        "encrypted"
      ]
    },
    {
      "id": "WebServerLoadBalancer",
      "kind": "AWS::ElasticLoadBalancingV2::LoadBalancer",
      "fields": {
        "Name": "WebServerLoadBalancer",
        "Scheme": "internet-facing",
        "Subnets": [
          {
            "Ref": "PublicSubnet1"
          },
          {
            "Ref": "PublicSubnet2"
          }
        ],
        "Type": "application"
      },
      "effects": [
        "public-read"
      ]
    },
    {
      "id": "WebServerLoadBalancerListener",
      "kind": "AWS::ElasticLoadBalancingV2::Listener",
      "fields": {
        "DefaultActions": [
          {
            "Type": "forward",
            "TargetGroupArn": {
              "Ref": "WebServerTargetGroup"
            }
          }
        ],
        "LoadBalancerArn": {
          "Ref": "WebServerLoadBalancer"
        },
        "Port": 80,
        "Protocol": "HTTP"
      },
      "effects": [
        "public-read"
      ]
    },
    {
      "id": "WebServerSecurityGroup",
      "kind": "AWS::EC2::SecurityGroup",
      "fields": {
        "GroupDescription": "Security group for web servers",
        "SecurityGroupEgress": [
          {
            "CidrIp": "0.0.0.0/0",
            "FromPort": 0,
            "IpProtocol": "-1",
            "ToPort": 0
          }
        ],
        "SecurityGroupIngress": [
          {
            "FromPort": 80,
            "IpProtocol": "tcp",
            "SourceSecurityGroupId": {
              "Ref": "LoadBalancerSecurityGroup"
            },
            "ToPort": 80
          }
        ],
        "VpcId": {
          "Ref": "VPC"
        }
      },
      "effects": [
        "encrypted"
      ]
    },
    {
      "id": "LoadBalancerSecurityGroup",
      "kind": "AWS::EC2::SecurityGroup",
      "fields": {
        "GroupDescription": "Security group for load balancer",
        "SecurityGroupEgress": [
          {
            "CidrIp": "0.0.0.0/0",
            "FromPort": 0,
            "IpProtocol": "-1",
            "ToPort": 0
          }
        ],
        "SecurityGroupIngress": [
          {
            "CidrIp": "0.0.0.0/0",
            "FromPort": 80,
            "IpProtocol": "tcp",
            "ToPort": 80
          }
        ],
        "VpcId": {
          "Ref": "VPC"
        }
      },
      "effects": [
        "public-read"
      ]
    },
    {
      "id": "EC2SSMRole",
      "kind": "AWS::IAM::Role",
      "fields": {
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Action": "sts:AssumeRole",
              "Effect": "Allow",
              "Principal": {
                "Service": "ec2.amazonaws.com"
              }
            }
          ]
        },
        "ManagedPolicyArns": [
          "arn:aws:iam::aws:policy/service-role/AmazonEC2RoleforSSM"
        ]
      },
      "effects": [
        "encrypted"
      ]
    },
    {
      "id": "EC2SSMInstanceProfile",
      "kind": "AWS::IAM::InstanceProfile",
      "fields": {
        "Roles": [
          {
            "Ref": "EC2SSMRole"
          }
        ]
      },
      "effects": [
        "encrypted"
      ]
    },
    {
      "id": "VPC",
      "kind": "AWS::EC2::VPC",
      "fields": {
        "CidrBlock": "10.0.0.0/16",
        "EnableDnsSupport": true,
        "EnableDnsHostnames": true
      },
      "effects": [
        "encrypted"
      ]
    },
    {
      "id": "PublicSubnet1",
      "kind": "AWS::EC2::Subnet",
      "fields": {
        "AvailabilityZone": {
          "Fn::Select": [
            0,
            {
              "Fn::GetAZs": ""
            }
          ]
        },
        "CidrBlock": "10.0.1.0/24",
        "VpcId": {
          "Ref": "VPC"
        }
      },
      "effects": [
        "encrypted"
      ]
    },
    {
      "id": "PublicSubnet2",
      "kind": "AWS::EC2::Subnet",
      "fields": {
        "AvailabilityZone": {
          "Fn::Select": [
            1,
            {
              "Fn::GetAZs": ""
            }
          ]
        },
        "CidrBlock": "10.0.2.0/24",
        "VpcId": {
          "Ref": "VPC"
        }
      },
      "effects": [
        "encrypted"
      ]
    }
  ],
  "edges": [
    {
      "type": "depends",
      "from": "WebServerLaunchTemplate",
      "to": "EC2SSMInstanceProfile"
    },
    {
      "type": "depends",
      "from": "WebServerAutoScalingGroup",
      "to": "WebServerLaunchTemplate"
    },
    {
      "type": "depends",
      "from": "WebServerAutoScalingGroup",
      "to": "PublicSubnet1"
    },
    {
      "type": "depends",
      "from": "WebServerAutoScalingGroup",
      "to": "PublicSubnet2"
    },
    {
      "type": "depends",
      "from": "WebServerTargetGroup",
      "to": "VPC"
    },
    {
      "type": "depends",
      "from": "WebServerLoadBalancer",
      "to": "PublicSubnet1"
    },
    {
      "type": "depends",
      "from": "WebServerLoadBalancer",
      "to": "PublicSubnet2"
    },
    {
      "type": "depends",
      "from": "WebServerLoadBalancerListener",
      "to": "WebServerLoadBalancer"
    },
    {
      "type": "depends",
      "from": "WebServerLoadBalancerListener",
      "to": "WebServerTargetGroup"
    },
    {
      "type": "depends",
      "from": "WebServerSecurityGroup",
      "to": "VPC"
    },
    {
      "type": "depends",
      "from": "LoadBalancerSecurityGroup",
      "to": "VPC"
    },
    {
      "type": "depends",
      "from": "EC2SSMInstanceProfile",
      "to": "EC2SSMRole"
    },
    {
      "type": "depends",
      "from": "PublicSubnet1",
      "to": "VPC"
    },
    {
      "type": "depends",
      "from": "PublicSubnet2",
      "to": "VPC"
    }
  ],
  "invariants": [
    "EC2 instances must have IAM role for SSM access",
    "Web server traffic must be restricted to ALB only",
    "Load balancer must be internet-facing for public access",
    "Auto Scaling group must span multiple Availability Zones",
    "Instances must dynamically generate unique HTML pages"
  ]
}