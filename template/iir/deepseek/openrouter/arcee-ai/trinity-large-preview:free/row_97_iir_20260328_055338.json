{
  "resources": [
    {
      "id": "DataBucket",
      "kind": "AWS::S3::Bucket",
      "fields": {
        "BucketName": "organization-data-store",
        "BucketEncryption": {
          "ServerSideEncryptionConfiguration": [
            {
              "ServerSideEncryptionByDefault": {
                "SSEAlgorithm": "AES256"
              }
            }
          ]
        },
        "AccessControl": "Private",
        "PublicAccessBlockConfiguration": {
          "BlockPublicAcls": true,
          "IgnorePublicAcls": true,
          "BlockPublicPolicy": true,
          "RestrictPublicBuckets": true
        },
        "VersioningConfiguration": {
          "Status": "Enabled"
        }
      },
      "effects": [
        "encrypted",
        "versioned",
        "private"
      ]
    },
    {
      "id": "LambdaExecutionRole",
      "kind": "AWS::IAM::Role",
      "fields": {
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "lambda.amazonaws.com"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "Policies": [
          {
            "PolicyName": "OrganizationsAccess",
            "PolicyDocument": {
              "Version": "2012-10-17",
              "Statement": [
                {
                  "Effect": "Allow",
                  "Action": [
                    "organizations:Describe*",
                    "organizations:List*"
                  ],
                  "Resource": "*"
                },
                {
                  "Effect": "Allow",
                  "Action": [
                    "sts:AssumeRole"
                  ],
                  "Resource": {
                    "Fn::Sub": "arn:aws:iam::${ManagementAccountId}:role/OrganizationCrossAccountRole"
                  }
                },
                {
                  "Effect": "Allow",
                  "Action": "s3:PutObject",
                  "Resource": {
                    "Fn::Sub": "arn:aws:s3:::${DataBucket}/*"
                  }
                }
              ]
            }
          }
        ]
      },
      "effects": [
        "cross-account",
        "organizations-read",
        "s3-write"
      ]
    },
    {
      "id": "OrganizationDataLambda",
      "kind": "AWS::Lambda::Function",
      "fields": {
        "Handler": "index.handler",
        "Runtime": "nodejs18.x",
        "Role": {
          "Fn::GetAtt": [
            "LambdaExecutionRole",
            "Arn"
          ]
        },
        "Timeout": 300,
        "MemorySize": 256,
        "Environment": {
          "Variables": {
            "TARGET_BUCKET": {
              "Ref": "DataBucket"
            },
            "TAGS_TO_INCLUDE": {
              "Ref": "TagsToInclude"
            },
            "MANAGEMENT_ACCOUNT_ID": {
              "Ref": "ManagementAccountId"
            }
          }
        }
      },
      "effects": [
        "cross-account",
        "organizations-metadata-collection"
      ]
    },
    {
      "id": "CloudWatchEventRule",
      "kind": "AWS::Events::Rule",
      "fields": {
        "ScheduleExpression": "rate(7 days)",
        "Targets": [
          {
            "Arn": {
              "Fn::GetAtt": [
                "OrganizationDataLambda",
                "Arn"
              ]
            },
            "Id": "OrganizationDataCollection"
          }
        ]
      },
      "effects": [
        "weekly-schedule"
      ]
    },
    {
      "id": "LambdaInvokePermission",
      "kind": "AWS::Lambda::Permission",
      "fields": {
        "FunctionName": {
          "Fn::GetAtt": [
            "OrganizationDataLambda",
            "Arn"
          ]
        },
        "Action": "lambda:InvokeFunction",
        "Principal": "events.amazonaws.com",
        "SourceArn": {
          "Fn::GetAtt": [
            "CloudWatchEventRule",
            "Arn"
          ]
        }
      },
      "effects": [
        "cloudwatch-events-trigger"
      ]
    },
    {
      "id": "GlueCrawlerRole",
      "kind": "AWS::IAM::Role",
      "fields": {
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "glue.amazonaws.com"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "Policies": [
          {
            "PolicyName": "GlueS3Access",
            "PolicyDocument": {
              "Version": "2012-10-17",
              "Statement": [
                {
                  "Effect": "Allow",
                  "Action": [
                    "s3:Get*",
                    "s3:List*"
                  ],
                  "Resource": {
                    "Fn::Sub": "arn:aws:s3:::${DataBucket}/*"
                  }
                },
                {
                  "Effect": "Allow",
                  "Action": "s3:PutObject",
                  "Resource": {
                    "Fn::Sub": "arn:aws:s3:::aws-glue-*/*"
                  }
                }
              ]
            }
          }
        ]
      },
      "effects": [
        "s3-read-write",
        "glue-crawler"
      ]
    },
    {
      "id": "GlueCrawler",
      "kind": "AWS::Glue::Crawler",
      "fields": {
        "Name": "OrganizationDataCrawler",
        "DatabaseName": {
          "Ref": "AthenaDatabaseName"
        },
        "Role": {
          "Fn::GetAtt": [
            "GlueCrawlerRole",
            "Arn"
          ]
        },
        "Targets": {
          "S3Targets": [
            {
              "Path": {
                "Fn::Sub": "s3://${DataBucket}/"
              }
            }
          ]
        },
        "Schedule": {
          "ScheduleExpression": "cron(0 2 * * ? *)"
        },
        "SchemaChangePolicy": {
          "UpdateBehavior": "UPDATE_IN_DATABASE",
          "DeleteBehavior": "DEPRECATE_IN_DATABASE"
        }
      },
      "effects": [
        "automatic-cataloging",
        "athena-integration"
      ]
    }
  ],
  "edges": [
    {
      "type": "depends",
      "from": "LambdaExecutionRole",
      "to": "OrganizationDataLambda"
    },
    {
      "type": "depends",
      "from": "DataBucket",
      "to": "OrganizationDataLambda"
    },
    {
      "type": "depends",
      "from": "CloudWatchEventRule",
      "to": "LambdaInvokePermission"
    },
    {
      "type": "depends",
      "from": "GlueCrawlerRole",
      "to": "GlueCrawler"
    },
    {
      "type": "depends",
      "from": "DataBucket",
      "to": "GlueCrawler"
    }
  ],
  "invariants": [
    "S3 bucket must be encrypted at rest with AES-256",
    "Lambda must have cross-account STS assume role capability",
    "Glue crawler must have S3 read/write permissions",
    "CloudWatch Events must trigger Lambda weekly",
    "Athena database must be created before crawler runs"
  ]
}