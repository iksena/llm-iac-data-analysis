{
  "resources": [
    {
      "id": "PartnerAppEventBus",
      "kind": "AWS::Events::EventBus",
      "fields": {
        "Name": "PartnerAppEventBus"
      },
      "effects": [
        "event-bus"
      ]
    },
    {
      "id": "StripeApiDestination",
      "kind": "AWS::Events::ApiDestination",
      "fields": {
        "Name": "StripeProductApi",
        "Description": "API destination for Stripe product creation",
        "InvocationEndpoint": "https://api.stripe.com/v1/products",
        "HttpMethod": "POST",
        "ConnectionArn": {
          "Ref": "StripeConnection"
        },
        "InvocationRateLimitPerSecond": 5
      },
      "effects": [
        "api-destination",
        "stripe-integration"
      ]
    },
    {
      "id": "StripeConnection",
      "kind": "AWS::Events::ApiDestination",
      "fields": {
        "Name": "StripeApiConnection",
        "Description": "Connection to Stripe API",
        "AuthorizationType": "API_KEY",
        "ApiKey": {
          "Ref": "StripeApiKey"
        },
        "ApiKeyName": "Authorization"
      },
      "effects": [
        "api-connection",
        "stripe-integration"
      ]
    },
    {
      "id": "PartnerAppRule",
      "kind": "AWS::Events::Rule",
      "fields": {
        "EventBusName": {
          "Ref": "PartnerAppEventBus"
        },
        "EventPattern": {
          "source": [
            "PartnerApp"
          ],
          "detail-type": [
            "PartnerAppDetailType"
          ]
        },
        "State": "ENABLED",
        "Targets": [
          {
            "Id": "StripeProductTarget",
            "Arn": {
              "Ref": "StripeApiDestination"
            }
          }
        ]
      },
      "effects": [
        "event-rule",
        "stripe-integration"
      ]
    }
  ],
  "edges": [
    {
      "type": "depends",
      "from": "StripeApiDestination",
      "to": "StripeConnection"
    },
    {
      "type": "depends",
      "from": "PartnerAppRule",
      "to": "PartnerAppEventBus"
    },
    {
      "type": "depends",
      "from": "PartnerAppRule",
      "to": "StripeApiDestination"
    }
  ],
  "invariants": [
    "EventBridge event bus captures PartnerApp events with source 'PartnerApp' and detail-type 'PartnerAppDetailType'",
    "API destination targets Stripe's product creation endpoint with POST method",
    "API key authentication uses 'Authorization' header with provided Stripe API key",
    "Rate limiting of 5 requests per second to Stripe API",
    "Event-driven automation of Stripe product creation based on application events"
  ]
}