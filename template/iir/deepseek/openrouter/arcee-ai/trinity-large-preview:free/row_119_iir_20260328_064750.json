{
  "resources": [
    {
      "id": "EventBus",
      "kind": "AWS::Events::EventBus",
      "fields": {
        "Name": "my-application-events"
      },
      "effects": [
        "event-capture"
      ]
    },
    {
      "id": "KinesisStream",
      "kind": "AWS::Kinesis::Stream",
      "fields": {
        "ShardCount": 1
      },
      "effects": [
        "event-ingestion",
        "buffering"
      ]
    },
    {
      "id": "EventBridgeKinesisRole",
      "kind": "AWS::IAM::Role",
      "fields": {
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "events.amazonaws.com"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "Policies": [
          {
            "PolicyName": "EventBridgeToKinesis",
            "PolicyDocument": {
              "Version": "2012-10-17",
              "Statement": [
                {
                  "Effect": "Allow",
                  "Action": "kinesis:PutRecord",
                  "Resource": {
                    "Fn::GetAtt": [
                      "KinesisStream",
                      "Arn"
                    ]
                  }
                }
              ]
            }
          }
        ]
      },
      "effects": [
        "eventbridge-kinesis-permission"
      ]
    },
    {
      "id": "EventBridgeRule",
      "kind": "AWS::Events::Rule",
      "fields": {
        "EventPattern": {
          "source": [
            "my-application"
          ]
        },
        "State": "ENABLED",
        "Targets": [
          {
            "Arn": {
              "Fn::GetAtt": [
                "KinesisStream",
                "Arn"
              ]
            },
            "Id": "KinesisTarget",
            "RoleArn": {
              "Fn::GetAtt": [
                "EventBridgeKinesisRole",
                "Arn"
              ]
            }
          }
        ]
      },
      "effects": [
        "event-routing"
      ]
    }
  ],
  "edges": [
    {
      "type": "depends",
      "from": "EventBridgeKinesisRole",
      "to": "KinesisStream"
    },
    {
      "type": "depends",
      "from": "EventBridgeRule",
      "to": "EventBus"
    },
    {
      "type": "depends",
      "from": "EventBridgeRule",
      "to": "KinesisStream"
    },
    {
      "type": "depends",
      "from": "EventBridgeRule",
      "to": "EventBridgeKinesisRole"
    }
  ],
  "invariants": [
    "EventBridge must have permission to publish to Kinesis",
    "Kinesis stream must exist before EventBridge rule targets it",
    "EventBridge rule must be associated with the correct event bus"
  ]
}