{
  "resources": [
    {
      "id": "VPCFlowLog",
      "kind": "AWS::EC2::FlowLog",
      "fields": {
        "ResourceId": "VPC",
        "ResourceType": "VPC",
        "TrafficType": "ALL",
        "LogDestinationType": "s3",
        "LogDestination": "S3BucketArn",
        "LogFormat": "$version $vpcId $subnetId $instanceId $srcaddr $dstaddr $srcport $dstport $protocol $bytes $start $end $action $logStatus"
      },
      "effects": [
        "encrypted",
        "versioned"
      ]
    },
    {
      "id": "VPC",
      "kind": "AWS::EC2::VPC",
      "fields": {
        "CidrBlock": "10.0.0.0/16",
        "EnableDnsSupport": true,
        "EnableDnsHostnames": true
      },
      "effects": [
        "public"
      ]
    },
    {
      "id": "S3Bucket",
      "kind": "AWS::S3::Bucket",
      "fields": {
        "BucketName": "vpc-flow-logs-bucket",
        "PublicAccessBlockConfiguration": {
          "BlockPublicAcls": true,
          "BlockPublicPolicy": true,
          "IgnorePublicAcls": true,
          "RestrictPublicBuckets": true
        },
        "BucketEncryption": {
          "ServerSideEncryptionConfiguration": [
            {
              "ServerSideEncryptionByDefault": {
                "SSEAlgorithm": "AES256"
              }
            }
          ]
        },
        "VersioningConfiguration": {
          "Status": "Enabled"
        },
        "LifecycleConfiguration": {
          "Rules": [
            {
              "Id": "TransitionToGlacier",
              "Status": "Enabled",
              "Transition": {
                "Days": 30,
                "StorageClass": "GLACIER"
              }
            }
          ]
        }
      },
      "effects": [
        "encrypted",
        "versioned"
      ]
    },
    {
      "id": "S3BucketPolicy",
      "kind": "AWS::S3::BucketPolicy",
      "fields": {
        "Bucket": "S3Bucket",
        "PolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "vpc-flow-logs.amazonaws.com"
              },
              "Action": [
                "s3:PutObject"
              ],
              "Resource": "S3BucketArn/*",
              "Condition": {
                "StringEquals": {
                  "s3:x-amz-acl": "bucket-owner-full-control"
                }
              }
            },
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "delivery.logs.amazonaws.com"
              },
              "Action": "s3:PutObject",
              "Resource": "S3BucketArn/*",
              "Condition": {
                "StringEquals": {
                  "s3:x-amz-acl": "bucket-owner-full-control"
                }
              }
            },
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "delivery.logs.amazonaws.com"
              },
              "Action": "s3:GetBucketAcl",
              "Resource": "S3BucketArn"
            }
          ]
        }
      },
      "effects": [
        "encrypted"
      ]
    }
  ],
  "edges": [
    {
      "type": "depends",
      "from": "VPCFlowLog",
      "to": "VPC"
    },
    {
      "type": "depends",
      "from": "VPCFlowLog",
      "to": "S3Bucket"
    },
    {
      "type": "depends",
      "from": "S3BucketPolicy",
      "to": "S3Bucket"
    }
  ],
  "invariants": [
    "VPC flow logs must capture all traffic types",
    "S3 bucket must block all public access",
    "SSL/TLS must be enforced for all S3 data transfers",
    "IAM permissions must be minimal and specific to log delivery services",
    "Log files must include comprehensive metadata fields",
    "Bucket versioning must be enabled for data protection",
    "Logs must be encrypted at rest using AES-256",
    "Lifecycle policies must transition logs to Glacier after 30 days"
  ]
}