{
  "resources": [
    {
      "id": "VPC",
      "kind": "AWS::EC2::VPC",
      "fields": {
        "CidrBlock": "10.0.0.0/16",
        "EnableDnsSupport": true,
        "EnableDnsHostnames": true
      },
      "effects": [
        "vpc"
      ]
    },
    {
      "id": "InternetGateway",
      "kind": "AWS::EC2::InternetGateway",
      "fields": {},
      "effects": [
        "public"
      ]
    },
    {
      "id": "VPCGatewayAttachment",
      "kind": "AWS::EC2::VPCGatewayAttachment",
      "fields": {
        "VpcId": "VPC",
        "InternetGatewayId": "InternetGateway"
      },
      "effects": []
    },
    {
      "id": "PublicRouteTable",
      "kind": "AWS::EC2::RouteTable",
      "fields": {
        "VpcId": "VPC"
      },
      "effects": [
        "public"
      ]
    },
    {
      "id": "PublicRoute",
      "kind": "AWS::EC2::Route",
      "fields": {
        "RouteTableId": "PublicRouteTable",
        "DestinationCidrBlock": "0.0.0.0/0",
        "GatewayId": "InternetGateway"
      },
      "effects": [
        "public"
      ]
    },
    {
      "id": "PublicSubnet",
      "kind": "AWS::EC2::Subnet",
      "fields": {
        "VpcId": "VPC",
        "CidrBlock": "10.0.1.0/24",
        "AvailabilityZone": "us-east-1a"
      },
      "effects": [
        "public"
      ]
    },
    {
      "id": "PublicSubnetRouteTableAssociation",
      "kind": "AWS::EC2::SubnetRouteTableAssociation",
      "fields": {
        "SubnetId": "PublicSubnet",
        "RouteTableId": "PublicRouteTable"
      },
      "effects": []
    },
    {
      "id": "SecurityGroup",
      "kind": "AWS::EC2::SecurityGroup",
      "fields": {
        "GroupDescription": "Allow SSH and HTTP access",
        "VpcId": "VPC",
        "SecurityGroupIngress": [
          {
            "IpProtocol": "tcp",
            "FromPort": 22,
            "ToPort": 22,
            "CidrIp": "0.0.0.0/0"
          },
          {
            "IpProtocol": "tcp",
            "FromPort": 80,
            "ToPort": 80,
            "CidrIp": "0.0.0.0/0"
          }
        ],
        "SecurityGroupEgress": [
          {
            "IpProtocol": "-1",
            "CidrIp": "0.0.0.0/0"
          }
        ]
      },
      "effects": [
        "public",
        "ssh",
        "http"
      ]
    }
  ],
  "edges": [
    {
      "type": "depends",
      "from": "InternetGateway",
      "to": "VPC"
    },
    {
      "type": "depends",
      "from": "VPCGatewayAttachment",
      "to": "VPC"
    },
    {
      "type": "depends",
      "from": "VPCGatewayAttachment",
      "to": "InternetGateway"
    },
    {
      "type": "depends",
      "from": "PublicRouteTable",
      "to": "VPC"
    },
    {
      "type": "depends",
      "from": "PublicRoute",
      "to": "PublicRouteTable"
    },
    {
      "type": "depends",
      "from": "PublicRoute",
      "to": "InternetGateway"
    },
    {
      "type": "depends",
      "from": "PublicSubnet",
      "to": "VPC"
    },
    {
      "type": "depends",
      "from": "PublicSubnetRouteTableAssociation",
      "to": "PublicSubnet"
    },
    {
      "type": "depends",
      "from": "PublicSubnetRouteTableAssociation",
      "to": "PublicRouteTable"
    },
    {
      "type": "depends",
      "from": "SecurityGroup",
      "to": "VPC"
    }
  ],
  "invariants": [
    "VPC must have internet connectivity",
    "Security group must allow SSH and HTTP ingress from anywhere",
    "Security group must allow all egress traffic"
  ]
}