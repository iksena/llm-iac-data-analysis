{
  "resources": [
    {
      "id": "AutomationRole",
      "kind": "AWS::IAM::Role",
      "fields": {
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": [
                  "ec2.amazonaws.com",
                  "ssm.amazonaws.com"
                ]
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "Path": "/",
        "ManagedPolicyArns": [
          "arn:aws:iam::aws:policy/service-role/AmazonEC2RoleforSSM",
          "arn:aws:iam::aws:policy/CloudWatchAgentServerPolicy"
        ]
      },
      "effects": [
        "automation",
        "cross-service"
      ]
    },
    {
      "id": "AutomationInstanceProfile",
      "kind": "AWS::IAM::InstanceProfile",
      "fields": {
        "Path": "/",
        "Roles": [
          {
            "Ref": "AutomationRole"
          }
        ]
      },
      "effects": [
        "automation",
        "cross-service"
      ]
    }
  ],
  "edges": [
    {
      "type": "depends",
      "from": "AutomationInstanceProfile",
      "to": "AutomationRole"
    }
  ],
  "invariants": [
    "IAM role must allow EC2 and SSM services to assume it",
    "Instance profile must reference the IAM role",
    "Managed policies should include SSM and CloudWatch agent permissions"
  ]
}