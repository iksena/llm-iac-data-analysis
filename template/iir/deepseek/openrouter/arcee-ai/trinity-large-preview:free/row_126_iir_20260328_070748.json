                    "kinesis:DescribeStream",
                    "kinesis:ListStreams"
                  ],
                  "Resource": {
                    "Fn::GetAtt": [
                      "KinesisStream",
                      "Arn"
                    ]
                  }
                }
              ]
            }
          }
        ]
      },
      "effects": [
