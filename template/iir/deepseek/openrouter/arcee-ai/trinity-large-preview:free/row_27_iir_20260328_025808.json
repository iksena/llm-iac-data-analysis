{
  "resources": [
    {
      "id": "KinesisDataStream",
      "kind": "AWS::Kinesis::Stream",
      "fields": {
        "Name": "RealTimeDataStream",
        "ShardCount": 1
      },
      "effects": [
        "real-time-ingestion"
      ]
    },
    {
      "id": "S3Bucket",
      "kind": "AWS::S3::Bucket",
      "fields": {
        "BucketName": "data-ingestion-bucket"
      },
      "effects": [
        "encrypted",
        "versioned"
      ]
    },
    {
      "id": "KinesisFirehoseDeliveryStream",
      "kind": "AWS::KinesisFirehose::DeliveryStream",
      "fields": {
        "DeliveryStreamName": "FirehoseToS3",
        "DeliveryStreamType": "KinesisStreamAsSource",
        "KinesisStreamSourceConfiguration": {
          "KinesisStreamARN": {
            "Ref": "KinesisDataStream"
          },
          "RoleARN": {
            "Fn::GetAtt": [
              "FirehoseRole",
              "Arn"
            ]
          }
        },
        "DestinationId": "S3Destination",
        "S3DestinationConfiguration": {
          "BucketARN": {
            "Fn::GetAtt": [
              "S3Bucket",
              "Arn"
            ]
          },
          "RoleARN": {
            "Fn::GetAtt": [
              "FirehoseRole",
              "Arn"
            ]
          },
          "Prefix": "kinesis/",
          "ErrorOutputPrefix": "error/",
          "BufferingHints": {
            "SizeInMBs": 5,
            "IntervalInSeconds": 300
          },
          "CompressionFormat": "UNCOMPRESSED",
          "EncryptionConfiguration": {
            "NoEncryptionConfig": "NoEncryption"
          }
        }
      },
      "effects": [
        "public-read"
      ]
    },
    {
      "id": "FirehoseRole",
      "kind": "AWS::IAM::Role",
      "fields": {
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "firehose.amazonaws.com"
              },
              "Action": "sts:AssumeRole",
              "Condition": {
                "StringEquals": {
                  "sts:ExternalId": {
                    "Ref": "AWS::AccountId"
                  }
                }
              }
            }
          ]
        },
        "Path": "/"
      },
      "effects": []
    },
    {
      "id": "FirehosePolicy",
      "kind": "AWS::IAM::Policy",
      "fields": {
        "PolicyName": "FirehoseAccessPolicy",
        "PolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Action": [
                "kinesis:DescribeStream",
                "kinesis:GetShardIterator",
                "kinesis:GetRecords",
                "kinesis:ListStreams"
              ],
              "Resource": {
                "Fn::GetAtt": [
                  "KinesisDataStream",
                  "Arn"
                ]
              }
            },
            {
              "Effect": "Allow",
              "Action": [
                "s3:AbortMultipartUpload",
                "s3:GetBucketLocation",
                "s3:GetObject",
                "s3:ListBucket",
                "s3:PutObject"
              ],
              "Resource": [
                {
                  "Fn::GetAtt": [
                    "S3Bucket",
                    "Arn"
                  ]
                },
                {
                  "Fn::Join": [
                    "",
                    [
                      {
                        "Fn::GetAtt": [
                          "S3Bucket",
                          "Arn"
                        ]
                      },
                      "/*"
                    ]
                  ]
                }
              ]
            }
          ]
        },
        "Roles": [
          {
            "Ref": "FirehoseRole"
          }
        ]
      },
      "effects": []
    }
  ],
  "edges": [
    {
      "type": "depends",
      "from": "KinesisFirehoseDeliveryStream",
      "to": "KinesisDataStream"
    },
    {
      "type": "depends",
      "from": "KinesisFirehoseDeliveryStream",
      "to": "S3Bucket"
    },
    {
      "type": "depends",
      "from": "KinesisFirehoseDeliveryStream",
      "to": "FirehoseRole"
    },
    {
      "type": "depends",
      "from": "FirehosePolicy",
      "to": "FirehoseRole"
    }
  ],
  "invariants": [
    "Kinesis Data Stream must be created before Firehose can use it as a source",
    "S3 bucket must exist before Firehose can deliver to it",
    "IAM role and policy must be created before Firehose can assume permissions"
  ]
}