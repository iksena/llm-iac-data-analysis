{
  "resources": [
    {
      "id": "CentralizedSNSTopic",
      "kind": "AWS::SNS::Topic",
      "fields": {
        "TopicName": "CentralizedAlertsTopic",
        "DisplayName": "Centralized Alerts and Events"
      },
      "effects": [
        "encrypted",
        "versioned"
      ]
    },
    {
      "id": "TopicPolicy",
      "kind": "AWS::SNS::TopicPolicy",
      "fields": {
        "Topics": [
          {
            "Ref": "CentralizedSNSTopic"
          }
        ],
        "PolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": "*",
              "Action": [
                "sns:Publish",
                "sns:Subscribe",
                "sns:Receive"
              ],
              "Resource": {
                "Ref": "CentralizedSNSTopic"
              },
              "Condition": {
                "ArnLike": {
                  "AWS:SourceArn": [
                    "arn:aws:cloudformation:*:*:*",
                    "arn:aws:cloudwatch:*:*:*",
                    "arn:aws:lambda:*:*:*",
                    "arn:aws:s3:*:*:*",
                    "arn:aws:sns:*:*:*"
                  ]
                }
              }
            }
          ]
        }
      },
      "effects": [
        "secure"
      ]
    },
    {
      "id": "EmailSubscription",
      "kind": "AWS::SNS::Subscription",
      "fields": {
        "Endpoint": {
          "Ref": "EmailEndpoint"
        },
        "Protocol": "email",
        "TopicArn": {
          "Ref": "CentralizedSNSTopic"
        }
      },
      "effects": [
        "email-subscription"
      ]
    },
    {
      "id": "EmailEndpoint",
      "kind": "AWS::SSM::Parameter",
      "fields": {
        "Name": "/CentralizedAlerts/EmailEndpoint",
        "Type": "String",
        "Value": "alerts@example.com"
      },
      "effects": [
        "secure-parameter"
      ]
    }
  ],
  "edges": [
    {
      "type": "depends",
      "from": "TopicPolicy",
      "to": "CentralizedSNSTopic"
    },
    {
      "type": "depends",
      "from": "EmailSubscription",
      "to": "CentralizedSNSTopic"
    },
    {
      "type": "depends",
      "from": "EmailSubscription",
      "to": "EmailEndpoint"
    }
  ],
  "invariants": [
    "Topic must be encrypted at rest using AWS-managed KMS key",
    "Cross-service notifications must be restricted to authorized AWS services only",
    "Email subscription must use secure parameter store for endpoint configuration",
    "Topic policy must allow publish/subscribe/receive from specific AWS services",
    "All resources must be created in the same region as the CloudFormation stack"
  ]
}