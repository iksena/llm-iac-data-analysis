{
  "resources": [
    {
      "id": "VPC",
      "kind": "AWS::EC2::VPC",
      "fields": {
        "CidrBlock": "10.0.0.0/16",
        "EnableDnsSupport": true,
        "EnableDnsHostnames": true
      },
      "effects": [
        "isolated"
      ]
    },
    {
      "id": "PublicSubnet1",
      "kind": "AWS::EC2::Subnet",
      "fields": {
        "VpcId": "VPC",
        "CidrBlock": "10.0.1.0/24",
        "AvailabilityZone": "us-east-1a"
      },
      "effects": [
        "public"
      ]
    },
    {
      "id": "PublicSubnet2",
      "kind": "AWS::EC2::Subnet",
      "fields": {
        "VpcId": "VPC",
        "CidrBlock": "10.0.2.0/24",
        "AvailabilityZone": "us-east-1b"
      },
      "effects": [
        "public"
      ]
    },
    {
      "id": "DBSubnetGroup",
      "kind": "AWS::RDS::DBSubnetGroup",
      "fields": {
        "DBSubnetGroupDescription": "Subnets for RDS instances",
        "SubnetIds": [
          "PublicSubnet1",
          "PublicSubnet2"
        ]
      },
      "effects": [
        "isolated"
      ]
    },
    {
      "id": "DBSecurityGroup",
      "kind": "AWS::EC2::SecurityGroup",
      "fields": {
        "GroupDescription": "Security group for RDS instance",
        "VpcId": "VPC",
        "SecurityGroupIngress": [
          {
            "IpProtocol": "tcp",
            "FromPort": 3306,
            "ToPort": 3306,
            "SourceSecurityGroupId": {
              "Ref": "AppSecurityGroup"
            }
          }
        ],
        "SecurityGroupEgress": [
          {
            "IpProtocol": "-1",
            "CidrIp": "0.0.0.0/0"
          }
        ]
      },
      "effects": [
        "isolated"
      ]
    },
    {
      "id": "DBParameterGroup",
      "kind": "AWS::RDS::DBParameterGroup",
      "fields": {
        "Description": "Custom parameter group for MySQL",
        "Family": "mysql8.0",
        "Parameters": {
          "max_connections": "150",
          "character_set_server": "utf8mb4"
        }
      },
      "effects": [
        "custom"
      ]
    },
    {
      "id": "DBSecret",
      "kind": "AWS::SecretsManager::Secret",
      "fields": {
        "Name": "MySQLAdminSecret",
        "Description": "Secret for MySQL admin credentials",
        "GenerateSecretString": {
          "SecretStringTemplate": "{\"username\": \"admin\"}",
          "GenerateStringKey": "password",
          "PasswordLength": 16,
          "ExcludeCharacters": "\"@/\\"
        }
      },
      "effects": [
        "encrypted"
      ]
    },
    {
      "id": "DBInstance",
      "kind": "AWS::RDS::DBInstance",
      "fields": {
        "AllocatedStorage": "20",
        "DBInstanceClass": "db.t3.micro",
        "Engine": "mysql",
        "EngineVersion": "8.0",
        "MasterUsername": {
          "Fn::Join": [
            "",
            [
              {
                "Fn::GetAtt": [
                  "DBSecret",
                  "SecretString"
                ]
              },
              ".username"
            ]
          ]
        },
        "MasterUserPassword": {
          "Fn::Join": [
            "",
            [
              {
                "Fn::GetAtt": [
                  "DBSecret",
                  "SecretString"
                ]
              },
              ".password"
            ]
          ]
        },
        "DBSubnetGroupName": "DBSubnetGroup",
        "VPCSecurityGroups": [
          {
            "Fn::GetAtt": [
              "DBSecurityGroup",
              "GroupId"
            ]
          }
        ],
        "DBParameterGroupName": "DBParameterGroup",
        "BackupRetentionPeriod": 7,
        "MultiAZ": false,
        "StorageEncrypted": true
      },
      "effects": [
        "encrypted",
        "versioned"
      ]
    },
    {
      "id": "AppSecurityGroup",
      "kind": "AWS::EC2::SecurityGroup",
      "fields": {
        "GroupDescription": "Security group for application servers",
        "VpcId": "VPC"
      },
      "effects": [
        "public"
      ]
    }
  ],
  "edges": [
    {
      "type": "depends",
      "from": "PublicSubnet1",
      "to": "VPC"
    },
    {
      "type": "depends",
      "from": "PublicSubnet2",
      "to": "VPC"
    },
    {
      "type": "depends",
      "from": "DBSubnetGroup",
      "to": "PublicSubnet1"
    },
    {
      "type": "depends",
      "from": "DBSubnetGroup",
      "to": "PublicSubnet2"
    },
    {
      "type": "depends",
      "from": "DBSecurityGroup",
      "to": "VPC"
    },
    {
      "type": "depends",
      "from": "DBInstance",
      "to": "DBSubnetGroup"
    },
    {
      "type": "depends",
      "from": "DBInstance",
      "to": "DBSecurityGroup"
    },
    {
      "type": "depends",
      "from": "DBInstance",
      "to": "DBParameterGroup"
    },
    {
      "type": "depends",
      "from": "DBInstance",
      "to": "DBSecret"
    },
    {
      "type": "depends",
      "from": "AppSecurityGroup",
      "to": "VPC"
    },
    {
      "type": "connects",
      "from": "DBSecurityGroup",
      "to": "AppSecurityGroup",
      "proto": "tcp",
      "port": 3306
    }
  ],
  "invariants": [
    "Database must be deployed in a VPC with two subnets across Availability Zones",
    "AWS Secrets Manager must be used to securely generate and manage admin credentials",
    "Database must use a custom parameter group",
    "Network isolation must be implemented using security groups",
    "Storage must be encrypted at rest"
  ]
}