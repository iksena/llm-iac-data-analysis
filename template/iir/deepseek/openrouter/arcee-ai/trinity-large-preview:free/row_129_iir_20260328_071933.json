{
  "resources": [
    {
      "id": "ConfigS3Bucket",
      "kind": "AWS::S3::Bucket",
      "fields": {
        "BucketName": "config-bucket",
        "AccessControl": "Private",
        "PublicAccessBlockConfiguration": {
          "BlockPublicAcls": true,
          "BlockPublicPolicy": true,
          "IgnorePublicAcls": true,
          "RestrictPublicBuckets": true
        },
        "BucketEncryption": {
          "ServerSideEncryptionConfiguration": [
            {
              "ServerSideEncryptionByDefault": {
                "SSEAlgorithm": "AES256"
              }
            }
          ]
        },
        "VersioningConfiguration": {
          "Status": "Enabled"
        },
        "LifecycleConfiguration": {
          "Rules": [
            {
              "Id": "ConfigRetention",
              "Status": "Enabled",
              "ExpirationInDays": 2557
            }
          ]
        },
        "BucketPolicy": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Deny",
              "Principal": "*",
              "Action": "s3:*",
              "Resource": [
                "arn:aws:s3:::config-bucket",
                "arn:aws:s3:::config-bucket/*"
              ],
              "Condition": {
                "Bool": {
                  "aws:SecureTransport": "false"
                }
              }
            }
          ]
        }
      },
      "effects": [
        "encrypted",
        "versioned",
        "public-blocked",
        "ssl-enforced"
      ]
    },
    {
      "id": "ConfigSnsTopic",
      "kind": "AWS::SNS::Topic",
      "fields": {
        "TopicName": "config-topic"
      },
      "effects": [
        "public"
      ]
    },
    {
      "id": "ConfigRecorder",
      "kind": "AWS::Config::ConfigurationRecorder",
      "fields": {
        "Name": "config-recorder",
        "RecordingGroup": {
          "AllSupported": true,
          "IncludeGlobalResourceTypes": true
        },
        "RoleARN": {
          "Fn::GetAtt": [
            "ConfigRecorderRole",
            "Arn"
          ]
        }
      },
      "effects": [
        "global-coverage"
      ]
    },
    {
      "id": "ConfigRecorderRole",
      "kind": "AWS::IAM::Role",
      "fields": {
        "RoleName": "config-recorder-role",
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "config.amazonaws.com"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "Policies": [
          {
            "PolicyName": "config-policy",
            "PolicyDocument": {
              "Version": "2012-10-17",
              "Statement": [
                {
                  "Effect": "Allow",
                  "Action": [
                    "s3:GetBucketAcl",
                    "s3:PutObject"
                  ],
                  "Resource": [
                    {
                      "Fn::GetAtt": [
                        "ConfigS3Bucket",
                        "Arn"
                      ]
                    },
                    {
                      "Fn::Join": [
                        "",
                        [
                          {
                            "Fn::GetAtt": [
                              "ConfigS3Bucket",
                              "Arn"
                            ]
                          },
                          "/*"
                        ]
                      ]
                    }
                  ]
                },
                {
                  "Effect": "Allow",
                  "Action": "sns:Publish",
                  "Resource": {
                    "Ref": "ConfigSnsTopic"
                  }
                },
                {
                  "Effect": "Allow",
                  "Action": "iam:PassRole",
                  "Resource": "*"
                }
              ]
            }
          }
        ]
      },
      "effects": [
        "iam-role"
      ]
    },
    {
      "id": "ConfigDeliveryChannel",
      "kind": "AWS::Config::DeliveryChannel",
      "fields": {
        "Name": "config-delivery-channel",
        "S3BucketName": {
          "Ref": "ConfigS3Bucket"
        },
        "SnsTopicARN": {
          "Fn::GetAtt": [
            "ConfigSnsTopic",
            "Arn"
          ]
        },
        "ConfigSnapshotDeliveryProperties": {
          "DeliveryFrequency": "Six_Hours"
        }
      },
      "effects": [
        "delivery-configured"
      ]
    },
    {
      "id": "ConfigRetentionLambda",
      "kind": "AWS::Lambda::Function",
      "fields": {
        "FunctionName": "config-retention-manager",
        "Runtime": "python3.9",
        "Handler": "index.handler",
        "Code": {
          "ZipFile": "def handler(event, context):\n    # Lambda code to manage retention periods\n    return {}"
        },
        "Role": {
          "Fn::GetAtt": [
            "ConfigRetentionLambdaRole",
            "Arn"
          ]
        }
      },
      "effects": [
        "custom-resource"
      ]
    },
    {
      "id": "ConfigRetentionLambdaRole",
      "kind": "AWS::IAM::Role",
      "fields": {
        "RoleName": "config-retention-lambda-role",
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "lambda.amazonaws.com"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "Policies": [
          {
            "PolicyName": "lambda-policy",
            "PolicyDocument": {
              "Version": "2012-10-17",
              "Statement": [
                {
                  "Effect": "Allow",
                  "Action": [
                    "logs:CreateLogGroup",
                    "logs:CreateLogStream",
                    "logs:PutLogEvents"
                  ],
                  "Resource": "arn:aws:logs:*:*:*"
                },
                {
                  "Effect": "Allow",
                  "Action": "s3:PutLifecycleConfiguration",
                  "Resource": {
                    "Fn::GetAtt": [
                      "ConfigS3Bucket",
                      "Arn"
                    ]
                  }
                }
              ]
            }
          }
        ]
      },
      "effects": [
        "iam-role"
      ]
    },
    {
      "id": "ConfigRetentionCustomResource",
      "kind": "AWS::CloudFormation::CustomResource",
      "fields": {
        "ServiceToken": {
          "Fn::GetAtt": [
            "ConfigRetentionLambda",
            "Arn"
          ]
        },
        "RetentionDays": 2557
      },
      "effects": [
        "custom-resource"
      ]
    }
  ],
  "edges": [
    {
      "type": "depends",
      "from": "ConfigRecorder",
      "to": "ConfigRecorderRole"
    },
    {
      "type": "depends",
      "from": "ConfigDeliveryChannel",
      "to": "ConfigS3Bucket"
    },
    {
      "type": "depends",
      "from": "ConfigDeliveryChannel",
      "to": "ConfigSnsTopic"
    },
    {
      "type": "depends",
      "from": "ConfigDeliveryChannel",
      "to": "ConfigRecorderRole"
    },
    {
      "type": "depends",
      "from": "ConfigRetentionLambda",
      "to": "ConfigRetentionLambdaRole"
    },
    {
      "type": "depends",
      "from": "ConfigRetentionCustomResource",
      "to": "ConfigRetentionLambda"
    }
  ],
  "invariants": [
    "SSL enforced for S3 bucket access",
    "Public access blocked on S3 bucket",
    "Global resource coverage enabled",
    "Encryption at rest required",
    "Versioning enabled for S3 bucket",
    "Custom retention period management via Lambda",
    "Delivery frequency configurable (default: six hours)"
  ]
}