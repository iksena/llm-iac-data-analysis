{
  "resources": [
    {
      "id": "VPC",
      "kind": "AWS::EC2::VPC",
      "fields": {
        "CidrBlock": "10.0.0.0/16",
        "EnableDnsSupport": true,
        "EnableDnsHostnames": true
      },
      "effects": [
        "private-network"
      ]
    },
    {
      "id": "InternetGateway",
      "kind": "AWS::EC2::InternetGateway",
      "fields": {},
      "effects": [
        "internet-access"
      ]
    },
    {
      "id": "VPCGatewayAttachment",
      "kind": "AWS::EC2::VPCGatewayAttachment",
      "fields": {
        "VpcId": "VPC",
        "InternetGatewayId": "InternetGateway"
      },
      "effects": [
        "internet-access"
      ]
    },
    {
      "id": "PublicRouteTable",
      "kind": "AWS::EC2::RouteTable",
      "fields": {
        "VpcId": "VPC"
      },
      "effects": [
        "public-subnet"
      ]
    },
    {
      "id": "PublicRoute",
      "kind": "AWS::EC2::Route",
      "fields": {
        "RouteTableId": "PublicRouteTable",
        "DestinationCidrBlock": "0.0.0.0/0",
        "GatewayId": "InternetGateway"
      },
      "effects": [
        "internet-access"
      ]
    },
    {
      "id": "PublicSubnet",
      "kind": "AWS::EC2::Subnet",
      "fields": {
        "VpcId": "VPC",
        "CidrBlock": "10.0.0.0/24",
        "AvailabilityZone": "us-east-1a",
        "MapPublicIpOnLaunch": true
      },
      "effects": [
        "public-subnet"
      ]
    },
    {
      "id": "SubnetRouteTableAssociation",
      "kind": "AWS::EC2::SubnetRouteTableAssociation",
      "fields": {
        "SubnetId": "PublicSubnet",
        "RouteTableId": "PublicRouteTable"
      },
      "effects": [
        "public-subnet"
      ]
    }
  ],
  "edges": [
    {
      "type": "depends",
      "from": "VPCGatewayAttachment",
      "to": "VPC"
    },
    {
      "type": "depends",
      "from": "VPCGatewayAttachment",
      "to": "InternetGateway"
    },
    {
      "type": "depends",
      "from": "PublicRouteTable",
      "to": "VPC"
    },
    {
      "type": "depends",
      "from": "PublicRoute",
      "to": "PublicRouteTable"
    },
    {
      "type": "depends",
      "from": "PublicRoute",
      "to": "InternetGateway"
    },
    {
      "type": "depends",
      "from": "PublicSubnet",
      "to": "VPC"
    },
    {
      "type": "depends",
      "from": "SubnetRouteTableAssociation",
      "to": "PublicSubnet"
    },
    {
      "type": "depends",
      "from": "SubnetRouteTableAssociation",
      "to": "PublicRouteTable"
    }
  ],
  "invariants": [
    "VPC must have internet connectivity through IGW",
    "Public subnet must be associated with route table containing default route",
    "Resources in public subnet must receive public IP addresses on launch"
  ]
}