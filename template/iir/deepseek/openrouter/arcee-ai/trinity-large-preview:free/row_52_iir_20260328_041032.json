{
  "resources": [
    {
      "id": "RecoveryCluster",
      "kind": "AWS::Route53RecoveryCluster::Cluster",
      "fields": {
        "Name": "MultiRegionRecoveryCluster"
      },
      "effects": [
        "recovery-cluster"
      ]
    },
    {
      "id": "ControlPanel",
      "kind": "AWS::Route53RecoveryControl::ControlPanel",
      "fields": {
        "Name": "RegionalFailoverControlPanel",
        "ClusterArn": {
          "ref": "RecoveryCluster"
        }
      },
      "effects": [
        "control-panel"
      ]
    },
    {
      "id": "RoutingControlRegion1",
      "kind": "AWS::Route53RecoveryControl::RoutingControl",
      "fields": {
        "Name": "Region1RoutingControl",
        "ControlPanelArn": {
          "ref": "ControlPanel"
        }
      },
      "effects": [
        "routing-control"
      ]
    },
    {
      "id": "RoutingControlRegion2",
      "kind": "AWS::Route53RecoveryControl::RoutingControl",
      "fields": {
        "Name": "Region2RoutingControl",
        "ControlPanelArn": {
          "ref": "ControlPanel"
        }
      },
      "effects": [
        "routing-control"
      ]
    },
    {
      "id": "SafetyRule",
      "kind": "AWS::Route53RecoveryControl::SafetyRule",
      "fields": {
        "Name": "AtLeastOneRegionActive",
        "ControlPanelArn": {
          "ref": "ControlPanel"
        },
        "RuleConfig": {
          "RuleType": "ATLEAST",
          "Threshold": 1,
          "RoutingControls": [
            {
              "RoutingControlArn": {
                "ref": "RoutingControlRegion1"
              }
            },
            {
              "RoutingControlArn": {
                "ref": "RoutingControlRegion2"
              }
            }
          ]
        },
        "Status": "ENABLED"
      },
      "effects": [
        "safety-rule"
      ]
    },
    {
      "id": "HealthCheckRegion1",
      "kind": "AWS::Route53RecoveryHealthCheck::HealthCheck",
      "fields": {
        "Name": "Region1HealthCheck",
        "HealthCheckConfig": {
          "Port": 443,
          "Protocol": "HTTPS",
          "Type": "HTTPS"
        }
      },
      "effects": [
        "health-check"
      ]
    },
    {
      "id": "HealthCheckRegion2",
      "kind": "AWS::Route53RecoveryHealthCheck::HealthCheck",
      "fields": {
        "Name": "Region2HealthCheck",
        "HealthCheckConfig": {
          "Port": 443,
          "Protocol": "HTTPS",
          "Type": "HTTPS"
        }
      },
      "effects": [
        "health-check"
      ]
    }
  ],
  "edges": [
    {
      "type": "depends",
      "from": "ControlPanel",
      "to": "RecoveryCluster"
    },
    {
      "type": "depends",
      "from": "RoutingControlRegion1",
      "to": "ControlPanel"
    },
    {
      "type": "depends",
      "from": "RoutingControlRegion2",
      "to": "ControlPanel"
    },
    {
      "type": "depends",
      "from": "SafetyRule",
      "to": "ControlPanel"
    },
    {
      "type": "connects",
      "from": "RoutingControlRegion1",
      "to": "HealthCheckRegion1",
      "proto": "https",
      "port": 443
    },
    {
      "type": "connects",
      "from": "RoutingControlRegion2",
      "to": "HealthCheckRegion2",
      "proto": "https",
      "port": 443
    }
  ],
  "invariants": [
    "At least one region must remain active at all times",
    "Health checks must monitor regional application endpoints",
    "Routing controls must be linked to health checks for automatic failover"
  ]
}