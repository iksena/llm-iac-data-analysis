{
  "resources": [
    {
      "id": "ImageAnalysisBucket",
      "kind": "AWS::S3::Bucket",
      "fields": {
        "BucketName": "image-analysis-bucket",
        "NotificationConfiguration": {
          "LambdaConfigurations": [
            {
              "Event": "s3:ObjectCreated:*",
              "Filter": {
                "S3Key": {
                  "Rules": [
                    {
                      "Name": "suffix",
                      "Value": ".jpg"
                    }
                  ]
                }
              },
              "Function": "Ref::ImageUploadLambda"
            }
          ]
        }
      },
      "effects": [
        "versioned"
      ]
    },
    {
      "id": "ImageUploadLambda",
      "kind": "AWS::Lambda::Function",
      "fields": {
        "Handler": "index.handler",
        "Runtime": "nodejs18.x",
        "Code": {
          "ZipFile": "deferred"
        },
        "Timeout": 30,
        "MemorySize": 128,
        "Role": "Ref::LambdaExecutionRole"
      },
      "effects": [
        "encrypted"
      ]
    },
    {
      "id": "StepFunctionsStateMachine",
      "kind": "AWS::StepFunctions::StateMachine",
      "fields": {
        "DefinitionString": "deferred",
        "RoleArn": "Ref::StepFunctionsRole"
      },
      "effects": [
        "encrypted"
      ]
    },
    {
      "id": "RekognitionLambda",
      "kind": "AWS::Lambda::Function",
      "fields": {
        "Handler": "index.handler",
        "Runtime": "nodejs18.x",
        "Code": {
          "ZipFile": "deferred"
        },
        "Timeout": 30,
        "MemorySize": 128,
        "Role": "Ref::LambdaExecutionRole"
      },
      "effects": [
        "encrypted"
      ]
    },
    {
      "id": "SNSLambda",
      "kind": "AWS::Lambda::Function",
      "fields": {
        "Handler": "index.handler",
        "Runtime": "nodejs18.x",
        "Code": {
          "ZipFile": "deferred"
        },
        "Timeout": 30,
        "MemorySize": 128,
        "Role": "Ref::LambdaExecutionRole"
      },
      "effects": [
        "encrypted"
      ]
    },
    {
      "id": "LambdaExecutionRole",
      "kind": "AWS::IAM::Role",
      "fields": {
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "lambda.amazonaws.com"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "ManagedPolicyArns": [
          "arn:aws:iam::aws:policy/service-role/AWSLambdaBasicExecutionRole"
        ],
        "Policies": [
          {
            "PolicyName": "RekognitionAccess",
            "PolicyDocument": {
              "Version": "2012-10-17",
              "Statement": [
                {
                  "Effect": "Allow",
                  "Action": [
                    "rekognition:DetectFaces",
                    "rekognition:DetectLabels"
                  ],
                  "Resource": "*"
                }
              ]
            }
          },
          {
            "PolicyName": "S3Access",
            "PolicyDocument": {
              "Version": "2012-10-17",
              "Statement": [
                {
                  "Effect": "Allow",
                  "Action": [
                    "s3:GetObject",
                    "s3:PutObject"
                  ],
                  "Resource": "Fn::Join::[\"\",[\"arn:aws:s3:::\",Ref::ImageAnalysisBucket,\"/*\"]]"
                }
              ]
            }
          },
          {
            "PolicyName": "SNSAccess",
            "PolicyDocument": {
              "Version": "2012-10-17",
              "Statement": [
                {
                  "Effect": "Allow",
                  "Action": "sns:Publish",
                  "Resource": "Ref::SNSTopic"
                }
              ]
            }
          }
        ]
      },
      "effects": [
        "least-privilege"
      ]
    },
    {
      "id": "StepFunctionsRole",
      "kind": "AWS::IAM::Role",
      "fields": {
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "states.amazonaws.com"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "Policies": [
          {
            "PolicyName": "StepFunctionsAccess",
            "PolicyDocument": {
              "Version": "2012-10-17",
              "Statement": [
                {
                  "Effect": "Allow",
                  "Action": [
                    "lambda:InvokeFunction"
                  ],
                  "Resource": [
                    "Ref::RekognitionLambda",
                    "Ref::SNSLambda"
                  ]
                }
              ]
            }
          }
        ]
      },
      "effects": [
        "least-privilege"
      ]
    },
    {
      "id": "SNSTopic",
      "kind": "AWS::SNS::Topic",
      "fields": {
        "TopicName": "ImageAnalysisAlerts"
      },
      "effects": [
        "encrypted"
      ]
    },
    {
      "id": "SNSTMSSubscription",
      "kind": "AWS::SNS::Subscription",
      "fields": {
        "Endpoint": "+1234567890",
        "Protocol": "sms",
        "TopicArn": "Ref::SNSTopic"
      },
      "effects": [
        "public"
      ]
    }
  ],
  "edges": [
    {
      "type": "depends",
      "from": "ImageUploadLambda",
      "to": "LambdaExecutionRole"
    },
    {
      "type": "depends",
      "from": "RekognitionLambda",
      "to": "LambdaExecutionRole"
    },
    {
      "type": "depends",
      "from": "SNSLambda",
      "to": "LambdaExecutionRole"
    },
    {
      "type": "depends",
      "from": "StepFunctionsStateMachine",
      "to": "StepFunctionsRole"
    },
    {
      "type": "connects",
      "from": "ImageUploadLambda",
      "to": "StepFunctionsStateMachine",
      "proto": "https",
      "port": 443
    },
    {
      "type": "connects",
      "from": "StepFunctionsStateMachine",
      "to": "RekognitionLambda",
      "proto": "https",
      "port": 443
    },
    {
      "type": "connects",
      "from": "StepFunctionsStateMachine",
      "to": "SNSLambda",
      "proto": "https",
      "port": 443
    },
    {
      "type": "connects",
      "from": "SNSLambda",
      "to": "SNSTopic",
      "proto": "https",
      "port": 443
    }
  ],
  "invariants": [
    "S3 bucket must trigger Lambda on image upload",
    "Step Functions must orchestrate Rekognition analysis and SMS notification",
    "Lambda functions must have least-privilege IAM roles",
    "Rekognition must detect human faces/labels in images",
    "SNS must send SMS alerts when human labels are detected",
    "IAM roles must resolve circular dependencies between S3 and Lambda",
    "All cross-service communication must be secure"
  ]
}