      "to": "WindowsLaunchTemplate"
    }
  ],
  "invariants": [
    "Instances must be accessible via SSM for management tasks",
    "Auto Scaling Groups must use the latest AMI from SSM Parameter Store",
    "Security groups must allow HTTP and HTTPS access for web services",
    "IAM roles must have AmazonEC2RoleforSSM policy attached"
  ]
}