{
  "resources": [
    {
      "id": "ScreenshotQueue",
      "kind": "AWS::SQS::Queue",
      "fields": {
        "QueueName": "ScreenshotQueue"
      },
      "effects": [
        "encrypted"
      ]
    },
    {
      "id": "ScreenshotBucket",
      "kind": "AWS::S3::Bucket",
      "fields": {
        "BucketName": "screenshot-service-results",
        "AccessControl": "Private",
        "VersioningConfiguration": {
          "Status": "Enabled"
        }
      },
      "effects": [
        "encrypted",
        "versioned"
      ]
    },
    {
      "id": "WorkerLaunchConfig",
      "kind": "AWS::AutoScaling::LaunchConfiguration",
      "fields": {
        "ImageId": "ami-0123456789abcdef0",
        "InstanceType": "t3.medium",
        "IamInstanceProfile": "ScreenshotWorkerProfile",
        "UserData": "base64-encoded-chromium-screenshot-script"
      },
      "effects": [
        "encrypted"
      ]
    },
    {
      "id": "WorkerASG",
      "kind": "AWS::AutoScaling::AutoScalingGroup",
      "fields": {
        "AvailabilityZones": [
          "us-east-1a",
          "us-east-1b"
        ],
        "VPCZoneIdentifier": [
          "subnet-abc123",
          "subnet-def456"
        ],
        "LaunchConfigurationName": "WorkerLaunchConfig",
        "MinSize": "1",
        "MaxSize": "2",
        "DesiredCapacity": "1"
      },
      "effects": [
        "encrypted"
      ]
    },
    {
      "id": "LoadTestInstance",
      "kind": "AWS::EC2::Instance",
      "fields": {
        "ImageId": "ami-0123456789abcdef0",
        "InstanceType": "t3.small",
        "SubnetId": "subnet-abc123",
        "IamInstanceProfile": "ScreenshotWorkerProfile",
        "UserData": "base64-encoded-load-test-script"
      },
      "effects": [
        "encrypted"
      ]
    },
    {
      "id": "QueueDepthAlarm",
      "kind": "AWS::CloudWatch::Alarm",
      "fields": {
        "AlarmName": "QueueDepthHigh",
        "Namespace": "AWS/SQS",
        "MetricName": "ApproximateNumberOfMessagesVisible",
        "Dimensions": [
          {
            "Name": "QueueName",
            "Value": "ScreenshotQueue"
          }
        ],
        "Statistic": "Sum",
        "Period": 300,
        "EvaluationPeriods": 1,
        "Threshold": 10,
        "ComparisonOperator": "GreaterThanThreshold"
      },
      "effects": [
        "monitoring"
      ]
    },
    {
      "id": "ScaleUpPolicy",
      "kind": "AWS::AutoScaling::ScalingPolicy",
      "fields": {
        "AdjustmentType": "ChangeInCapacity",
        "ScalingAdjustment": 1,
        "Cooldown": 300
      },
      "effects": [
        "monitoring"
      ]
    },
    {
      "id": "ScaleDownPolicy",
      "kind": "AWS::AutoScaling::ScalingPolicy",
      "fields": {
        "AdjustmentType": "ChangeInCapacity",
        "ScalingAdjustment": -1,
        "Cooldown": 300
      },
      "effects": [
        "monitoring"
      ]
    },
    {
      "id": "LowQueueDepthAlarm",
      "kind": "AWS::CloudWatch::Alarm",
      "fields": {
        "AlarmName": "QueueDepthLow",
        "Namespace": "AWS/SQS",
        "MetricName": "ApproximateNumberOfMessagesVisible",
        "Dimensions": [
          {
            "Name": "QueueName",
            "Value": "ScreenshotQueue"
          }
        ],
        "Statistic": "Sum",
        "Period": 300,
        "EvaluationPeriods": 1,
        "Threshold": 2,
        "ComparisonOperator": "LessThanThreshold"
      },
      "effects": [
        "monitoring"
      ]
    },
    {
      "id": "WorkerRole",
      "kind": "AWS::IAM::Role",
      "fields": {
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "ec2.amazonaws.com"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "ManagedPolicyArns": [
          "arn:aws:iam::aws:policy/AmazonSQSFullAccess",
          "arn:aws:iam::aws:policy/AmazonS3FullAccess"
        ]
      },
      "effects": [
        "encrypted"
      ]
    }
  ],
  "edges": [
    {
      "type": "depends",
      "from": "WorkerLaunchConfig",
      "to": "WorkerRole"
    },
    {
      "type": "depends",
      "from": "WorkerASG",
      "to": "WorkerLaunchConfig"
    },
    {
      "type": "connects",
      "from": "WorkerASG",
      "to": "ScreenshotQueue",
      "proto": "https",
      "port": 443
    },
    {
      "type": "connects",
      "from": "WorkerASG",
      "to": "ScreenshotBucket",
      "proto": "https",
      "port": 443
    },
    {
      "type": "connects",
      "from": "LoadTestInstance",
      "to": "ScreenshotQueue",
      "proto": "https",
      "port": 443
    },
    {
      "type": "depends",
      "from": "QueueDepthAlarm",
      "to": "ScreenshotQueue"
    },
    {
      "type": "depends",
      "from": "ScaleUpPolicy",
      "to": "WorkerASG"
    },
    {
      "type": "depends",
      "from": "ScaleDownPolicy",
      "to": "WorkerASG"
    },
    {
      "type": "depends",
      "from": "LowQueueDepthAlarm",
      "to": "ScreenshotQueue"
    }
  ],
  "invariants": [
    "Auto Scaling between 1-2 instances based on queue depth",
    "SQS queue encrypted at rest",
    "S3 bucket encrypted with versioning enabled",
    "EC2 instances have IAM permissions for SQS and S3",
    "CloudWatch alarms trigger scaling policies",
    "Load test instance populates queue with sample requests",
    "Cross-AZ deployment for high availability"
  ]
}