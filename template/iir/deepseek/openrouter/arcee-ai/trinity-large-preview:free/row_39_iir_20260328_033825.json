{
  "resources": [
    {
      "id": "ECRRepository",
      "kind": "AWS::ECR::Repository",
      "fields": {},
      "effects": [
        "encrypted"
      ]
    },
    {
      "id": "RepositoryPolicy",
      "kind": "AWS::ECR::RepositoryPolicy",
      "fields": {
        "RepositoryPolicyText": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Sid": "RootUserPermissions",
              "Effect": "Allow",
              "Principal": {
                "AWS": "arn:aws:iam::123456789012:root"
              },
              "Action": [
                "ecr:GetDownloadUrlForLayer",
                "ecr:BatchGetImage",
                "ecr:BatchCheckLayerAvailability",
                "ecr:PutImage",
                "ecr:InitiateLayerUpload",
                "ecr:UploadLayerPart",
                "ecr:CompleteLayerUpload",
                "ecr:DescribeRepositories",
                "ecr:GetRepositoryPolicy",
                "ecr:ListImages",
                "ecr:DeleteRepository",
                "ecr:BatchDeleteImage",
                "ecr:SetRepositoryPolicy",
                "ecr:PutLifecyclePolicy",
                "ecr:PutImageTagMutability",
                "ecr:StartLifecyclePolicyPreview"
              ]
            }
          ]
        }
      },
      "effects": []
    }
  ],
  "edges": [
    {
      "type": "depends",
      "from": "RepositoryPolicy",
      "to": "ECRRepository"
    }
  ],
  "invariants": [
    "ECR repository must be encrypted at rest",
    "Root user must have full ECR permissions for Kubernetes container management"
  ]
}