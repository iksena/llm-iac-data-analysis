  "invariants": [
    "VPC provides isolated network environment",
    "Internet Gateway enables public internet access",
    "Public Subnet allows public IP assignment",
    "Security Group restricts HTTP access to port 80",
    "IAM Role grants CloudWatch and SSM permissions",
    "S3 Bucket enforces server-side encryption",
