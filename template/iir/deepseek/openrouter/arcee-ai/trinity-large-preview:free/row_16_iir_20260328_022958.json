{
  "resources": [
    {
      "id": "CloudTrailDatabase",
      "kind": "AWS::Glue::Database",
      "fields": {
        "CatalogId": {
          "Ref": "AWS::AccountId"
        },
        "DatabaseName": "cloudtrail_logs"
      },
      "effects": [
        "encrypted"
      ]
    },
    {
      "id": "CloudTrailCrawler",
      "kind": "AWS::Glue::Crawler",
      "fields": {
        "Name": "CloudTrailCrawler",
        "DatabaseName": {
          "Ref": "CloudTrailDatabase"
        },
        "Role": {
          "Ref": "GlueServiceRole"
        },
        "Targets": {
          "S3Targets": [
            {
              "Path": "s3://kk-admin/cloud-trail/AWSLogs/"
            }
          ]
        },
        "SchemaChangePolicy": {
          "UpdateBehavior": "UPDATE_IN_DATABASE",
          "DeleteBehavior": "DEPRECATE_IN_DATABASE"
        },
        "TablePrefix": "cloudtrail_",
        "Schedule": {
          "ScheduleExpression": "cron(0 2 * * ? *)"
        }
      },
      "effects": [
        "versioned"
      ]
    },
    {
      "id": "GlueServiceRole",
      "kind": "AWS::IAM::Role",
      "fields": {
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "glue.amazonaws.com"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "ManagedPolicyArns": [
          {
            "Fn::Join": [
              "",
              [
                "arn:aws:iam::",
                {
                  "Ref": "AWS::AccountId"
                },
                ":policy/AWSGlueServiceRole-default"
              ]
            ]
          }
        ],
        "Policies": [
          {
            "PolicyName": "CloudTrailAccess",
            "PolicyDocument": {
              "Version": "2012-10-17",
              "Statement": [
                {
                  "Effect": "Allow",
                  "Action": [
                    "s3:Get*",
                    "s3:List*"
                  ],
                  "Resource": "arn:aws:s3:::kk-admin/cloud-trail/AWSLogs/*"
                },
                {
                  "Effect": "Allow",
                  "Action": [
                    "glue:*",
                    "s3:GetBucketLocation",
                    "s3:ListAllMyBuckets"
                  ],
                  "Resource": "*"
                }
              ]
            }
          }
        ]
      },
      "effects": [
        "encrypted"
      ]
    }
  ],
  "edges": [
    {
      "type": "depends",
      "from": "CloudTrailCrawler",
      "to": "CloudTrailDatabase"
    },
    {
      "type": "depends",
      "from": "CloudTrailCrawler",
      "to": "GlueServiceRole"
    }
  ],
  "invariants": [
    "Crawler must have IAM permissions to read CloudTrail logs from S3",
    "Crawler must have permissions to create/update metadata in Glue Data Catalog",
    "Crawler should run on a schedule to automatically update schemas",
    "Tables should be prefixed with 'cloudtrail_' for organizational clarity",
    "Database should be encrypted at rest",
    "Crawler should handle schema changes by updating existing tables"
  ]
}