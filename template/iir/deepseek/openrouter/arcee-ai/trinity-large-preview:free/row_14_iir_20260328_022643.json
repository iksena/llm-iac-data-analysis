{
  "resources": [
    {
      "id": "NetworkInterface",
      "kind": "AWS::EC2::NetworkInterface",
      "fields": {
        "Description": "Primary network interface with multiple IPs",
        "PrivateIpAddress": "10.0.0.10",
        "SecondaryPrivateIpAddressCount": 2,
        "SubnetId": "subnet-12345678",
        "GroupSet": [
          "sg-12345678"
        ]
      },
      "effects": [
        "private-network"
      ]
    },
    {
      "id": "EIP1",
      "kind": "AWS::EC2::EIP",
      "fields": {
        "Domain": "vpc"
      },
      "effects": [
        "public-ip"
      ]
    },
    {
      "id": "EIP2",
      "kind": "AWS::EC2::EIP",
      "fields": {
        "Domain": "vpc"
      },
      "effects": [
        "public-ip"
      ]
    },
    {
      "id": "EIPAssoc1",
      "kind": "AWS::EC2::EIPAssociation",
      "fields": {
        "AllocationId": {
          "Fn::GetAtt": [
            "EIP1",
            "AllocationId"
          ]
        },
        "NetworkInterfaceId": {
          "Ref": "NetworkInterface"
        }
      },
      "effects": [
        "eip-association"
      ]
    },
    {
      "id": "EIPAssoc2",
      "kind": "AWS::EC2::EIPAssociation",
      "fields": {
        "AllocationId": {
          "Fn::GetAtt": [
            "EIP2",
            "AllocationId"
          ]
        },
        "NetworkInterfaceId": {
          "Ref": "NetworkInterface"
        }
      },
      "effects": [
        "eip-association"
      ]
    }
  ],
  "edges": [
    {
      "type": "depends",
      "from": "EIPAssoc1",
      "to": "EIP1"
    },
    {
      "type": "depends",
      "from": "EIPAssoc2",
      "to": "EIP2"
    },
    {
      "type": "depends",
      "from": "EIPAssoc1",
      "to": "NetworkInterface"
    },
    {
      "type": "depends",
      "from": "EIPAssoc2",
      "to": "NetworkInterface"
    }
  ],
  "invariants": [
    "NetworkInterface must have exactly 2 secondary private IPs",
    "Both EIPs must be associated with the same NetworkInterface",
    "EC2 instance will attach to this NetworkInterface for multi-IP functionality"
  ]
}