{
  "resources": [
    {
      "id": "StaticSiteBucket",
      "kind": "AWS::S3::Bucket",
      "fields": {
        "AccessControl": "Private",
        "WebsiteConfiguration": {
          "IndexDocument": "index.html"
        }
      },
      "effects": [
        "encrypted",
        "versioned"
      ]
    },
    {
      "id": "OriginAccessIdentity",
      "kind": "AWS::CloudFront::CloudFrontOriginAccessIdentity",
      "fields": {
        "Comment": "OAI for static site bucket"
      },
      "effects": []
    },
    {
      "id": "CloudFrontDistribution",
      "kind": "AWS::CloudFront::Distribution",
      "fields": {
        "DistributionConfig": {
          "Origins": [
            {
              "Id": "S3Origin",
              "DomainName": {
                "Fn::GetAtt": [
                  "StaticSiteBucket",
                  "DomainName"
                ]
              },
              "S3OriginConfig": {
                "OriginAccessIdentity": {
                  "Fn::Join": [
                    "",
                    [
                      "origin-access-identity/cloudfront/",
                      {
                        "Ref": "OriginAccessIdentity"
                      }
                    ]
                  ]
                }
              }
            }
          ],
          "DefaultCacheBehavior": {
            "AllowedMethods": [
              "GET",
              "HEAD"
            ],
            "Compress": true,
            "TargetOriginId": "S3Origin",
            "ViewerProtocolPolicy": "redirect-to-https",
            "ForwardedValues": {
              "QueryString": false,
              "Cookies": {
                "Forward": "none"
              }
            }
          },
          "Enabled": true,
          "HttpVersion": "http2",
          "PriceClass": "PriceClass_100",
          "ViewerCertificate": {
            "CloudFrontDefaultCertificate": true
          }
        }
      },
      "effects": [
        "public-read"
      ]
    },
    {
      "id": "PopulateS3Lambda",
      "kind": "AWS::Lambda::Function",
      "fields": {
        "Handler": "index.handler",
        "Role": {
          "Fn::GetAtt": [
            "PopulateS3LambdaExecutionRole",
            "Arn"
          ]
        },
        "Code": {
          "ZipFile": {
            "Fn::Join": [
              "",
              [
                "exports.handler = async (event) => {\n",
                "  const AWS = require('aws-sdk');\n",
                "  const s3 = new AWS.S3();\n",
                "  \n",
                "  if (event.RequestType === 'Create' || event.RequestType === 'Update') {\n",
                "    await s3.putObject({\n",
                "      Bucket: process.env.BUCKET_NAME,\n",
                "      Key: 'index.html',\n",
                "      Body: '<html><body><h1>Welcome to our static site!</h1></body></html>',\n",
                "      ContentType: 'text/html'\n",
                "    }).promise();\n",
                "  } else if (event.RequestType === 'Delete') {\n",
                "    const objects = await s3.listObjectsV2({ Bucket: process.env.BUCKET_NAME }).promise();\n",
                "    if (objects.Contents && objects.Contents.length > 0) {\n",
                "      await s3.deleteObjects({\n",
                "        Bucket: process.env.BUCKET_NAME,\n",
                "        Delete: {\n",
                "          Objects: objects.Contents.map(obj => ({ Key: obj.Key }))\n",
                "        }\n",
                "      }).promise();\n",
                "    }\n",
                "  }\n",
                "  return event;\n",
                "};\n"
              ]
            ]
          }
        },
        "Runtime": "nodejs18.x",
        "Timeout": 30,
        "Environment": {
          "Variables": {
            "BUCKET_NAME": {
              "Ref": "StaticSiteBucket"
            }
          }
        }
      },
      "effects": []
    },
    {
      "id": "PopulateS3LambdaExecutionRole",
      "kind": "AWS::IAM::Role",
      "fields": {
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "lambda.amazonaws.com"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "Policies": [
          {
            "PolicyName": "S3AccessPolicy",
            "PolicyDocument": {
              "Version": "2012-10-17",
              "Statement": [
                {
                  "Effect": "Allow",
                  "Action": [
                    "s3:PutObject",
                    "s3:GetObject",
                    "s3:DeleteObject",
                    "s3:ListBucket"
                  ],
                  "Resource": [
                    {
                      "Fn::GetAtt": [
                        "StaticSiteBucket",
                        "Arn"
                      ]
                    },
                    {
                      "Fn::Join": [
                        "",
                        [
                          {
                            "Fn::GetAtt": [
                              "StaticSiteBucket",
                              "Arn"
                            ]
                          },
                          "/*"
                        ]
                      ]
                    }
                  ]
                }
              ]
            }
          }
        ]
      },
      "effects": []
    },
    {
      "id": "PopulateS3CustomResource",
      "kind": "AWS::CloudFormation::CustomResource",
      "fields": {
        "ServiceToken": {
          "Fn::GetAtt": [
            "PopulateS3Lambda",
            "Arn"
          ]
        }
      },
      "effects": []
    }
  ],
  "edges": [
    {
      "type": "depends",
      "from": "OriginAccessIdentity",
      "to": "StaticSiteBucket"
    },
    {
      "type": "depends",
      "from": "CloudFrontDistribution",
      "to": "OriginAccessIdentity"
    },
    {
      "type": "depends",
      "from": "PopulateS3Lambda",
      "to": "PopulateS3LambdaExecutionRole"
    },
    {
      "type": "depends",
      "from": "PopulateS3CustomResource",
      "to": "PopulateS3Lambda"
    },
    {
      "type": "depends",
      "from": "PopulateS3CustomResource",
      "to": "StaticSiteBucket"
    }
  ],
  "invariants": [
    "S3 bucket must be private with OAI for CloudFront access",
    "Lambda function must clean up bucket contents on stack deletion",
    "CloudFront distribution must enforce HTTPS",
    "Custom resource must trigger Lambda for content population"
  ]
}