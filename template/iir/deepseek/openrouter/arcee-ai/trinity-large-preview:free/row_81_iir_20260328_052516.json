{
  "resources": [
    {
      "id": "ResourceTagFilter",
      "kind": "AWS::ResourceGroups::Group",
      "fields": {
        "Name": "ServiceInstances",
        "ResourceQuery": {
          "Type": "TAG_FILTERS_1_0",
          "Query": {
            "ResourceTypeFilters": [
              "AWS::EC2::Instance",
              "AWS::RDS::DBInstance",
              "AWS::SageMaker::NotebookInstance",
              "AWS::SSM::ManagedInstance"
            ],
            "TagFilters": [
              {
                "Key": "Environment",
                "Values": [
                  "Production"
                ]
              }
            ]
          }
        }
      },
      "effects": [
        "tag-filtered"
      ]
    }
  ],
  "edges": [],
  "invariants": [
    "Resource group includes EC2, RDS, SageMaker, and SSM instances",
    "Tag-based filtering on Environment:Production",
    "No explicit dependencies between resources"
  ]
}