{
  "resources": [
    {
      "id": "Calculator-StateMachine",
      "kind": "AWS::StepFunctions::StateMachine",
      "fields": {
        "DefinitionString": {
          "Fn::Sub": "[{\"StartAt\":\"ChoiceState\",\"States\":{\"ChoiceState\":{\"Type\":\"Choice\",\"Choices\":[{\"Variable\":\"$.operator\",\"StringEquals\":\"add\",\"Next\":\"Add\"},{\"Variable\":\"$.operator\",\"StringEquals\":\"subtract\",\"Next\":\"Subtract\"},{\"Variable\":\"$.operator\",\"StringEquals\":\"multiply\",\"Next\":\"Multiply\"},{\"Variable\":\"$.operator\",\"StringEquals\":\"divide\",\"Next\":\"Divide\"}],\"Default\":\"FailState\"},\"Add\":{\"Type\":\"Task\",\"Resource\":\"${Calculator.Arn}\",\"End\":true},\"Subtract\":{\"Type\":\"Task\",\"Resource\":\"${Calculator.Arn}\",\"End\":true},\"Multiply\":{\"Type\":\"Task\",\"Resource\":\"${Calculator.Arn}\",\"End\":true},\"Divide\":{\"Type\":\"Task\",\"Resource\":\"${Calculator.Arn}\",\"End\":true},\"FailState\":{\"Type\":\"Fail\",\"Cause\":\"Unsupported operator\",\"Error\":\"UnsupportedOperatorError\"}}]"
        },
        "RoleArn": {
          "Fn::GetAtt": [
            "StateMachineRole",
            "Arn"
          ]
        }
      },
      "effects": [
        "state-machine"
      ]
    },
    {
      "id": "Calculator",
      "kind": "AWS::Lambda::Function",
      "fields": {
        "Handler": "index.handler",
        "Runtime": "nodejs18.x",
        "Code": {
          "ZipFile": {
            "Fn::Join": [
              "",
              [
                "exports.handler = async (event) => {",
                "const { operator, operands } = event;",
                "let result;",
                "switch(operator) {",
                "case 'add': result = operands[0] + operands[1]; break;",
                "case 'subtract': result = operands[0] - operands[1]; break;",
                "case 'multiply': result = operands[0] * operands[1]; break;",
                "case 'divide': result = operands[1] !== 0 ? operands[0] / operands[1] : 'Error: Division by zero'; break;",
                "default: throw new Error('Unsupported operator');",
                "}",
                "return { result };",
                "};"
              ]
            ]
          }
        },
        "Timeout": 30,
        "MemorySize": 128,
        "Role": {
          "Fn::GetAtt": [
            "LambdaRole",
            "Arn"
          ]
        }
      },
      "effects": [
        "lambda",
        "serverless"
      ]
    },
    {
      "id": "CalculatorLogGroup",
      "kind": "AWS::Logs::LogGroup",
      "fields": {
        "LogGroupName": {
          "Fn::Join": [
            "",
            [
              "/aws/lambda/",
              {
                "Ref": "Calculator"
              }
            ]
          ]
        },
        "RetentionInDays": 3
      },
      "effects": [
        "logging",
        "retention-3d"
      ]
    },
    {
      "id": "StateMachineRole",
      "kind": "AWS::IAM::Role",
      "fields": {
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "states.amazonaws.com"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "ManagedPolicyArns": [
          "arn:aws:iam::aws:policy/service-role/AWSLambdaRole"
        ]
      },
      "effects": [
        "iam",
        "execution-role"
      ]
    },
    {
      "id": "LambdaRole",
      "kind": "AWS::IAM::Role",
      "fields": {
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "lambda.amazonaws.com"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "ManagedPolicyArns": [
          "arn:aws:iam::aws:policy/service-role/AWSLambdaBasicExecutionRole"
        ]
      },
      "effects": [
        "iam",
        "execution-role"
      ]
    }
  ],
  "edges": [
    {
      "type": "depends",
      "from": "Calculator-StateMachine",
      "to": "StateMachineRole"
    },
    {
      "type": "depends",
      "from": "Calculator",
      "to": "LambdaRole"
    },
    {
      "type": "depends",
      "from": "Calculator",
      "to": "CalculatorLogGroup"
    }
  ],
  "invariants": [
    "Step Functions state machine routes arithmetic operations based on operator input",
    "Lambda function executes calculations and returns results to workflow",
    "CloudWatch Logs group retains logs for 3 days for debugging and cleanup",
    "IAM roles provide necessary permissions for Step Functions and Lambda execution"
  ]
}