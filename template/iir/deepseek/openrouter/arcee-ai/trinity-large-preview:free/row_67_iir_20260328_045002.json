{
  "resources": [
    {
      "id": "S3Bucket",
      "kind": "AWS::S3::Bucket",
      "fields": {
        "AccessControl": "Private",
        "PublicAccessBlockConfiguration": {
          "BlockPublicAcls": true,
          "BlockPublicPolicy": true,
          "IgnorePublicAcls": true,
          "RestrictPublicBuckets": true
        }
      },
      "effects": [
        "encrypted",
        "versioned"
      ]
    },
    {
      "id": "BucketPolicy",
      "kind": "AWS::S3::BucketPolicy",
      "fields": {
        "Bucket": "S3Bucket"
      },
      "effects": [
        "organization-access"
      ]
    }
  ],
  "edges": [
    {
      "type": "depends",
      "from": "BucketPolicy",
      "to": "S3Bucket"
    }
  ],
  "invariants": [
    "Bucket must be encrypted at rest",
    "Bucket must have versioning enabled",
    "Policy must allow access to entire AWS Organization or Organization Unit when OrgId is provided",
    "Policy must allow full access to single account when no OrgId is provided"
  ]
}