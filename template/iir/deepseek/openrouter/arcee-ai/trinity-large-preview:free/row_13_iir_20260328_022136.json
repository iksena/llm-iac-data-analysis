{
  "resources": [
    {
      "id": "WebServerInstance",
      "kind": "AWS::EC2::Instance",
      "fields": {
        "ImageId": "ami-0c55b159cbfafe1f0",
        "InstanceType": "t2.micro",
        "KeyName": "my-key-pair",
        "IamInstanceProfile": "EC2InstanceProfile",
        "UserData": {
          "Fn::Base64": {
            "Fn::Join": [
              "",
              [
                "#!/bin/bash -xe\n",
                "/opt/aws/bin/cfn-init -v ",
                "         --stack ",
                {
                  "Ref": "AWS::StackName"
                },
                "         --resource WebServerInstance ",
                "         --region ",
                {
                  "Ref": "AWS::Region"
                },
                "\n",
                "/opt/aws/bin/cfn-signal -e $? ",
                "         --stack ",
                {
                  "Ref": "AWS::StackName"
                },
                "         --resource WebServerInstance ",
                "         --region ",
                {
                  "Ref": "AWS::Region"
                }
              ]
            ]
          }
        },
        "Metadata": {
          "AWS::CloudFormation::Init": {
            "config": {
              "packages": {
                "yum": {
                  "httpd": []
                }
              },
              "files": {
                "/var/www/html/index.html": {
                  "content": "Hello World from EC2 instance!",
                  "mode": "000644",
                  "owner": "root",
                  "group": "root"
                }
              },
              "services": {
                "sysvinit": {
                  "httpd": {
                    "enabled": "true",
                    "ensureRunning": "true"
                  }
                }
              }
            }
          },
          "AWS::CloudFormation::Authentication": {
            "S3AccessCreds": {
              "type": "S3",
              "accessKeyId": {
                "Ref": "AWSAccessKeyId"
              },
              "secretKey": {
                "Ref": "AWSSecretKey"
              },
              "buckets": [
                "my-s3-bucket"
              ]
            }
          }
        }
      },
      "effects": [
        "encrypted",
        "versioned"
      ]
    },
    {
      "id": "WebServerSecurityGroup",
      "kind": "AWS::EC2::SecurityGroup",
      "fields": {
        "GroupDescription": "Enable HTTP access",
        "SecurityGroupIngress": [
          {
            "IpProtocol": "tcp",
            "FromPort": "80",
            "ToPort": "80",
            "CidrIp": "0.0.0.0/0"
          }
        ]
      },
      "effects": [
        "public-read"
      ]
    },
    {
      "id": "WebServerRole",
      "kind": "AWS::IAM::Role",
      "fields": {
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": [
                  "ec2.amazonaws.com"
                ]
              },
              "Action": [
                "sts:AssumeRole"
              ]
            }
          ]
        },
        "ManagedPolicyArns": [
          "arn:aws:iam::aws:policy/service-role/AmazonEC2RoleforSSM"
        ]
      },
      "effects": [
        "encrypted"
      ]
    },
    {
      "id": "WebServerInstanceProfile",
      "kind": "AWS::IAM::InstanceProfile",
      "fields": {
        "Roles": [
          {
            "Ref": "WebServerRole"
          }
        ]
      },
      "effects": [
        "encrypted"
      ]
    }
  ],
  "edges": [
    {
      "type": "depends",
      "from": "WebServerInstance",
      "to": "WebServerSecurityGroup"
    },
    {
      "type": "depends",
      "from": "WebServerInstance",
      "to": "WebServerInstanceProfile"
    },
    {
      "type": "connects",
      "from": "WebServerInstance",
      "to": "Internet",
      "proto": "tcp",
      "port": 80
    }
  ],
  "invariants": [
    "EC2 instance must be bootstrapped with Apache HTTP Server",
    "CreationPolicy with cfn-signal must confirm successful initialization",
    "Instance must be accessible via HTTP on port 80",
    "IAM role must grant necessary permissions for cfn-init and SSM",
    "UserData must execute cfn-init and cfn-signal for proper stack coordination"
  ]
}