{
  "resources": [
    {
      "id": "EFSFileSystem",
      "kind": "AWS::EFS::FileSystem",
      "fields": {
        "PerformanceMode": "generalPurpose",
        "ThroughputMode": "bursting",
        "Encrypted": true,
        "BackupPolicy": {
          "Status": "ENABLED"
        }
      },
      "effects": [
        "encrypted",
        "versioned"
      ]
    },
    {
      "id": "MountTargetA",
      "kind": "AWS::EFS::MountTarget",
      "fields": {
        "FileSystemId": "EFSFileSystem",
        "SubnetId": "PublicSubnetA",
        "SecurityGroups": [
          "EFSSecurityGroup"
        ]
      },
      "effects": []
    },
    {
      "id": "MountTargetB",
      "kind": "AWS::EFS::MountTarget",
      "fields": {
        "FileSystemId": "EFSFileSystem",
        "SubnetId": "PublicSubnetB",
        "SecurityGroups": [
          "EFSSecurityGroup"
        ]
      },
      "effects": []
    },
    {
      "id": "EFSSecurityGroup",
      "kind": "AWS::EC2::SecurityGroup",
      "fields": {
        "VpcId": "VPC",
        "GroupDescription": "Security group for EFS access",
        "SecurityGroupIngress": [
          {
            "IpProtocol": "tcp",
            "FromPort": 2049,
            "ToPort": 2049,
            "SourceSecurityGroupId": "ClientSecurityGroup"
          }
        ]
      },
      "effects": []
    },
    {
      "id": "IOUtilizationAlarm",
      "kind": "AWS::CloudWatch::Alarm",
      "fields": {
        "AlarmName": "EFS IO Utilization High",
        "AlarmDescription": "Alarm when EFS IO utilization exceeds 80%",
        "Namespace": "AWS/EFS",
        "MetricName": "PercentIOLimit",
        "Statistic": "Average",
        "Period": 300,
        "EvaluationPeriods": 1,
        "Threshold": 80,
        "ComparisonOperator": "GreaterThanThreshold",
        "AlarmActions": [
          "AlarmTopic"
        ]
      },
      "effects": [
        "monitored"
      ]
    },
    {
      "id": "BurstCreditAlarm",
      "kind": "AWS::CloudWatch::Alarm",
      "fields": {
        "AlarmName": "EFS Burst Credit Low",
        "AlarmDescription": "Alarm when EFS burst credits fall below 20%",
        "Namespace": "AWS/EFS",
        "MetricName": "BurstCreditBalance",
        "Statistic": "Average",
        "Period": 300,
        "EvaluationPeriods": 1,
        "Threshold": 20,
        "ComparisonOperator": "LessThanThreshold",
        "AlarmActions": [
          "AlarmTopic"
        ]
      },
      "effects": [
        "monitored"
      ]
    },
    {
      "id": "ThroughputAlarm",
      "kind": "AWS::CloudWatch::Alarm",
      "fields": {
        "AlarmName": "EFS Throughput High",
        "AlarmDescription": "Alarm when EFS throughput exceeds 90% of provisioned",
        "Namespace": "AWS/EFS",
        "MetricName": "PermittedThroughput",
        "Statistic": "Average",
        "Period": 300,
        "EvaluationPeriods": 1,
        "Threshold": 90,
        "ComparisonOperator": "GreaterThanThreshold",
        "AlarmActions": [
          "AlarmTopic"
        ]
      },
      "effects": [
        "monitored"
      ]
    },
    {
      "id": "AlarmTopic",
      "kind": "AWS::SNS::Topic",
      "fields": {
        "DisplayName": "EFS Alarms"
      },
      "effects": []
    },
    {
      "id": "BackupPlan",
      "kind": "AWS::Backup::BackupPlan",
      "fields": {
        "BackupPlan": {
          "BackupPlanName": "EFS Backup Plan",
          "Rules": [
            {
              "RuleName": "Daily EFS Backup",
              "TargetBackupVault": "EFSBackupVault",
              "ScheduleExpression": "cron(0 2 * * ? *)",
              "StartWindowMinutes": 60,
              "CompletionWindowMinutes": 480,
              "Lifecycle": {
                "DeleteAfterDays": 30
              }
            }
          ]
        }
      },
      "effects": [
        "automated-backup"
      ]
    },
    {
      "id": "EFSBackupVault",
      "kind": "AWS::Backup::BackupVault",
      "fields": {
        "BackupVaultName": "EFSBackupVault"
      },
      "effects": []
    },
    {
      "id": "BackupSelection",
      "kind": "AWS::Backup::BackupSelection",
      "fields": {
        "BackupPlanId": "BackupPlan",
        "BackupSelection": {
          "SelectionName": "EFS Backup Selection",
          "IamRoleArn": "BackupRole",
          "Resources": [
            "EFSFileSystem"
          ]
        }
      },
      "effects": []
    },
    {
      "id": "BackupRole",
      "kind": "AWS::IAM::Role",
      "fields": {
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "backup.amazonaws.com"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "ManagedPolicyArns": [
          "arn:aws:iam::aws:policy/service-role/AWSBackupDefaultServiceRole"
        ]
      },
      "effects": []
    }
  ],
  "edges": [
    {
      "type": "depends",
      "from": "MountTargetA",
      "to": "EFSFileSystem"
    },
    {
      "type": "depends",
      "from": "MountTargetB",
      "to": "EFSFileSystem"
    },
    {
      "type": "depends",
      "from": "MountTargetA",
      "to": "EFSSecurityGroup"
    },
    {
      "type": "depends",
      "from": "MountTargetB",
      "to": "EFSSecurityGroup"
    },
    {
      "type": "depends",
      "from": "IOUtilizationAlarm",
      "to": "AlarmTopic"
    },
    {
      "type": "depends",
      "from": "BurstCreditAlarm",
      "to": "AlarmTopic"
    },
    {
      "type": "depends",
      "from": "ThroughputAlarm",
      "to": "AlarmTopic"
    },
    {
      "type": "depends",
      "from": "BackupSelection",
      "to": "BackupPlan"
    },
    {
      "type": "depends",
      "from": "BackupSelection",
      "to": "BackupRole"
    }
  ],
  "invariants": [
    "EFS file system must be encrypted at rest",
    "CloudWatch alarms must monitor IO utilization, burst credits, and throughput",
    "Automated backups must be conditionally enabled with customizable CRON schedule",
    "EFS must be accessible from VPC subnets with proper security groups",
    "Backup plan must include lifecycle policies for data retention"
  ]
}