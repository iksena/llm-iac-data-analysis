{
  "resources": [
    {
      "id": "SecretsManagerEventRule",
      "kind": "AWS::Events::Rule",
      "fields": {
        "EventPattern": {
          "source": [
            "aws.secretsmanager"
          ],
          "detail-type": [
            "AWS API Call via CloudTrail"
          ],
          "detail": {
            "eventSource": [
              "secretsmanager.amazonaws.com"
            ],
            "eventName": [
              "CreateSecret",
              "UpdateSecret",
              "DeleteSecret",
              "RotateSecret",
              "PutSecretValue"
            ]
          }
        },
        "State": "ENABLED",
        "Targets": [
          {
            "Id": "SecretsManagerEventTarget",
            "Arn": "Ref: SecretsManagerSNSTopic"
          }
        ]
      },
      "effects": [
        "event-driven",
        "secrets-monitoring"
      ]
    },
    {
      "id": "SecretsManagerSNSTopic",
      "kind": "AWS::SNS::Topic",
      "fields": {
        "DisplayName": "SecretsManagerAlertTopic"
      },
      "effects": [
        "messaging",
        "notifications"
      ]
    },
    {
      "id": "SecretsManagerSNSTubscription",
      "kind": "AWS::SNS::Subscription",
      "fields": {
        "Endpoint": "Ref: EmailAddress",
        "Protocol": "email",
        "TopicArn": "Ref: SecretsManagerSNSTopic"
      },
      "effects": [
        "email-notifications"
      ]
    }
  ],
  "edges": [
    {
      "type": "depends",
      "from": "SecretsManagerEventRule",
      "to": "SecretsManagerSNSTopic"
    },
    {
      "type": "depends",
      "from": "SecretsManagerSNSTubscription",
      "to": "SecretsManagerSNSTopic"
    }
  ],
  "invariants": [
    "EventBridge rule must monitor Secrets Manager API calls",
    "SNS topic must receive events from EventBridge rule",
    "Email subscription must be configured for SNS topic",
    "Only critical secret lifecycle events should trigger notifications"
  ]
}