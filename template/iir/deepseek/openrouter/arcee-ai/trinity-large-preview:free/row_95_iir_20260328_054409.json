{
  "resources": [
    {
      "id": "EC2Instance",
      "kind": "AWS::EC2::Instance",
      "fields": {
        "ImageId": "ami-0c55b159cbfafe0f0",
        "InstanceType": "t3.micro",
        "IamInstanceProfile": {
          "Ref": "SSMInstanceProfile"
        },
        "Tags": [
          {
            "Key": "nginx",
            "Value": "Yes"
          }
        ]
      },
      "effects": [
        "encrypted"
      ]
    },
    {
      "id": "SSMInstanceProfile",
      "kind": "AWS::IAM::InstanceProfile",
      "fields": {
        "Roles": [
          {
            "Ref": "SSMRole"
          }
        ]
      }
    },
    {
      "id": "SSMRole",
      "kind": "AWS::IAM::Role",
      "fields": {
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "ec2.amazonaws.com"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "ManagedPolicyArns": [
          "arn:aws:iam::aws:policy/service-role/AmazonEC2RoleforSSM"
        ]
      }
    },
    {
      "id": "SSMAutomationDocument",
      "kind": "AWS::SSM::Document",
      "fields": {
        "Content": {
          "schemaVersion": "1.0",
          "description": "Install Nginx and validate",
          "parameters": {},
          "mainSteps": [
            {
              "name": "UpdateOS",
              "action": "aws:runShellScript",
              "inputs": {
                "runCommand": [
                  "sudo yum update -y",
                  "sudo shutdown -r now"
                ]
              }
            },
            {
              "name": "InstallNginx",
              "action": "aws:runShellScript",
              "inputs": {
                "runCommand": [
                  "sudo yum install -y nginx",
                  "sudo systemctl start nginx",
                  "sudo systemctl enable nginx"
                ]
              }
            },
            {
              "name": "ValidateNginx",
              "action": "aws:runShellScript",
              "inputs": {
                "runCommand": [
                  "curl -f http://localhost/ || exit 1"
                ]
              }
            }
          ]
        },
        "DocumentType": "Automation",
        "Tags": [
          {
            "Key": "nginx",
            "Value": "Yes"
          }
        ]
      },
      "effects": [
        "tag-driven"
      ]
    }
  ],
  "edges": [
    {
      "type": "depends",
      "from": "EC2Instance",
      "to": "SSMInstanceProfile"
    },
    {
      "type": "depends",
      "from": "SSMInstanceProfile",
      "to": "SSMRole"
    },
    {
      "type": "connects",
      "from": "SSMAutomationDocument",
      "to": "EC2Instance",
      "proto": "https",
      "port": 443
    }
  ],
  "invariants": [
    "EC2 instance must have SSM access for automation",
    "Nginx installation and validation must complete successfully",
    "Automation targets instances with nginx:Yes tag"
  ]
}