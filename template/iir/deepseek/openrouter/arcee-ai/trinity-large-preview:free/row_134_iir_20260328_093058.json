{
  "resources": [
    {
      "id": "LambdaExecutionRole",
      "kind": "AWS::IAM::Role",
      "fields": {
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "lambda.amazonaws.com"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "ManagedPolicyArns": [
          "arn:aws:iam::aws:policy/service-role/AWSLambdaBasicExecutionRole"
        ]
      },
      "effects": [
        "iam-role",
        "cloudwatch-logs"
      ]
    },
    {
      "id": "BasicLambdaFunction",
      "kind": "AWS::Lambda::Function",
      "fields": {
        "Handler": "index.handler",
        "Runtime": "nodejs18.x",
        "Role": "LambdaExecutionRole",
        "Code": {
          "ZipFile": "exports.handler = async (event) => {\n  console.log('Event received:', JSON.stringify(event));\n  return event.value || 'No value provided';\n};"
        },
        "Timeout": 10
      },
      "effects": [
        "lambda-function",
        "inline-code"
      ]
    }
  ],
  "edges": [
    {
      "type": "depends",
      "from": "BasicLambdaFunction",
      "to": "LambdaExecutionRole"
    }
  ],
  "invariants": [
    "Lambda function must have IAM role with CloudWatch Logs permissions",
    "Function uses inline Node.js code for logging and returning value",
    "Runtime is Node.js 18.x",
    "Timeout is set to 10 seconds"
  ]
}