{
  "resources": [
    {
      "id": "DynamoDbTable",
      "kind": "AWS::DynamoDB::Table",
      "fields": {
        "TableName": "OrdersTable",
        "BillingMode": "PAY_PER_REQUEST",
        "StreamSpecification": {
          "StreamViewType": "NEW_AND_OLD_IMAGES"
        },
        "KeySchema": [
          {
            "AttributeName": "OrderId",
            "KeyType": "HASH"
          }
        ],
        "AttributeDefinitions": [
          {
            "AttributeName": "OrderId",
            "AttributeType": "S"
          }
        ]
      },
      "effects": [
        "encrypted",
        "versioned"
      ]
    },
    {
      "id": "EventBus",
      "kind": "AWS::Events::EventBus",
      "fields": {
        "Name": "OrdersEventBus"
      },
      "effects": [
        "public-read"
      ]
    },
    {
      "id": "InsertPipe",
      "kind": "AWS::Events::Pipe",
      "fields": {
        "Name": "InsertEventPipe",
        "Source": {
          "DynamoDBStreamParameters": {
            "StreamArn": {
              "Fn::GetAtt": [
                "DynamoDbTable",
                "StreamArn"
              ]
            },
            "StartingPosition": "LATEST"
          }
        },
        "Target": {
          "EventBridgeEventBusParameters": {
            "EventBusName": {
              "Ref": "EventBus"
            },
            "DetailType": "OrderCreated",
            "Source": "com.company.orders"
          }
        },
        "Filter": {
          "EventPattern": {
            "source": [
              "aws.dynamodb"
            ],
            "detail": {
              "eventName": [
                "INSERT"
              ]
            }
          }
        }
      },
      "effects": [
        "encrypted"
      ]
    },
    {
      "id": "ModifyPipe",
      "kind": "AWS::Events::Pipe",
      "fields": {
        "Name": "ModifyEventPipe",
        "Source": {
          "DynamoDBStreamParameters": {
            "StreamArn": {
              "Fn::GetAtt": [
                "DynamoDbTable",
                "StreamArn"
              ]
            },
            "StartingPosition": "LATEST"
          }
        },
        "Target": {
          "EventBridgeEventBusParameters": {
            "EventBusName": {
              "Ref": "EventBus"
            },
            "DetailType": "OrderUpdated",
            "Source": "com.company.orders"
          }
        },
        "Filter": {
          "EventPattern": {
            "source": [
              "aws.dynamodb"
            ],
            "detail": {
              "eventName": [
                "MODIFY"
              ]
            }
          }
        }
      },
      "effects": [
        "encrypted"
      ]
    }
  ],
  "edges": [
    {
      "type": "depends",
      "from": "InsertPipe",
      "to": "DynamoDbTable"
    },
    {
      "type": "depends",
      "from": "ModifyPipe",
      "to": "DynamoDbTable"
    },
    {
      "type": "depends",
      "from": "InsertPipe",
      "to": "EventBus"
    },
    {
      "type": "depends",
      "from": "ModifyPipe",
      "to": "EventBus"
    }
  ],
  "invariants": [
    "DynamoDB table must have stream enabled for NEW_AND_OLD_IMAGES",
    "EventBridge Pipes must filter INSERT and MODIFY events separately",
    "EventBridge Pipes must forward events to the same centralized event bus"
  ]
}