{
  "resources": [
    {
      "id": "MyS3Bucket",
      "kind": "AWS::S3::Bucket",
      "fields": {},
      "effects": [
        "versioned"
      ]
    },
    {
      "id": "MySNSTopic",
      "kind": "AWS::SNS::Topic",
      "fields": {},
      "effects": []
    },
    {
      "id": "S3TopicPolicy",
      "kind": "AWS::SNS::TopicPolicy",
      "fields": {
        "Topics": [
          {
            "Ref": "MySNSTopic"
          }
        ],
        "PolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "s3.amazonaws.com"
              },
              "Action": "sns:Publish",
              "Resource": {
                "Ref": "MySNSTopic"
              },
              "Condition": {
                "ArnLike": {
                  "AWS:SourceArn": {
                    "Fn::Join": [
                      "",
                      [
                        "arn:aws:s3:::",
                        {
                          "Ref": "MyS3Bucket"
                        }
                      ]
                    ]
                  }
                }
              }
            }
          ]
        }
      },
      "effects": []
    },
    {
      "id": "S3NotificationConfig",
      "kind": "AWS::S3::BucketNotification",
      "fields": {
        "Bucket": {
          "Ref": "MyS3Bucket"
        },
        "TopicConfigurations": [
          {
            "Topic": {
              "Ref": "MySNSTopic"
            },
            "Events": [
              "s3:ObjectCreated:*"
            ]
          }
        ]
      },
      "effects": []
    }
  ],
  "edges": [
    {
      "type": "depends",
      "from": "S3TopicPolicy",
      "to": "MySNSTopic"
    },
    {
      "type": "depends",
      "from": "S3NotificationConfig",
      "to": "MyS3Bucket"
    },
    {
      "type": "depends",
      "from": "S3NotificationConfig",
      "to": "MySNSTopic"
    }
  ],
  "invariants": [
    "SNS topic policy restricts S3 service access to specific bucket and account",
    "S3 bucket sends notifications for all object creation events",
    "Notification configuration links bucket events to SNS topic"
  ]
}