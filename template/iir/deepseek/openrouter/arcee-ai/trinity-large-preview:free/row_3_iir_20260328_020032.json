{
  "resources": [
    {
      "id": "WebsiteBucket",
      "kind": "AWS::S3::Bucket",
      "fields": {
        "AccessControl": "PublicRead",
        "WebsiteConfiguration": {
          "IndexDocument": "index.html",
          "ErrorDocument": "error.html"
        }
      },
      "effects": [
        "public-read",
        "website-hosting"
      ]
    }
  ],
  "edges": [],
  "invariants": [
    "DeletionPolicy: Retain"
  ]
}