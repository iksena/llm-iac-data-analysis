{
  "resources": [
    {
      "id": "MyRestApi",
      "kind": "AWS::ApiGateway::RestApi",
      "fields": {
        "Name": "MyRestApi"
      },
      "effects": []
    },
    {
      "id": "MyLambdaFunction",
      "kind": "AWS::Lambda::Function",
      "fields": {
        "Handler": "index.handler",
        "Runtime": "nodejs14.x",
        "Code": {
          "ZipFile": "exports.handler = async (event) => {\n  const response = {\n    statusCode: 200,\n    body: JSON.stringify('Hello from Lambda!'),\n  };\n  return response;\n};"
        },
        "Timeout": 30,
        "Role": {
          "Fn::GetAtt": [
            "LambdaExecutionRole",
            "Arn"
          ]
        }
      },
      "effects": []
    },
    {
      "id": "LambdaExecutionRole",
      "kind": "AWS::IAM::Role",
      "fields": {
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "lambda.amazonaws.com"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "ManagedPolicyArns": [
          "arn:aws:iam::aws:policy/service-role/AWSLambdaBasicExecutionRole"
        ]
      },
      "effects": []
    },
    {
      "id": "MyApiGatewayMethod",
      "kind": "AWS::ApiGateway::Method",
      "fields": {
        "HttpMethod": "GET",
        "ResourceId": {
          "Fn::GetAtt": [
            "MyRestApi",
            "RootResourceId"
          ]
        },
        "RestApiId": {
          "Ref": "MyRestApi"
        },
        "AuthorizationType": "NONE",
        "Integration": {
          "IntegrationHttpMethod": "POST",
          "Type": "AWS_PROXY",
          "Uri": {
            "Fn::Sub": "arn:aws:apigateway:${AWS::Region}:lambda:path/2015-03-31/functions/${MyLambdaFunction.Arn}/invocations"
          }
        }
      },
      "effects": []
    },
    {
      "id": "MyApiGatewayDeployment",
      "kind": "AWS::ApiGateway::Deployment",
      "fields": {
        "RestApiId": {
          "Ref": "MyRestApi"
        },
        "StageName": "prod"
      },
      "effects": []
    },
    {
      "id": "LambdaApiGatewayPermission",
      "kind": "AWS::Lambda::Permission",
      "fields": {
        "Action": "lambda:InvokeFunction",
        "FunctionName": {
          "Fn::GetAtt": [
            "MyLambdaFunction",
            "Arn"
          ]
        },
        "Principal": "apigateway.amazonaws.com",
        "SourceArn": {
          "Fn::Sub": "arn:aws:execute-api:${AWS::Region}:${AWS::AccountId}:${MyRestApi}/*/*/"
        }
      },
      "effects": []
    }
  ],
  "edges": [
    {
      "type": "depends",
      "from": "MyLambdaFunction",
      "to": "LambdaExecutionRole"
    },
    {
      "type": "depends",
      "from": "MyApiGatewayMethod",
      "to": "MyRestApi"
    },
    {
      "type": "depends",
      "from": "MyApiGatewayDeployment",
      "to": "MyRestApi"
    },
    {
      "type": "depends",
      "from": "LambdaApiGatewayPermission",
      "to": "MyLambdaFunction"
    },
    {
      "type": "depends",
      "from": "LambdaApiGatewayPermission",
      "to": "MyRestApi"
    }
  ],
  "invariants": [
    "Lambda function must have execution role with basic execution permissions",
    "API Gateway method must integrate with Lambda using AWS_PROXY",
    "Deployment must be created for the API to be accessible",
    "Lambda must be granted permission to be invoked by API Gateway"
  ]
}