{
  "resources": [
    {
      "id": "VPC",
      "kind": "AWS::EC2::VPC",
      "fields": {
        "CidrBlock": "10.0.0.0/16",
        "EnableDnsSupport": true,
        "EnableDnsHostnames": true
      },
      "effects": [
        "isolated"
      ]
    },
    {
      "id": "PrivateSubnetA",
      "kind": "AWS::EC2::Subnet",
      "fields": {
        "VpcId": "VPC",
        "CidrBlock": "10.0.1.0/24",
        "AvailabilityZone": "us-east-1a"
      },
      "effects": [
        "private"
      ]
    },
    {
      "id": "PrivateSubnetB",
      "kind": "AWS::EC2::Subnet",
      "fields": {
        "VpcId": "VPC",
        "CidrBlock": "10.0.2.0/24",
        "AvailabilityZone": "us-east-1b"
      },
      "effects": [
        "private"
      ]
    },
    {
      "id": "DBSubnetGroup",
      "kind": "AWS::RDS::DBSubnetGroup",
      "fields": {
        "DBSubnetGroupDescription": "RDS subnet group for MySQL",
        "SubnetIds": [
          "PrivateSubnetA",
          "PrivateSubnetB"
        ]
      },
      "effects": [
        "database"
      ]
    },
    {
      "id": "RDSSecurityGroup",
      "kind": "AWS::EC2::SecurityGroup",
      "fields": {
        "GroupDescription": "Security group for MySQL RDS",
        "VpcId": "VPC",
        "SecurityGroupIngress": [
          {
            "IpProtocol": "tcp",
            "FromPort": 3306,
            "ToPort": 3306,
            "SourceSecurityGroupId": {
              "Ref": "VPC"
            }
          }
        ]
      },
      "effects": [
        "restricted-access"
      ]
    },
    {
      "id": "MySQLRDS",
      "kind": "AWS::RDS::DBInstance",
      "fields": {
        "DBInstanceClass": "db.r5.large",
        "Engine": "mysql",
        "MasterUsername": "admin",
        "MasterUserPassword": "password",
        "AllocatedStorage": 100,
        "StorageType": "io1",
        "Iops": 1000,
        "DBSubnetGroupName": "DBSubnetGroup",
        "VPCSecurityGroups": [
          "RDSSecurityGroup"
        ],
        "MultiAZ": false,
        "BackupRetentionPeriod": 7,
        "StorageEncrypted": true
      },
      "effects": [
        "encrypted",
        "provisioned-iops"
      ]
    }
  ],
  "edges": [
    {
      "type": "depends",
      "from": "PrivateSubnetA",
      "to": "VPC"
    },
    {
      "type": "depends",
      "from": "PrivateSubnetB",
      "to": "VPC"
    },
    {
      "type": "depends",
      "from": "DBSubnetGroup",
      "to": "PrivateSubnetA"
    },
    {
      "type": "depends",
      "from": "DBSubnetGroup",
      "to": "PrivateSubnetB"
    },
    {
      "type": "depends",
      "from": "RDSSecurityGroup",
      "to": "VPC"
    },
    {
      "type": "depends",
      "from": "MySQLRDS",
      "to": "DBSubnetGroup"
    },
    {
      "type": "depends",
      "from": "MySQLRDS",
      "to": "RDSSecurityGroup"
    }
  ],
  "invariants": [
    "Database deployed across two private subnets in different AZs",
    "Provisioned IOPS storage (io1) with 1000 IOPS",
    "Network isolation via dedicated VPC and security group",
    "Access restricted to port 3306 for internal VPC traffic",
    "Storage encryption enabled",
    "db.r5.large instance class"
  ]
}