{
  "resources": [
    {
      "id": "MyS3Bucket",
      "kind": "AWS::S3::Bucket",
      "fields": {},
      "effects": [
        "versioned"
      ]
    },
    {
      "id": "MyLambdaFunction",
      "kind": "AWS::Lambda::Function",
      "fields": {
        "Handler": "index.handler",
        "Runtime": "nodejs18.x",
        "Role": "arn:aws:iam::123456789012:role/lambda-execution-role"
      },
      "effects": [
        "encrypted"
      ]
    },
    {
      "id": "MyLambdaPermission",
      "kind": "AWS::Lambda::Permission",
      "fields": {
        "Action": "lambda:InvokeFunction",
        "Principal": "s3.amazonaws.com",
        "SourceArn": "arn:aws:s3:::my-bucket-name"
      },
      "effects": []
    },
    {
      "id": "MyS3BucketNotification",
      "kind": "AWS::S3::BucketNotification",
      "fields": {
        "Bucket": "MyS3Bucket",
        "LambdaFunctionConfigurations": [
          {
            "LambdaFunctionArn": "arn:aws:lambda:us-east-1:123456789012:function:MyLambdaFunction",
            "Events": [
              "s3:ObjectCreated:*"
            ]
          }
        ]
      },
      "effects": []
    }
  ],
  "edges": [
    {
      "type": "depends",
      "from": "MyLambdaPermission",
      "to": "MyLambdaFunction"
    },
    {
      "type": "depends",
      "from": "MyS3BucketNotification",
      "to": "MyS3Bucket"
    },
    {
      "type": "depends",
      "from": "MyS3BucketNotification",
      "to": "MyLambdaFunction"
    }
  ],
  "invariants": [
    "S3 bucket must be versioned",
    "Lambda function must have execution role",
    "Lambda must be triggered on object creation events"
  ]
}