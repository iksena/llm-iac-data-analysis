        ],
        "LaunchTemplate": {
          "LaunchTemplateId": "LaunchTemplate",
          "Version": "1"
        },
        "MinSize": 1,
        "MaxSize": 3,
        "DesiredCapacity": 1
      },
      "effects": [
        "high-availability",
        "multi-az",
        "automated-scaling"
      ]
