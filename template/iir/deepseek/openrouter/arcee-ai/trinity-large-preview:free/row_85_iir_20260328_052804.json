{
  "resources": [
    {
      "id": "CloudWatchExportBucket",
      "kind": "AWS::S3::Bucket",
      "fields": {
        "BucketName": "cloudwatch-exports-${AWS::AccountId}",
        "AccessControl": "Private",
        "VersioningConfiguration": {
          "Status": "Enabled"
        },
        "LifecycleConfiguration": {
          "Rules": [
            {
              "Id": "TransitionToInfrequentAccess",
              "Status": "Enabled",
              "Transitions": [
                {
                  "Days": 30,
                  "StorageClass": "STANDARD_IA"
                }
              ]
            },
            {
              "Id": "TransitionToGlacier",
              "Status": "Enabled",
              "Transitions": [
                {
                  "Days": 60,
                  "StorageClass": "GLACIER"
                }
              ]
            },
            {
              "Id": "Expiration",
              "Status": "Enabled",
              "ExpirationInDays": 365
            }
          ]
        },
        "PublicAccessBlockConfiguration": {
          "BlockPublicAcls": true,
          "BlockPublicPolicy": true,
          "IgnorePublicAcls": true,
          "RestrictPublicBuckets": true
        },
        "BucketEncryption": {
          "ServerSideEncryptionConfiguration": [
            {
              "ServerSideEncryptionByDefault": {
                "SSEAlgorithm": "AES256"
              }
            }
          ]
        }
      },
      "effects": [
        "private",
        "encrypted",
        "versioned",
        "lifecycle-managed"
      ]
    }
  ],
  "edges": [],
  "invariants": [
    "Bucket must be private and encrypted at rest",
    "Versioning must be configurable",
    "Lifecycle policies must transition to STANDARD_IA after 30 days",
    "Lifecycle policies must transition to GLACIER after 60 days",
    "Objects must expire after 365 days",
    "Bucket must block all public access"
  ]
}