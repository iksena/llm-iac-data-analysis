{
  "resources": [
    {
      "id": "S3AccessPolicy",
      "kind": "AWS::IAM::ManagedPolicy",
      "fields": {
        "PolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Action": [
                "s3:PutObject",
                "s3:GetObject",
                "s3:DeleteObject",
                "s3:ListBucket",
                "s3:GetBucketLocation"
              ],
              "Resource": [
                "arn:aws:s3:::ios-apps.sagebridge.org",
                "arn:aws:s3:::ios-apps.sagebridge.org/*"
              ]
            }
          ]
        },
        "Description": "Grants iOS application read/write access to ios-apps.sagebridge.org S3 bucket"
      },
      "effects": [
        "s3-access"
      ]
    },
    {
      "id": "DynamoDBProtectionPolicy",
      "kind": "AWS::IAM::ManagedPolicy",
      "fields": {
        "PolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Deny",
              "Action": [
                "dynamodb:DeleteTable",
                "dynamodb:UpdateTable",
                "dynamodb:TagResource",
                "dynamodb:UntagResource",
                "dynamodb:RestoreTableFromBackup",
                "dynamodb:RestoreTableToPointInTime"
              ],
              "Resource": "*"
            }
          ]
        },
        "Description": "Prevents deletion and schema modification of DynamoDB tables"
      },
      "effects": [
        "dynamodb-protection"
      ]
    },
    {
      "id": "RDSProtectionPolicy",
      "kind": "AWS::IAM::ManagedPolicy",
      "fields": {
        "PolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Deny",
              "Action": [
                "rds:DeleteDBInstance",
                "rds:DeleteDBCluster",
                "rds:DeleteDBSnapshot",
                "rds:DeleteDBClusterSnapshot",
                "rds:DeleteEventSubscription",
                "rds:DeleteOptionGroup",
                "rds:DeleteDBSubnetGroup",
                "rds:DeleteDBParameterGroup",
                "rds:DeleteDBSecurityGroup"
              ],
              "Resource": "*"
            }
          ]
        },
        "Description": "Blocks destructive RDS operations to protect databases and backups"
      },
      "effects": [
        "rds-protection"
      ]
    }
  ],
  "edges": [],
  "invariants": [
    "S3 policy grants read/write access to ios-apps.sagebridge.org bucket",
    "DynamoDB policy explicitly denies deletion and schema modification actions",
    "RDS policy blocks all destructive database operations",
    "Policies are independent and can be attached to different IAM roles/users"
  ]
}