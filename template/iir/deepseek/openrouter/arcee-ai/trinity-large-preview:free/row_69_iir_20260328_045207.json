{
  "resources": [
    {
      "id": "VPC",
      "kind": "AWS::EC2::VPC",
      "fields": {
        "CidrBlock": "10.0.0.0/16",
        "EnableDnsSupport": true,
        "EnableDnsHostnames": true
      },
      "effects": [
        "vpc"
      ]
    },
    {
      "id": "SecurityGroup",
      "kind": "AWS::EC2::SecurityGroup",
      "fields": {
        "GroupDescription": "Security group for application",
        "VpcId": {
          "Ref": "VPC"
        },
        "SecurityGroupIngress": [
          {
            "IpProtocol": "tcp",
            "FromPort": 80,
            "ToPort": 80,
            "CidrIp": "0.0.0.0/0"
          }
        ]
      },
      "effects": [
        "public-facing"
      ]
    },
    {
      "id": "S3Bucket",
      "kind": "AWS::S3::Bucket",
      "fields": {
        "BucketName": "my-application-bucket",
        "AccessControl": "Private",
        "VersioningConfiguration": {
          "Status": "Enabled"
        }
      },
      "effects": [
        "encrypted",
        "versioned"
      ]
    },
    {
      "id": "DynamoDBTable",
      "kind": "AWS::DynamoDB::Table",
      "fields": {
        "TableName": "my-application-table",
        "BillingMode": "PAY_PER_REQUEST",
        "KeySchema": [
          {
            "AttributeName": "id",
            "KeyType": "HASH"
          }
        ],
        "AttributeDefinitions": [
          {
            "AttributeName": "id",
            "AttributeType": "S"
          }
        ],
        "SSESpecification": {
          "Enabled": true
        }
      },
      "effects": [
        "encrypted",
        "deletion-protected"
      ]
    }
  ],
  "edges": [
    {
      "type": "depends",
      "from": "SecurityGroup",
      "to": "VPC"
    }
  ],
  "invariants": [
    "VPC must be created before Security Group",
    "S3 Bucket must be encrypted",
    "DynamoDB Table must have server-side encryption enabled",
    "DynamoDB Table must have deletion protection enabled"
  ]
}