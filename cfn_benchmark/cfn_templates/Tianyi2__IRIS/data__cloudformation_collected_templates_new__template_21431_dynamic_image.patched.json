                "ReadOnly": true,
                "SourceContainer": "KiltImage"
              }
            ]
          },
          {
            "EntryPoint": [
              "/kilt/wait"
            ],
            "Image": "KILT:latest",
            "Name": "KiltImage"
          }
        ],
        "RequiresCompatibilities": [
          "FARGATE"
        ],
        "Tags": [
          {
            "Key": "antani",
            "Value": "sbiribuda"
          },
          {
            "Key": "kiltinclude",
            "Value": "itisignored"
          }
        ]
