{
  "resources": [
    {
      "id": "LambdaExecutionRole",
      "kind": "AWS::IAM::Role",
      "fields": {
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "lambda.amazonaws.com"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "Policies": [
          {
            "PolicyName": "LambdaBasicExecution",
            "PolicyDocument": {
              "Version": "2012-10-17",
              "Statement": [
                {
                  "Effect": "Allow",
                  "Action": [
                    "logs:CreateLogGroup",
                    "logs:CreateLogStream",
                    "logs:PutLogEvents"
                  ],
                  "Resource": "arn:aws:logs:*:*:*"
                }
              ]
            }
          }
        ]
      },
      "effects": [
        "iam-role",
        "lambda-execution"
      ]
    },
    {
      "id": "LambdaFunction",
      "kind": "AWS::Lambda::Function",
      "fields": {
        "Handler": "index.handler",
        "Runtime": "nodejs18.x",
        "Role": "arn:aws:iam::123456789012:role/LambdaExecutionRole",
        "Code": {
          "ZipFile": "exports.handler = async (event) => { return { statusCode: 200, body: JSON.stringify('Hello from Lambda!') }; };"
        }
      },
      "effects": [
        "lambda-function",
        "cross-account"
      ]
    },
    {
      "id": "ApiGatewayRestApi",
      "kind": "AWS::ApiGateway::RestApi",
      "fields": {
        "Name": "PrivateAPIGateway",
        "EndpointConfiguration": {
          "Types": [
            "PRIVATE"
          ]
        }
      },
      "effects": [
        "private-api-gateway",
        "vpc-endpoint-restricted"
      ]
    },
    {
      "id": "ApiGatewayResource",
      "kind": "AWS::ApiGateway::Resource",
      "fields": {
        "ParentId": "ApiGatewayRestApi.RootResourceId",
        "PathPart": "lambda",
        "RestApiId": "ApiGatewayRestApi"
      },
      "effects": [
        "api-resource"
      ]
    },
    {
      "id": "ApiGatewayMethod",
      "kind": "AWS::ApiGateway::Method",
      "fields": {
        "HttpMethod": "GET",
        "ResourceId": "ApiGatewayResource",
        "RestApiId": "ApiGatewayRestApi",
        "AuthorizationType": "NONE",
        "Integration": {
          "Type": "AWS_PROXY",
          "IntegrationHttpMethod": "POST",
          "Uri": "arn:aws:apigateway:us-east-1:lambda:path/2015-03-31/functions/arn:aws:lambda:us-east-1:123456789012:function:LambdaFunction/invocations"
        }
      },
      "effects": [
        "api-method",
        "lambda-integration"
      ]
    },
    {
      "id": "ApiGatewayDeployment",
      "kind": "AWS::ApiGateway::Deployment",
      "fields": {
        "RestApiId": "ApiGatewayRestApi",
        "StageName": "prod"
      },
      "effects": [
        "api-deployment",
        "stage-prod"
      ]
    },
    {
      "id": "ApiGatewayVpcLink",
      "kind": "AWS::ApiGateway::VpcLink",
      "fields": {
        "Name": "PrivateVpcLink",
        "TargetArns": [
          "arn:aws:elasticloadbalancing:us-east-1:123456789012:loadbalancer/app/my-load-balancer/1234567890123456"
        ]
      },
      "effects": [
        "vpc-link",
        "private-access"
      ]
    },
    {
      "id": "ApiGatewayDomainName",
      "kind": "AWS::ApiGateway::DomainName",
      "fields": {
        "DomainName": "api.example.com",
        "EndpointConfiguration": {
          "Types": [
            "PRIVATE"
          ]
        }
      },
      "effects": [
        "custom-domain",
        "private-endpoint"
      ]
    },
    {
      "id": "ApiGatewayBasePathMapping",
      "kind": "AWS::ApiGateway::BasePathMapping",
      "fields": {
        "DomainName": "ApiGatewayDomainName",
        "RestApiId": "ApiGatewayRestApi",
        "Stage": "prod"
      },
      "effects": [
        "base-path-mapping",
        "custom-domain-mapping"
      ]
    },
    {
      "id": "ApiGatewayAccount",
      "kind": "AWS::ApiGateway::Account",
      "fields": {
        "CloudWatchRoleArn": "arn:aws:iam::123456789012:role/ApiGatewayCloudWatchRole"
      },
      "effects": [
        "api-account",
        "cloudwatch-logging"
      ]
    },
    {
      "id": "LambdaInvokePermission",
      "kind": "AWS::Lambda::Permission",
      "fields": {
        "FunctionName": "LambdaFunction",
        "Action": "lambda:InvokeFunction",
        "Principal": "apigateway.amazonaws.com",
        "SourceArn": "arn:aws:execute-api:us-east-1:123456789012:ApiGatewayRestApi/prod/GET/lambda"
      },
      "effects": [
        "lambda-permission",
        "api-gateway-invoke"
      ]
    }
  ],
  "edges": [
    {
      "type": "depends",
      "from": "LambdaFunction",
      "to": "LambdaExecutionRole"
    },
    {
      "type": "depends",
      "from": "ApiGatewayResource",
      "to": "ApiGatewayRestApi"
    },
    {
      "type": "depends",
      "from": "ApiGatewayMethod",
      "to": "ApiGatewayResource"
    },
    {
      "type": "depends",
      "from": "ApiGatewayDeployment",
      "to": "ApiGatewayMethod"
    },
    {
      "type": "depends",
      "from": "ApiGatewayBasePathMapping",
      "to": "ApiGatewayDomainName"
    },
    {
      "type": "depends",
      "from": "ApiGatewayBasePathMapping",
      "to": "ApiGatewayDeployment"
    },
    {
      "type": "depends",
      "from": "LambdaInvokePermission",
      "to": "LambdaFunction"
    },
    {
      "type": "depends",
      "from": "LambdaInvokePermission",
      "to": "ApiGatewayRestApi"
    }
  ],
  "invariants": [
    "API Gateway must be private and accessible only via specified VPC endpoint",
    "Lambda function must have execution role with CloudWatch logging permissions",
    "Custom domain must be configured for private API Gateway",
    "Cross-account Lambda invocation must be permitted",
    "API Gateway deployment must be associated with custom domain and stage"
  ]
}