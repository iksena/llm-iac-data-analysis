{
  "resources": [
    {
      "id": "EC2Instance",
      "kind": "AWS::EC2::Instance",
      "fields": {
        "ImageId": "ssm:/aws/service/ami-amazon-linux-latest/amzn2-ami-hvm-x86_64-gp2",
        "InstanceType": "t3.micro",
        "KeyName": "Ref::KeyName",
        "BlockDeviceMappings": [
          {
            "DeviceName": "/dev/xvda",
            "Ebs": {
              "VolumeType": "gp2",
              "DeleteOnTermination": true
            }
          },
          {
            "DeviceName": "/dev/xvdb",
            "VirtualName": "ephemeral0"
          }
        ]
      },
      "effects": [
        "encrypted"
      ]
    },
    {
      "id": "SSHKeyPair",
      "kind": "AWS::EC2::KeyPair",
      "fields": {
        "KeyName": "Ref::KeyName",
        "PublicKeyMaterial": "Ref::PublicKey"
      },
      "effects": []
    }
  ],
  "edges": [
    {
      "type": "depends",
      "from": "EC2Instance",
      "to": "SSHKeyPair"
    }
  ],
  "invariants": [
    "EC2 instance must use latest Amazon Linux 2 AMI",
    "Ephemeral drives must be configured via BlockDeviceMappings",
    "SSH key pair must be created for secure access",
    "Instance must deploy in default VPC/subnet"
  ]
}