{
  "resources": [
    {
      "id": "ObjectCreatedBucket",
      "kind": "AWS::S3::Bucket",
      "fields": {
        "NotificationConfiguration": {
          "EventBridgeConfiguration": {
            "Enabled": true
          }
        }
      },
      "effects": [
        "encrypted"
      ]
    },
    {
      "id": "EventBridgeRule",
      "kind": "AWS::Events::Rule",
      "fields": {
        "EventPattern": {
          "source": [
            "aws.s3"
          ],
          "detail-type": [
            "AWS API Call via CloudTrail"
          ],
          "detail": {
            "eventSource": [
              "s3.amazonaws.com"
            ],
            "eventName": [
              "PutObject"
            ]
          }
        },
        "Targets": [
          {
            "Arn": {
              "Ref": "SnsTopic"
            },
            "Id": "SnsTarget"
          }
        ]
      },
      "effects": []
    },
    {
      "id": "SnsTopic",
      "kind": "AWS::SNS::Topic",
      "fields": {},
      "effects": []
    }
  ],
  "edges": [
    {
      "type": "depends",
      "from": "EventBridgeRule",
      "to": "SnsTopic"
    },
    {
      "type": "connects",
      "from": "ObjectCreatedBucket",
      "to": "EventBridgeRule",
      "proto": "https",
      "port": 443
    }
  ],
  "invariants": [
    "S3 bucket must be encrypted at rest",
    "EventBridge rule must trigger on S3 object creation events",
    "SNS topic must receive notifications from EventBridge"
  ]
}