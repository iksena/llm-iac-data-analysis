{
  "resources": [
    {
      "id": "EC2Instance",
      "kind": "AWS::EC2::Instance",
      "fields": {
        "ImageId": "ami-0c55b159cbfafe0f0",
        "InstanceType": "t3.micro",
        "IamInstanceProfile": {
          "Ref": "InstanceProfile"
        },
        "UserData": {
          "Fn::Base64": {
            "Fn::Join": [
              "",
              [
                "#!/bin/bash\n",
                "yum update -y\n",
                "amazon-linux-extras install nginx1 -y\n",
                "systemctl start nginx\n",
                "systemctl enable nginx\n"
              ]
            ]
          }
        }
      },
      "effects": [
        "public-read | encrypted | versioned"
      ]
    },
    {
      "id": "InstanceProfile",
      "kind": "AWS::IAM::InstanceProfile",
      "fields": {
        "Roles": [
          {
            "Ref": "IAMRole"
          }
        ]
      },
      "effects": []
    },
    {
      "id": "IAMRole",
      "kind": "AWS::IAM::Role",
      "fields": {
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "ec2.amazonaws.com"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "ManagedPolicyArns": [
          "arn:aws:iam::aws:policy/AmazonSSMManagedInstanceCore",
          "arn:aws:iam::aws:policy/AmazonS3FullAccess"
        ]
      },
      "effects": []
    },
    {
      "id": "SSMBucket",
      "kind": "AWS::S3::Bucket",
      "fields": {
        "BucketName": "ssm-logs-bucket",
        "AccessControl": "Private",
        "VersioningConfiguration": {
          "Status": "Enabled"
        },
        "LoggingConfiguration": {
          "DestinationBucketName": {
            "Ref": "SSMBucket"
          },
          "LogFilePrefix": "logs/"
        }
      },
      "effects": [
        "public-read | encrypted | versioned"
      ]
    },
    {
      "id": "SSMAssociation",
      "kind": "AWS::SSM::Association",
      "fields": {
        "Name": "AWS-RunShellScript",
        "Targets": [
          {
            "Key": "InstanceIds",
            "Values": [
              {
                "Ref": "EC2Instance"
              }
            ]
          }
        ],
        "Parameters": {
          "commands": [
            [
              "#!/bin/bash\n",
              "yum update -y\n",
              "amazon-linux-extras install nginx1 -y\n",
              "systemctl start nginx\n",
              "systemctl enable nginx"
            ]
          ]
        },
        "OutputLocation": {
          "S3Location": {
            "BucketName": {
              "Ref": "SSMBucket"
            },
            "OutputS3Prefix": "logs/ssm/"
          }
        }
      },
      "effects": []
    }
  ],
  "edges": [
    {
      "type": "depends",
      "from": "EC2Instance",
      "to": "InstanceProfile"
    },
    {
      "type": "depends",
      "from": "InstanceProfile",
      "to": "IAMRole"
    },
    {
      "type": "depends",
      "from": "SSMAssociation",
      "to": "EC2Instance"
    },
    {
      "type": "connects",
      "from": "SSMAssociation",
      "to": "SSMBucket",
      "proto": "https",
      "port": 443
    }
  ],
  "invariants": [
    "EC2 instance must have SSM permissions for automated configuration",
    "Nginx installation must execute during instance launch",
    "SSM command outputs must be stored in S3 with structured logging paths",
    "S3 bucket must support versioning for audit trails",
    "IAM role must grant SSM and S3 access to the instance"
  ]
}