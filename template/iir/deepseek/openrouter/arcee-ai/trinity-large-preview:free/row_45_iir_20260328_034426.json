{
  "resources": [
    {
      "id": "FirehoseDeliveryStream",
      "kind": "AWS::KinesisFirehose::DeliveryStream",
      "fields": {
        "DeliveryStreamName": "EncryptedFirehoseStream",
        "DeliveryStreamType": "DirectPut",
        "ExtendedS3DestinationConfiguration": {
          "BucketARN": "arn:aws:s3:::example-bucket",
          "ErrorOutputPrefix": "error/!{firehose:error-output-type}/",
          "BufferingHints": {
            "SizeInMBs": 5,
            "IntervalInSeconds": 300
          },
          "CompressionFormat": "UNCOMPRESSED",
          "EncryptionConfiguration": {
            "KMSEncryptionConfig": {
              "AWSKMSKeyARN": "arn:aws:kms:us-east-1:123456789012:key/abcd1234-abcd-1234-abcd-123456789012"
            },
            "NoEncryptionConfig": "NoEncryption"
          }
        }
      },
      "effects": [
        "encrypted",
        "error-logging"
      ]
    },
    {
      "id": "CloudWatchLogGroup",
      "kind": "AWS::Logs::LogGroup",
      "fields": {
        "LogGroupName": "FirehoseErrorLogs",
        "RetentionInDays": 30
      },
      "effects": [
        "logging"
      ]
    },
    {
      "id": "CloudWatchLogStream",
      "kind": "AWS::Logs::LogStream",
      "fields": {
        "LogGroupName": "FirehoseErrorLogs",
        "LogStreamName": "FirehoseErrorStream"
      },
      "effects": [
        "logging"
      ]
    }
  ],
  "edges": [
    {
      "type": "depends",
      "from": "CloudWatchLogStream",
      "to": "CloudWatchLogGroup"
    }
  ],
  "invariants": [
    "Server-side encryption using AWS Managed keys (SSE-KMS)",
    "Error logging enabled to CloudWatch Logs",
    "Log group and stream created for error tracking"
  ]
}