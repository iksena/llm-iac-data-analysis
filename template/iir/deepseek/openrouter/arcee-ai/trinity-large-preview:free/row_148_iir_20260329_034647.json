      "effects": [
        "secure",
        "ssm-access"
      ]
    },
    {
      "id": "LaunchTemplate",
      "kind": "AWS::EC2::LaunchTemplate",
      "fields": {
        "LaunchTemplateName": "JenkinsLaunchTemplate",
        "LaunchTemplateData": {
          "ImageId": "ami-0c55b159cbfafe0f0",
          "InstanceType": "t3.medium",
          "IamInstanceProfile": {
            "Name": "InstanceProfile"
          },
          "SecurityGroupIds": [
            "SecurityGroup"
          ],
          "UserData": "base64-encoded-jenkins-install-script",
          "KeyName": "my-key-pair"
        }
      },
      "effects": [
        "automated-deployment",
        "jenkins"
      ]
    },
    {
      "id": "AutoScalingGroup",
      "kind": "AWS::AutoScaling::AutoScalingGroup",
      "fields": {
