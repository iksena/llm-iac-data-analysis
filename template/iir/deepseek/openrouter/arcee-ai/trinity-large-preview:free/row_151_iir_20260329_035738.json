{
  "resources": [
    {
      "id": "StockPriceLambda",
      "kind": "AWS::Lambda::Function",
      "fields": {
        "Handler": "index.handler",
        "Runtime": "nodejs18.x",
        "Code": {
          "ZipFile": "exports.handler = async (event) => { return { statusCode: 200, body: JSON.stringify({ price: 100 }) }; };"
        },
        "Role": "LambdaExecutionRole"
      },
      "effects": [
        "encrypted"
      ]
    },
    {
      "id": "LambdaExecutionRole",
      "kind": "AWS::IAM::Role",
      "fields": {
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "lambda.amazonaws.com"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "ManagedPolicyArns": [
          "arn:aws:iam::aws:policy/service-role/AWSLambdaBasicExecutionRole"
        ]
      },
      "effects": [
        "least-privilege"
      ]
    },
    {
      "id": "BedrockAgentRole",
      "kind": "AWS::IAM::Role",
      "fields": {
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "bedrock.amazonaws.com"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "Policies": [
          {
            "PolicyName": "BedrockAgentPolicy",
            "PolicyDocument": {
              "Version": "2012-10-17",
              "Statement": [
                {
                  "Effect": "Allow",
                  "Action": "bedrock:InvokeModel",
                  "Resource": "*"
                }
              ]
            }
          }
        ]
      },
      "effects": [
        "least-privilege"
      ]
    },
    {
      "id": "BedrockAgent",
      "kind": "AWS::Bedrock::Agent",
      "fields": {
        "Name": "StockPriceAgent",
        "Description": "Agent for stock price lookup",
        "RoleArn": "BedrockAgentRole",
        "ModelId": "anthropic.claude-3-sonnet-20240229",
        "Instructions": "Handle stock-related queries. Use the getStockPrice action to retrieve stock prices.",
        "ActionGroups": [
          {
            "Name": "StockPriceLookup",
            "Description": "Retrieve stock prices",
            "Actions": [
              {
                "Name": "getStockPrice",
                "Description": "Get stock price for a symbol",
                "LambdaFunction": "StockPriceLambda",
                "Parameters": [
                  {
                    "Name": "symbol",
                    "Type": "STRING",
                    "Required": true
                  }
                ]
              }
            ]
          }
        ]
      },
      "effects": [
        "public-read"
      ]
    }
  ],
  "edges": [
    {
      "type": "depends",
      "from": "StockPriceLambda",
      "to": "LambdaExecutionRole"
    },
    {
      "type": "depends",
      "from": "BedrockAgent",
      "to": "BedrockAgentRole"
    },
    {
      "type": "depends",
      "from": "BedrockAgent",
      "to": "StockPriceLambda"
    }
  ],
  "invariants": [
    "Lambda function must have logging permissions",
    "Bedrock Agent must have model invocation permissions",
    "IAM roles must follow least-privilege principle",
    "Bedrock Agent must be configured with Claude 3 Sonnet model",
    "Action group must support parameterized stock symbol inputs"
  ]
}