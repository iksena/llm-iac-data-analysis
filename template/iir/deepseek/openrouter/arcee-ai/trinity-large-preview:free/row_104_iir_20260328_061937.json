{
  "resources": [
    {
      "id": "VPC",
      "kind": "AWS::EC2::VPC",
      "fields": {
        "CidrBlock": "10.0.0.0/16",
        "EnableDnsSupport": true,
        "EnableDnsHostnames": true
      },
      "effects": [
        "isolated"
      ]
    },
    {
      "id": "InternetGateway",
      "kind": "AWS::EC2::InternetGateway",
      "fields": {},
      "effects": [
        "public"
      ]
    },
    {
      "id": "VPCGatewayAttachment",
      "kind": "AWS::EC2::VPCGatewayAttachment",
      "fields": {
        "VpcId": "VPC",
        "InternetGatewayId": "InternetGateway"
      },
      "effects": []
    },
    {
      "id": "PublicRouteTable",
      "kind": "AWS::EC2::RouteTable",
      "fields": {
        "VpcId": "VPC"
      },
      "effects": [
        "public"
      ]
    },
    {
      "id": "PublicRoute",
      "kind": "AWS::EC2::Route",
      "fields": {
        "RouteTableId": "PublicRouteTable",
        "DestinationCidrBlock": "0.0.0.0/0",
        "GatewayId": "InternetGateway"
      },
      "effects": [
        "public"
      ]
    },
    {
      "id": "PublicSubnet",
      "kind": "AWS::EC2::Subnet",
      "fields": {
        "VpcId": "VPC",
        "CidrBlock": "10.0.1.0/24",
        "MapPublicIpOnLaunch": true,
        "AvailabilityZone": "us-east-1a"
      },
      "effects": [
        "public"
      ]
    },
    {
      "id": "SubnetRouteTableAssociation",
      "kind": "AWS::EC2::SubnetRouteTableAssociation",
      "fields": {
        "SubnetId": "PublicSubnet",
        "RouteTableId": "PublicRouteTable"
      },
      "effects": []
    },
    {
      "id": "AdminInstanceRole",
      "kind": "AWS::IAM::Role",
      "fields": {
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "ec2.amazonaws.com"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "ManagedPolicyArns": [
          "arn:aws:iam::aws:policy/service-role/AmazonEC2RoleforSSM"
        ],
        "Policies": [
          {
            "PolicyName": "AdminInstancePolicy",
            "PolicyDocument": {
              "Version": "2012-10-17",
              "Statement": [
                {
                  "Effect": "Allow",
                  "Action": [
                    "lambda:InvokeFunction",
                    "cloudformation:*"
                  ],
                  "Resource": "*"
                }
              ]
            }
          }
        ]
      },
      "effects": [
        "privileged"
      ]
    },
    {
      "id": "AdminInstanceProfile",
      "kind": "AWS::IAM::InstanceProfile",
      "fields": {
        "Roles": [
          "AdminInstanceRole"
        ]
      },
      "effects": []
    },
    {
      "id": "SecurityGroup",
      "kind": "AWS::EC2::SecurityGroup",
      "fields": {
        "GroupDescription": "Allow all outbound traffic",
        "VpcId": "VPC",
        "SecurityGroupEgress": [
          {
            "IpProtocol": "-1",
            "CidrIp": "0.0.0.0/0"
          }
        ]
      },
      "effects": [
        "permissive"
      ]
    },
    {
      "id": "AdminInstance",
      "kind": "AWS::EC2::Instance",
      "fields": {
        "ImageId": "ami-0c55b159cbfafe1f0",
        "InstanceType": "t3.nano",
        "IamInstanceProfile": "AdminInstanceProfile",
        "SubnetId": "PublicSubnet",
        "SecurityGroupIds": [
          "SecurityGroup"
        ],
        "UserData": {
          "Fn::Base64": {
            "Fn::Join": [
              "",
              [
                "#!/bin/bash\n",
                "yum update -y\n",
                "yum install -y aws-cli\n",
                "curl -o aws-instance-scheduler-cli.zip https://github.com/awslabs/aws-instance-scheduler-cli/releases/latest/download/aws-instance-scheduler-cli.zip\n",
                "unzip aws-instance-scheduler-cli.zip -d /opt/aws-instance-scheduler-cli\n",
                "export PATH=$PATH:/opt/aws-instance-scheduler-cli\n",
                "echo 'Instance Scheduler CLI installed'\n"
              ]
            ]
          }
        },
        "Tags": [
          {
            "Key": "environment",
            "Value": "dev"
          }
        ]
      },
      "effects": [
        "admin",
        "dev"
      ]
    },
    {
      "id": "DevInstances",
      "kind": "AWS::EC2::Instance",
      "fields": {
        "ImageId": "ami-0c55b159cbfafe1f0",
        "InstanceType": "t3.nano",
        "SubnetId": "PublicSubnet",
        "SecurityGroupIds": [
          "SecurityGroup"
        ],
        "Tags": [
          {
            "Key": "environment",
            "Value": "dev"
          }
        ]
      },
      "effects": [
        "dev"
      ]
    }
  ],
