{
  "resources": [
    {
      "id": "MyBucket",
      "kind": "AWS::S3::Bucket",
      "fields": {
        "BucketName": "my-encrypted-bucket",
        "BucketEncryption": {
          "ServerSideEncryptionConfiguration": [
            {
              "ServerSideEncryptionByDefault": {
                "SSEAlgorithm": "aws:kms",
                "KMSMasterKeyID": "alias/MyKMSKeyAlias"
              }
            }
          ]
        },
        "LifecycleConfiguration": {
          "Rules": [
            {
              "Status": "Enabled",
              "Transition": [
                {
                  "Days": 30,
                  "StorageClass": "STANDARD_IA"
                },
                {
                  "Days": 90,
                  "StorageClass": "GLACIER"
                }
              ]
            }
          ]
        },
        "Tags": [
          {
            "Key": "Environment",
            "Value": "Production"
          },
          {
            "Key": "Project",
            "Value": "DataAnalytics"
          }
        ]
      },
      "effects": [
        "encrypted",
        "lifecycle-managed",
        "tagged"
      ]
    },
    {
      "id": "MyKMSKey",
      "kind": "AWS::KMS::Key",
      "fields": {
        "Description": "KMS key for S3 bucket encryption",
        "Enabled": true,
        "EnableKeyRotation": true
      },
      "effects": [
        "encrypted"
      ]
    },
    {
      "id": "MyKMSKeyAlias",
      "kind": "AWS::KMS::Alias",
      "fields": {
        "AliasName": "alias/MyKMSKeyAlias",
        "TargetKeyId": "MyKMSKey"
      },
      "effects": [
        "key-management"
      ]
    }
  ],
  "edges": [
    {
      "type": "depends",
      "from": "MyBucket",
      "to": "MyKMSKeyAlias"
    },
    {
      "type": "depends",
      "from": "MyKMSKeyAlias",
      "to": "MyKMSKey"
    }
  ],
  "invariants": [
    "S3 bucket must use KMS encryption",
    "Lifecycle management must transition objects to STANDARD_IA after 30 days and GLACIER after 90 days",
    "KMS key must be rotated automatically",
    "Bucket must be tagged for organizational tracking"
  ]
}