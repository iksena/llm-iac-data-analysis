{
  "resources": [
    {
      "id": "LambdaArtifactsBucket",
      "kind": "AWS::S3::Bucket",
      "fields": {
        "AccessControl": "PublicRead",
        "VersioningConfiguration": {
          "Status": "Enabled"
        }
      },
      "effects": [
        "public-read",
        "versioned"
      ]
    },
    {
      "id": "LambdaArtifactsKMSKey",
      "kind": "AWS::KMS::Key",
      "fields": {
        "Description": "KMS key for Lambda artifacts encryption",
        "EnableKeyRotation": true,
        "KeyPolicy": {
          "Version": "2012-10-17",
          "Id": "key-default-1",
          "Statement": [
            {
              "Sid": "Enable IAM User Permissions",
              "Effect": "Allow",
              "Principal": {
                "AWS": "arn:aws:iam::123456789012:root"
              },
              "Action": "kms:*",
              "Resource": "*"
            },
            {
              "Sid": "Allow service role usage",
              "Effect": "Allow",
              "Principal": {
                "AWS": "arn:aws:iam::123456789012:role/ServiceRole"
              },
              "Action": [
                "kms:Encrypt",
                "kms:Decrypt",
                "kms:ReEncrypt*",
                "kms:GenerateDataKey*",
                "kms:DescribeKey"
              ],
              "Resource": "*"
            }
          ]
        }
      },
      "effects": [
        "encrypted",
        "auto-rotate"
      ]
    },
    {
      "id": "LambdaArtifactsKMSKeyAlias",
      "kind": "AWS::KMS::Alias",
      "fields": {
        "AliasName": "alias/lambda-artifacts-key",
        "TargetKeyId": "LambdaArtifactsKMSKey"
      },
      "effects": [
        "key-alias"
      ]
    }
  ],
  "edges": [
    {
      "type": "depends",
      "from": "LambdaArtifactsKMSKeyAlias",
      "to": "LambdaArtifactsKMSKey"
    }
  ],
  "invariants": [
    "S3 bucket must be publicly accessible for Lambda artifact distribution",
    "KMS key must support automatic rotation",
    "KMS key must allow root account administration and service role usage",
    "KMS key alias must reference the correct key"
  ]
}