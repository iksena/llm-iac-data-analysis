{
  "resources": [
    {
      "id": "MyBucket",
      "kind": "AWS::S3::Bucket",
      "fields": {},
      "effects": [
        "encrypted"
      ]
    },
    {
      "id": "MyQueue",
      "kind": "AWS::SQS::Queue",
      "fields": {},
      "effects": []
    },
    {
      "id": "BucketNotification",
      "kind": "AWS::S3::BucketNotification",
      "fields": {
        "Bucket": "MyBucket",
        "QueueConfigurations": [
          {
            "Event": "s3:ObjectCreated:*",
            "QueueArn": {
              "Fn::GetAtt": [
                "MyQueue",
                "Arn"
              ]
            }
          }
        ]
      },
      "effects": []
    }
  ],
  "edges": [
    {
      "type": "depends",
      "from": "BucketNotification",
      "to": "MyBucket"
    },
    {
      "type": "depends",
      "from": "BucketNotification",
      "to": "MyQueue"
    }
  ],
  "invariants": [
    "S3 bucket must be encrypted at rest",
    "SQS queue must receive notifications for all object creation events",
    "Bucket notification configuration must reference both bucket and queue"
  ]
}