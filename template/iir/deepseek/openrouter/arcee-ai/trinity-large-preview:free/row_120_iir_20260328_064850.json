{
  "resources": [
    {
      "id": "SQSQueue",
      "kind": "AWS::SQS::Queue",
      "fields": {
        "QueueName": "OrderProcessingQueue"
      },
      "effects": [
        "event-source"
      ]
    },
    {
      "id": "BatchJobDefinition",
      "kind": "AWS::Batch::JobDefinition",
      "fields": {
        "Type": "container",
        "ContainerProperties": {
          "Image": "public.ecr.aws/my-container:latest",
          "Memory": 2048,
          "Vcpus": 2
        }
      },
      "effects": [
        "containerized"
      ]
    },
    {
      "id": "BatchJobQueue",
      "kind": "AWS::Batch::JobQueue",
      "fields": {
        "Priority": 1,
        "ComputeEnvironmentOrder": [
          {
            "Order": 1,
            "ComputeEnvironment": "BatchComputeEnvironment"
          }
        ]
      },
      "effects": [
        "job-queue"
      ]
    },
    {
      "id": "BatchComputeEnvironment",
      "kind": "AWS::Batch::ComputeEnvironment",
      "fields": {
        "Type": "MANAGED",
        "ComputeResources": {
          "Type": "EC2",
          "MinvCpus": 0,
          "MaxvCpus": 16,
          "DesiredvCpus": 4,
          "InstanceTypes": [
            "optimal"
          ],
          "Subnets": [
            {
              "Ref": "VPCPrivateSubnets"
            }
          ],
          "SecurityGroupIds": [
            {
              "Ref": "BatchSecurityGroup"
            }
          ]
        }
      },
      "effects": [
        "compute-resource"
      ]
    },
    {
      "id": "EventBridgePipe",
      "kind": "AWS::EventBridge::Pipe",
      "fields": {
        "Source": {
          "Ref": "SQSQueue"
        },
        "Target": {
          "Ref": "BatchJobQueue"
        },
        "Filter": {
          "EventPattern": {
            "detail": {
              "eventType": [
                "OrderCreated"
              ]
            }
          }
        }
      },
      "effects": [
        "event-driven",
        "message-filter"
      ]
    },
    {
      "id": "BatchIAMRole",
      "kind": "AWS::IAM::Role",
      "fields": {
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "batch.amazonaws.com"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "ManagedPolicyArns": [
          "arn:aws:iam::aws:policy/service-role/AWSBatchServiceRole"
        ]
      },
      "effects": [
        "batch-service-role"
      ]
    },
    {
      "id": "EventBridgePipeIAMRole",
      "kind": "AWS::IAM::Role",
      "fields": {
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "events.amazonaws.com"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "Policies": [
          {
            "PolicyName": "EventBridgePipePolicy",
            "PolicyDocument": {
              "Version": "2012-10-17",
              "Statement": [
                {
                  "Effect": "Allow",
                  "Action": [
                    "sqs:ReceiveMessage",
                    "sqs:DeleteMessage",
                    "batch:SubmitJob"
                  ],
                  "Resource": "*"
                }
              ]
            }
          }
        ]
      },
      "effects": [
        "pipe-execution-role"
      ]
    },
    {
      "id": "ECSIAMRole",
      "kind": "AWS::IAM::Role",
      "fields": {
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "ecs-tasks.amazonaws.com"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "ManagedPolicyArns": [
          "arn:aws:iam::aws:policy/service-role/AmazonECSTaskExecutionRolePolicy"
        ]
      },
      "effects": [
        "ecs-execution-role"
      ]
    },
    {
      "id": "VPC",
      "kind": "AWS::EC2::VPC",
      "fields": {
        "CidrBlock": "10.0.0.0/16",
        "EnableDnsSupport": true,
        "EnableDnsHostnames": true
      },
      "effects": [
        "isolated-network"
      ]
    },
    {
      "id": "VPCPrivateSubnets",
      "kind": "AWS::EC2::Subnet",
      "fields": {
        "VpcId": {
          "Ref": "VPC"
        },
        "CidrBlock": "10.0.1.0/24",
        "AvailabilityZone": "us-east-1a"
      },
      "effects": [
        "private-subnet"
      ]
    },
    {
      "id": "BatchSecurityGroup",
      "kind": "AWS::EC2::SecurityGroup",
      "fields": {
        "GroupDescription": "Security group for Batch compute resources",
        "VpcId": {
          "Ref": "VPC"
        },
        "SecurityGroupIngress": [
          {
            "IpProtocol": "tcp",
            "FromPort": 0,
            "ToPort": 65535,
            "SourceSecurityGroupId": {
              "Ref": "BatchSecurityGroup"
            }
          }
        ],
        "SecurityGroupEgress": [
          {
            "IpProtocol": "tcp",
            "FromPort": 0,
            "ToPort": 65535,
            "CidrIp": "0.0.0.0/0"
          }
        ]
      },
      "effects": [
        "isolated-compute"
      ]
    }
  ],
  "edges": [
    {
      "type": "depends",
      "from": "BatchJobQueue",
      "to": "BatchComputeEnvironment"
    },
    {
      "type": "depends",
      "from": "BatchComputeEnvironment",
      "to": "VPCPrivateSubnets"
    },
    {
      "type": "depends",
      "from": "BatchComputeEnvironment",
      "to": "BatchSecurityGroup"
    },
    {
      "type": "depends",
      "from": "EventBridgePipe",
      "to": "SQSQueue"
    },
    {
      "type": "depends",
      "from": "EventBridgePipe",
      "to": "BatchJobQueue"
    },
    {
      "type": "depends",
      "from": "BatchJobDefinition",
      "to": "ECSIAMRole"
    },
    {
      "type": "depends",
      "from": "VPCPrivateSubnets",
      "to": "VPC"
    }
  ],
  "invariants": [
    "EventBridge Pipe filters SQS messages for 'OrderCreated' events",
    "Batch jobs run in isolated VPC with private subnets",
    "IAM roles grant least-privilege access for Batch, Pipes, and ECS",
    "Compute resources scale between 0 and 16 vCPUs",
    "Container image is pulled from ECR with proper execution role"
  ]
}