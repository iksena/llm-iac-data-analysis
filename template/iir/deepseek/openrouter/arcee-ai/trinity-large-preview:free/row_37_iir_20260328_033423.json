        "public-access-disabled"
      ]
    }
  ],
  "edges": [
    {
      "type": "depends",
      "from": "ReplicaBucket",
      "to": "SecureBucket"
    },
    {
      "type": "depends",
      "from": "AccessLogBucket",
      "to": "SecureBucket"
    }
  ],
  "invariants": [
    "Server-side encryption enabled on all buckets",
    "Public access blocked on all buckets",
    "Secure transport required for SecureBucket",
    "Versioning enabled on all buckets"
  ]
