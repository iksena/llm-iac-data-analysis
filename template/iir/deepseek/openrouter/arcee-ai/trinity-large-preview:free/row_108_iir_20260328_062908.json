{
  "resources": [
    {
      "id": "CognitoUserPool",
      "kind": "AWS::Cognito::UserPool",
      "fields": {
        "UserPoolName": "SecureUserPool",
        "Policies": {
          "PasswordPolicy": {
            "MinimumLength": 8,
            "RequireLowercase": true,
            "RequireNumbers": true,
            "RequireSymbols": true,
            "RequireUppercase": true
          }
        },
        "AutoVerifiedAttributes": [
          "email"
        ],
        "EmailVerificationMessage": "Your verification code is {####}",
        "EmailVerificationSubject": "Your verification code",
        "AdminCreateUserConfig": {
          "AllowAdminCreateUserOnly": true,
          "InviteMessageTemplate": {
            "EmailMessage": "Your username is {username} and temporary password is {####}",
            "EmailSubject": "Your temporary password"
          }
        },
        "Schema": [
          {
            "Name": "email",
            "AttributeDataType": "String",
            "DeveloperOnlyAttribute": false,
            "Mutable": false,
            "Required": true,
            "StringAttributeConstraints": {
              "MinLength": "0",
              "MaxLength": "2048"
            }
          }
        ]
      },
      "effects": [
        "encrypted"
      ]
    },
    {
      "id": "CognitoUserPoolClient",
      "kind": "AWS::Cognito::UserPoolClient",
      "fields": {
        "ClientName": "SecureAppClient",
        "UserPoolId": "CognitoUserPool",
        "ExplicitAuthFlows": [
          "ALLOW_USER_PASSWORD_AUTH",
          "ALLOW_REFRESH_TOKEN_AUTH"
        ],
        "AllowedOAuthFlows": [
          "code",
          "implicit"
        ],
        "AllowedOAuthScopes": [
          "phone",
          "email",
          "openid",
          "profile",
          "aws.cognito.signin.user.admin"
        ],
        "CallbackURLs": [
          "https://your-application.com/callback"
        ],
        "LogoutURLs": [
          "https://your-application.com/logout"
        ],
        "SupportedIdentityProviders": [
          "COGNITO"
        ],
        "AllowedOAuthFlowsUserPoolClient": true
      },
      "effects": [
        "public-read"
      ]
    },
    {
      "id": "CognitoUserPoolDomain",
      "kind": "AWS::Cognito::UserPoolDomain",
      "fields": {
        "Domain": "secure-auth-domain",
        "UserPoolId": "CognitoUserPool"
      },
      "effects": [
        "public-read"
      ]
    }
  ],
  "edges": [
    {
      "type": "depends",
      "from": "CognitoUserPoolClient",
      "to": "CognitoUserPool"
    },
    {
      "type": "depends",
      "from": "CognitoUserPoolDomain",
      "to": "CognitoUserPool"
    }
  ],
  "invariants": [
    "User pool must enforce strong password policies",
    "Email verification is mandatory for all users",
    "Only administrators can create users",
    "OAuth flows must be securely configured",
    "Hosted UI domain must be preconfigured"
  ]
}