{
  "resources": [
    {
      "id": "IAMReadOnlyRole",
      "kind": "AWS::IAM::Role",
      "fields": {
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "ec2.amazonaws.com"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "Path": "/"
      },
      "effects": [
        "iam-role"
      ]
    },
    {
      "id": "IAMReadOnlyPolicy",
      "kind": "AWS::IAM::Policy",
      "fields": {
        "PolicyName": "IAMReadOnlyAccess",
        "PolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Action": [
                "iam:List*",
                "iam:Get*"
              ],
              "Resource": "*"
            }
          ]
        },
        "Roles": [
          {
            "Ref": "IAMReadOnlyRole"
          }
        ]
      },
      "effects": [
        "iam-policy",
        "read-only"
      ]
    },
    {
      "id": "IAMInstanceProfile",
      "kind": "AWS::IAM::InstanceProfile",
      "fields": {
        "Path": "/",
        "Roles": [
          {
            "Ref": "IAMReadOnlyRole"
          }
        ]
      },
      "effects": [
        "iam-instance-profile"
      ]
    }
  ],
  "edges": [
    {
      "type": "depends",
      "from": "IAMReadOnlyPolicy",
      "to": "IAMReadOnlyRole"
    },
    {
      "type": "depends",
      "from": "IAMInstanceProfile",
      "to": "IAMReadOnlyRole"
    }
  ],
  "invariants": [
    "EC2 instances can only read IAM metadata, no modification rights",
    "Role assumes EC2 service principal",
    "Instance profile wraps the IAM role for EC2 attachment"
  ]
}