{
  "Resources": {
    "taskdef": {
      "Properties": {
        "ContainerDefinitions": [
          {
            "Command": [
              "/bin/sh"
            ],
            "EntryPoint": [
              "/kilt/run",
              "--"
            ],
            "Image": {
              "Fn::Join": [
                "",
                [
                  "quak.io/gimme/",
                  {
                    "Fn::GetAtt": [
                      "fried",
                      "chicken"
                    ]
                  }
                ]
              ]
            },
            "Name": "app",
