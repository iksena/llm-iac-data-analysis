{
  "resources": [
    {
      "id": "EFSFileSystem",
      "kind": "AWS::EFS::FileSystem",
      "fields": {
        "Encrypted": true,
        "PerformanceMode": "generalPurpose",
        "ThroughputMode": "bursting",
        "Tags": [
          {
            "Key": "Name",
            "Value": "SharedEFS"
          }
        ]
      },
      "effects": [
        "encrypted",
        "shared-storage"
      ]
    },
    {
      "id": "MountTargetAZ1",
      "kind": "AWS::EFS::MountTarget",
      "fields": {
        "FileSystemId": "EFSFileSystem",
        "SubnetId": "PublicSubnetAZ1",
        "SecurityGroups": [
          "EFSSecurityGroup"
        ]
      },
      "effects": [
        "cross-az"
      ]
    },
    {
      "id": "MountTargetAZ2",
      "kind": "AWS::EFS::MountTarget",
      "fields": {
        "FileSystemId": "EFSFileSystem",
        "SubnetId": "PublicSubnetAZ2",
        "SecurityGroups": [
          "EFSSecurityGroup"
        ]
      },
      "effects": [
        "cross-az"
      ]
    },
    {
      "id": "EFSSecurityGroup",
      "kind": "AWS::EC2::SecurityGroup",
      "fields": {
        "GroupDescription": "Allow EFS access",
        "VpcId": "VPC",
        "SecurityGroupIngress": [
          {
            "IpProtocol": "tcp",
            "FromPort": 2049,
            "ToPort": 2049,
            "SourceSecurityGroupId": "EC2SecurityGroup"
          }
        ]
      },
      "effects": [
        "network-access"
      ]
    },
    {
      "id": "EC2InstanceAZ1",
      "kind": "AWS::EC2::Instance",
      "fields": {
        "ImageId": "ami-0123456789abcdef0",
        "InstanceType": "t3.medium",
        "IamInstanceProfile": "EC2InstanceProfile",
        "SubnetId": "PublicSubnetAZ1",
        "SecurityGroupIds": [
          "EC2SecurityGroup"
        ],
        "UserData": "base64-encoded-mount-script"
      },
      "effects": [
        "cross-az",
        "ssm-enabled"
      ]
    },
    {
      "id": "EC2InstanceAZ2",
      "kind": "AWS::EC2::Instance",
      "fields": {
        "ImageId": "ami-0123456789abcdef0",
        "InstanceType": "t3.medium",
        "IamInstanceProfile": "EC2InstanceProfile",
        "SubnetId": "PublicSubnetAZ2",
        "SecurityGroupIds": [
          "EC2SecurityGroup"
        ],
        "UserData": "base64-encoded-mount-script"
      },
      "effects": [
        "cross-az",
        "ssm-enabled"
      ]
    },
    {
      "id": "EC2InstanceProfile",
      "kind": "AWS::IAM::InstanceProfile",
      "fields": {
        "Roles": [
          "EC2InstanceRole"
        ]
      },
      "effects": [
        "ssm-enabled"
      ]
    },
    {
      "id": "EC2InstanceRole",
      "kind": "AWS::IAM::Role",
      "fields": {
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "ec2.amazonaws.com"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "ManagedPolicyArns": [
          "arn:aws:iam::aws:policy/AmazonSSMManagedInstanceCore",
          "arn:aws:iam::aws:policy/AmazonElasticFileSystemClientReadWriteAccess"
        ]
      },
      "effects": [
        "ssm-enabled",
        "efs-access"
      ]
    },
    {
      "id": "EC2SecurityGroup",
      "kind": "AWS::EC2::SecurityGroup",
      "fields": {
        "GroupDescription": "Allow SSH and HTTP access",
        "VpcId": "VPC",
        "SecurityGroupIngress": [
          {
            "IpProtocol": "tcp",
            "FromPort": 22,
            "ToPort": 22,
            "CidrIp": "0.0.0.0/0"
          }
        ]
      },
      "effects": [
        "network-access"
      ]
    },
    {
      "id": "EFSAlarm1",
      "kind": "AWS::CloudWatch::Alarm",
      "fields": {
        "AlarmName": "EFS-Storage-Consumed",
        "Namespace": "AWS/EFS",
        "MetricName": "StorageBytes",
        "Statistic": "Average",
        "Period": 300,
        "EvaluationPeriods": 1,
        "Threshold": 1073741824,
        "ComparisonOperator": "GreaterThanThreshold",
        "AlarmActions": [
          "SNSAlarmTopic"
        ]
      },
      "effects": [
        "monitoring"
      ]
    },
    {
      "id": "EFSAlarm2",
      "kind": "AWS::CloudWatch::Alarm",
      "fields": {
        "AlarmName": "EFS-PercentIOLimit",
        "Namespace": "AWS/EFS",
        "MetricName": "PercentIOLimit",
        "Statistic": "Average",
        "Period": 300,
        "EvaluationPeriods": 1,
        "Threshold": 80,
        "ComparisonOperator": "GreaterThanThreshold",
        "AlarmActions": [
          "SNSAlarmTopic"
        ]
      },
      "effects": [
        "monitoring"
      ]
    },
    {
      "id": "SNSAlarmTopic",
      "kind": "AWS::SNS::Topic",
      "fields": {
        "DisplayName": "EFS-Alarms"
      },
      "effects": [
        "monitoring"
      ]
    }
  ],
  "edges": [
    {
      "type": "depends",
      "from": "MountTargetAZ1",
      "to": "EFSFileSystem"
    },
    {
      "type": "depends",
      "from": "MountTargetAZ2",
      "to": "EFSFileSystem"
    },
    {
      "type": "depends",
      "from": "MountTargetAZ1",
      "to": "PublicSubnetAZ1"
    },
    {
      "type": "depends",
      "from": "MountTargetAZ2",
      "to": "PublicSubnetAZ2"
    },
    {
      "type": "depends",
      "from": "EFSSecurityGroup",
      "to": "VPC"
    },
    {
      "type": "depends",
      "from": "EC2InstanceAZ1",
      "to": "PublicSubnetAZ1"
    },
    {
      "type": "depends",
      "from": "EC2InstanceAZ2",
      "to": "PublicSubnetAZ2"
    },
    {
      "type": "depends",
      "from": "EC2InstanceAZ1",
      "to": "EC2SecurityGroup"
    },
    {
      "type": "depends",
      "from": "EC2InstanceAZ2",
      "to": "EC2SecurityGroup"
    },
    {
      "type": "depends",
      "from": "EC2InstanceAZ1",
      "to": "EC2InstanceProfile"
    },
    {
      "type": "depends",
      "from": "EC2InstanceAZ2",
      "to": "EC2InstanceProfile"
    },
    {
      "type": "depends",
      "from": "EC2InstanceProfile",
      "to": "EC2InstanceRole"
    },
    {
      "type": "depends",
      "from": "EFSAlarm1",
      "to": "SNSAlarmTopic"
    },
    {
      "type": "depends",
      "from": "EFSAlarm2",
      "to": "SNSAlarmTopic"
    }
  ],
  "invariants": [
    "EFS file system must be encrypted at rest",
    "EFS mount targets must be deployed in two public subnets across different AZs",
    "EC2 instances must have IAM roles with EFS and SSM permissions",
    "CloudWatch alarms must monitor EFS performance metrics for capacity and performance issues",
    "EC2 instances must automatically mount EFS to /home during bootstrapping"
  ]
}