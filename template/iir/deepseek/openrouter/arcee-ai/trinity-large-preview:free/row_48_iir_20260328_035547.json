{
  "resources": [
    {
      "id": "GlueScriptBucket",
      "kind": "AWS::S3::Bucket",
      "fields": {},
      "effects": [
        "encrypted"
      ]
    },
    {
      "id": "GlueRole",
      "kind": "AWS::IAM::Role",
      "fields": {
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "glue.amazonaws.com"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "ManagedPolicyArns": [
          "arn:aws:iam::aws:policy/service-role/AWSGlueServiceRole"
        ]
      },
      "effects": []
    },
    {
      "id": "GluePolicy",
      "kind": "AWS::IAM::Policy",
      "fields": {
        "PolicyName": "GlueS3AccessPolicy",
        "PolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Action": [
                "s3:GetObject",
                "s3:PutObject",
                "s3:ListBucket"
              ],
              "Resource": [
                {
                  "Fn::Join": [
                    "",
                    [
                      "arn:aws:s3:::",
                      {
                        "Ref": "GlueScriptBucket"
                      },
                      "/*"
                    ]
                  ]
                },
                {
                  "Fn::Join": [
                    "",
                    [
                      "arn:aws:s3:::",
                      {
                        "Ref": "GlueScriptBucket"
                      }
                    ]
                  ]
                }
              ]
            }
          ]
        },
        "Roles": [
          {
            "Ref": "GlueRole"
          }
        ]
      },
      "effects": []
    },
    {
      "id": "GlueJob",
      "kind": "AWS::Glue::Job",
      "fields": {
        "Name": "SampleConvertJob",
        "Role": {
          "Ref": "GlueRole"
        },
        "Command": {
          "Name": "glueetl",
          "ScriptLocation": {
            "Fn::Join": [
              "",
              [
                "s3://",
                {
                  "Ref": "GlueScriptBucket"
                },
                "/gue_scripts/sample_convert.py"
              ]
            ]
          },
          "PythonVersion": "3"
        },
        "DefaultArguments": {
          "--job-language": "python"
        },
        "GlueVersion": "4.0"
      },
      "effects": []
    }
  ],
  "edges": [
    {
      "type": "depends",
      "from": "GlueRole",
      "to": "GluePolicy"
    },
    {
      "type": "depends",
      "from": "GlueRole",
      "to": "GlueJob"
    },
    {
      "type": "depends",
      "from": "GlueScriptBucket",
      "to": "GluePolicy"
    }
  ],
  "invariants": [
    "S3 bucket must be encrypted",
    "Glue job must use version 4.0",
    "Python script must be accessible from S3 bucket",
    "IAM role must have S3 access permissions"
  ]
}