{
  "resources": [
    {
      "id": "VPC",
      "kind": "AWS::EC2::VPC",
      "fields": {
        "CidrBlock": "10.0.0.0/16",
        "EnableDnsSupport": true,
        "EnableDnsHostnames": true
      },
      "effects": [
        "vpc"
      ]
    },
    {
      "id": "InternetGateway",
      "kind": "AWS::EC2::InternetGateway",
      "fields": {},
      "effects": [
        "internet-access"
      ]
    },
    {
      "id": "VPCGatewayAttachment",
      "kind": "AWS::EC2::VPCGatewayAttachment",
      "fields": {
        "VpcId": "VPC",
        "InternetGatewayId": "InternetGateway"
      },
      "effects": [
        "internet-access"
      ]
    },
    {
      "id": "PublicSubnet1",
      "kind": "AWS::EC2::Subnet",
      "fields": {
        "VpcId": "VPC",
        "CidrBlock": "10.0.1.0/24",
        "AvailabilityZone": "us-east-1a"
      },
      "effects": [
        "public-subnet"
      ]
    },
    {
      "id": "PublicSubnet2",
      "kind": "AWS::EC2::Subnet",
      "fields": {
        "VpcId": "VPC",
        "CidrBlock": "10.0.2.0/24",
        "AvailabilityZone": "us-east-1b"
      },
      "effects": [
        "public-subnet"
      ]
    },
    {
      "id": "PublicRouteTable",
      "kind": "AWS::EC2::RouteTable",
      "fields": {
        "VpcId": "VPC"
      },
      "effects": [
        "public-routing"
      ]
    },
    {
      "id": "PublicRoute",
      "kind": "AWS::EC2::Route",
      "fields": {
        "RouteTableId": "PublicRouteTable",
        "DestinationCidrBlock": "0.0.0.0/0",
        "GatewayId": "InternetGateway"
      },
      "effects": [
        "public-routing"
      ]
    },
    {
      "id": "SubnetRouteTableAssociation1",
      "kind": "AWS::EC2::SubnetRouteTableAssociation",
      "fields": {
        "SubnetId": "PublicSubnet1",
        "RouteTableId": "PublicRouteTable"
      },
      "effects": [
        "public-routing"
      ]
    },
    {
      "id": "SubnetRouteTableAssociation2",
      "kind": "AWS::EC2::SubnetRouteTableAssociation",
      "fields": {
        "SubnetId": "PublicSubnet2",
        "RouteTableId": "PublicRouteTable"
      },
      "effects": [
        "public-routing"
      ]
    },
    {
      "id": "SSMSecurityGroup",
      "kind": "AWS::EC2::SecurityGroup",
      "fields": {
        "GroupDescription": "Security group for SSM managed instances",
        "VpcId": "VPC",
        "SecurityGroupIngress": [
          {
            "IpProtocol": "tcp",
            "FromPort": 80,
            "ToPort": 80,
            "CidrIp": "0.0.0.0/0"
          }
        ]
      },
      "effects": [
        "http-access",
        "ssm-allowed"
      ]
    },
    {
      "id": "SSMRole",
      "kind": "AWS::IAM::Role",
      "fields": {
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "ec2.amazonaws.com"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "ManagedPolicyArns": [
          "arn:aws:iam::aws:policy/AmazonEC2RoleforSSM"
        ]
      },
      "effects": [
        "ssm-permissions"
      ]
    },
    {
      "id": "SSMInstanceProfile",
      "kind": "AWS::IAM::InstanceProfile",
      "fields": {
        "Roles": [
          "SSMRole"
        ]
      },
      "effects": [
        "ssm-permissions"
      ]
    },
    {
      "id": "LinuxLaunchTemplate",
      "kind": "AWS::EC2::LaunchTemplate",
      "fields": {
        "LaunchTemplateName": "LinuxSSMInstance",
        "LaunchTemplateData": {
          "ImageId": {
            "Fn::ImportValue": "LinuxLatestAMI"
          },
          "InstanceType": "t3.micro",
          "IamInstanceProfile": {
            "Name": "SSMInstanceProfile"
          },
          "SecurityGroupIds": [
            {
              "Ref": "SSMSecurityGroup"
            }
          ],
          "UserData": {
            "Fn::Base64": {
              "Fn::Join": [
                "",
                [
                  "#!/bin/bash\n",
                  "sudo yum update -y\n",
                  "sudo yum install -y https://s3.amazonaws.com/ec2-downloads-windows/SSMAgent/latest/linux_amd64/amazon-ssm-agent.rpm\n",
                  "sudo systemctl enable amazon-ssm-agent\n",
                  "sudo systemctl start amazon-ssm-agent\n"
                ]
              ]
            }
          }
        }
      },
      "effects": [
        "linux-instance",
        "ssm-agent-installed"
      ]
    },
    {
      "id": "WindowsLaunchTemplate",
      "kind": "AWS::EC2::LaunchTemplate",
      "fields": {
        "LaunchTemplateName": "WindowsSSMInstance",
        "LaunchTemplateData": {
          "ImageId": {
            "Fn::ImportValue": "WindowsLatestAMI"
          },
          "InstanceType": "t3.micro",
          "IamInstanceProfile": {
            "Name": "SSMInstanceProfile"
          },
          "SecurityGroupIds": [
            {
              "Ref": "SSMSecurityGroup"
            }
          ]
        }
      },
      "effects": [
        "windows-instance",
        "ssm-preconfigured"
      ]
    },
    {
      "id": "LinuxAutoScalingGroup",
      "kind": "AWS::AutoScaling::AutoScalingGroup",
      "fields": {
        "VPCZoneIdentifier": [
          "PublicSubnet1",
          "PublicSubnet2"
        ],
        "LaunchTemplate": {
          "LaunchTemplateId": "LinuxLaunchTemplate",
          "Version": {
            "Fn::GetAtt": [
              "LinuxLaunchTemplate",
              "LatestVersionNumber"
            ]
          }
        },
        "MinSize": "1",
        "MaxSize": "3",
        "DesiredCapacity": "2"
      },
      "effects": [
        "auto-scaling",
        "linux-managed"
      ]
    },
    {
      "id": "WindowsAutoScalingGroup",
      "kind": "AWS::AutoScaling::AutoScalingGroup",
      "fields": {
        "VPCZoneIdentifier": [
          "PublicSubnet1",
          "PublicSubnet2"
        ],
        "LaunchTemplate": {
          "LaunchTemplateId": "WindowsLaunchTemplate",
          "Version": {
            "Fn::GetAtt": [
              "WindowsLaunchTemplate",
              "LatestVersionNumber"
            ]
          }
        },
        "MinSize": "1",
        "MaxSize": "3",
        "DesiredCapacity": "2"
      },
      "effects": [
        "auto-scaling",
        "windows-managed"
      ]
    }
  ],
  "edges": [
