{
  "resources": [
    {
      "id": "SSMParameterStore",
      "kind": "AWS::SSM::Parameter",
      "fields": {
        "Name": "/my-stack/config/ab-test",
        "Type": "String",
        "Value": "This is A/B"
      },
      "effects": [
        "encrypted"
      ]
    },
    {
      "id": "SecretsManagerSecret",
      "kind": "AWS::SecretsManager::Secret",
      "fields": {
        "Name": "my-stack-secret",
        "Description": "Stack-specific secret with predefined username",
        "SecretString": "{\"username\": \"admin\", \"password\": \"<PASSWORD>\"}",
        "GenerateSecretString": {
          "ExcludeCharacters": "\"@/\\",
          "GenerateStringKey": "password",
          "PasswordLength": 30,
          "IncludeSpace": false
        }
      },
      "effects": [
        "encrypted",
        "versioned"
      ]
    },
    {
      "id": "LambdaFunction",
      "kind": "AWS::Lambda::Function",
      "fields": {
        "Handler": "index.handler",
        "Runtime": "python3.9",
        "Code": {
          "ZipFile": "import boto3\nimport json\nimport os\n\ndef handler(event, context):\n    ssm_client = boto3.client('ssm')\n    secrets_client = boto3.client('secretsmanager')\n    \n    # Fetch SSM parameter\n    ssm_param = ssm_client.get_parameter(Name='/my-stack/config/ab-test', WithDecryption=True)\n    \n    # Fetch Secrets Manager secret\n    secret = secrets_client.get_secret_value(SecretId='my-stack-secret')\n    secret_value = json.loads(secret['SecretString'])\n    \n    return {\n        'statusCode': 200,\n        'body': json.dumps({\n            'ssm_value': ssm_param['Parameter']['Value'],\n            'secret': secret_value\n        })\n    }"
        },
        "Timeout": 30,
        "MemorySize": 128,
        "Environment": {
          "Variables": {
            "SSM_PARAMETER_NAME": "/my-stack/config/ab-test",
            "SECRET_NAME": "my-stack-secret"
          }
        }
      },
      "effects": [
        "public-read"
      ]
    },
    {
      "id": "LambdaIAMRole",
      "kind": "AWS::IAM::Role",
      "fields": {
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "lambda.amazonaws.com"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "ManagedPolicyArns": [
          "arn:aws:iam::aws:policy/service-role/AWSLambdaBasicExecutionRole"
        ]
      },
      "effects": [
        "least-privilege"
      ]
    },
    {
      "id": "LambdaSSMParameterPolicy",
      "kind": "AWS::IAM::Policy",
      "fields": {
        "PolicyName": "LambdaSSMParameterAccess",
        "PolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Action": [
                "ssm:GetParameter",
                "ssm:GetParametersByPath"
              ],
              "Resource": {
                "Fn::Sub": "arn:aws:ssm:${AWS::Region}:${AWS::AccountId}:parameter/my-stack/*"
              }
            }
          ]
        },
        "Roles": [
          {
            "Ref": "LambdaIAMRole"
          }
        ]
      },
      "effects": [
        "least-privilege"
      ]
    },
    {
      "id": "LambdaSecretsManagerPolicy",
      "kind": "AWS::IAM::Policy",
      "fields": {
        "PolicyName": "LambdaSecretsManagerAccess",
        "PolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Action": [
                "secretsmanager:GetSecretValue",
                "secretsmanager:DescribeSecret"
              ],
              "Resource": {
                "Fn::Sub": "arn:aws:secretsmanager:${AWS::Region}:${AWS::AccountId}:secret:my-stack-secret-*"
              }
            }
          ]
        },
        "Roles": [
          {
            "Ref": "LambdaIAMRole"
          }
        ]
      },
      "effects": [
        "least-privilege"
      ]
    }
  ],
  "edges": [
    {
      "type": "depends",
      "from": "LambdaFunction",
      "to": "LambdaIAMRole"
    },
    {
      "type": "depends",
      "from": "LambdaSSMParameterPolicy",
      "to": "LambdaIAMRole"
    },
    {
      "type": "depends",
      "from": "LambdaSecretsManagerPolicy",
      "to": "LambdaIAMRole"
    }
  ],
  "invariants": [
    "SSM parameters stored under stack-specific namespace",
    "Secrets Manager enforces excluded characters for password generation",
    "Lambda function has least-privilege IAM permissions",
    "Path-based SSM parameter retrieval demonstrated",
    "Secrets Manager secret decryption workflow implemented",
    "Centralized configuration management for serverless applications"
  ]
}