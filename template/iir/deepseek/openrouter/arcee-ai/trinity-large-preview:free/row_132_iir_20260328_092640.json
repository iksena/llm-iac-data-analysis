{
  "resources": [
    {
      "id": "VPC",
      "kind": "AWS::EC2::VPC",
      "fields": {
        "CidrBlock": "10.0.0.0/16",
        "EnableDnsSupport": true,
        "EnableDnsHostnames": true
      },
      "effects": [
        "vpc"
      ]
    },
    {
      "id": "PublicSubnet",
      "kind": "AWS::EC2::Subnet",
      "fields": {
        "VpcId": "VPC",
        "CidrBlock": "10.0.1.0/24",
        "AvailabilityZone": "us-east-1a"
      },
      "effects": [
        "public-subnet"
      ]
    },
    {
      "id": "InternetGateway",
      "kind": "AWS::EC2::InternetGateway",
      "fields": {},
      "effects": [
        "internet-gateway"
      ]
    },
    {
      "id": "VPCGatewayAttachment",
      "kind": "AWS::EC2::VPCGatewayAttachment",
      "fields": {
        "VpcId": "VPC",
        "InternetGatewayId": "InternetGateway"
      },
      "effects": [
        "vpc-gateway-attachment"
      ]
    },
    {
      "id": "RouteTable",
      "kind": "AWS::EC2::RouteTable",
      "fields": {
        "VpcId": "VPC"
      },
      "effects": [
        "route-table"
      ]
    },
    {
      "id": "Route",
      "kind": "AWS::EC2::Route",
      "fields": {
        "RouteTableId": "RouteTable",
        "DestinationCidrBlock": "0.0.0.0/0",
        "GatewayId": "InternetGateway"
      },
      "effects": [
        "public-route"
      ]
    },
    {
      "id": "SubnetRouteTableAssociation",
      "kind": "AWS::EC2::SubnetRouteTableAssociation",
      "fields": {
        "SubnetId": "PublicSubnet",
        "RouteTableId": "RouteTable"
      },
      "effects": [
        "subnet-route-association"
      ]
    },
    {
      "id": "S3Bucket",
      "kind": "AWS::S3::Bucket",
      "fields": {},
      "effects": [
        "s3-bucket"
      ]
    },
    {
      "id": "ComputeEnvironment",
      "kind": "AWS::Batch::ComputeEnvironment",
      "fields": {
        "Type": "MANAGED",
        "ComputeResources": {
          "Type": "EC2",
          "MinvCpus": 0,
          "MaxvCpus": 16,
          "DesiredvCpus": 4,
          "InstanceTypes": [
            "m5.large"
          ],
          "Subnets": [
            "PublicSubnet"
          ],
          "SecurityGroupIds": [
            "SecurityGroup"
          ]
        },
        "ServiceRole": "BatchServiceRole"
      },
      "effects": [
        "batch-compute"
      ]
    },
    {
      "id": "JobQueue",
      "kind": "AWS::Batch::JobQueue",
      "fields": {
        "ComputeEnvironmentOrder": [
          {
            "Order": 1,
            "ComputeEnvironment": "ComputeEnvironment"
          }
        ],
        "Priority": 1
      },
      "effects": [
        "batch-queue"
      ]
    },
    {
      "id": "JobDefinition",
      "kind": "AWS::Batch::JobDefinition",
      "fields": {
        "Type": "container",
        "ContainerProperties": {
          "Image": "amazonlinux",
          "Command": [
            "sh",
            "-c",
            "yum install -y awscli && aws s3 cp s3://S3Bucket/input.txt /tmp/input.txt && aws s3 cp /tmp/input.txt s3://S3Bucket/output.txt"
          ],
          "Memory": 2048,
          "Vcpus": 1
        }
      },
      "effects": [
        "batch-job"
      ]
    },
    {
      "id": "SecurityGroup",
      "kind": "AWS::EC2::SecurityGroup",
      "fields": {
        "GroupDescription": "Batch Security Group",
        "VpcId": "VPC"
      },
      "effects": [
        "security-group"
      ]
    },
    {
      "id": "SecurityGroupIngress",
      "kind": "AWS::EC2::SecurityGroupIngress",
      "fields": {
        "GroupId": "SecurityGroup",
        "IpProtocol": "tcp",
        "FromPort": 0,
        "ToPort": 65535,
        "CidrIp": "0.0.0.0/0"
      },
      "effects": [
        "security-group-ingress"
      ]
    },
    {
      "id": "BatchServiceRole",
      "kind": "AWS::IAM::Role",
      "fields": {
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "batch.amazonaws.com"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "ManagedPolicyArns": [
          "arn:aws:iam::aws:policy/service-role/AWSBatchServiceRole"
        ]
      },
      "effects": [
        "iam-role"
      ]
    },
    {
      "id": "EC2InstanceProfile",
      "kind": "AWS::IAM::InstanceProfile",
      "fields": {
        "Roles": [
          "EC2Role"
        ]
      },
      "effects": [
        "iam-instance-profile"
      ]
    },
    {
      "id": "EC2Role",
      "kind": "AWS::IAM::Role",
      "fields": {
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "ec2.amazonaws.com"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "ManagedPolicyArns": [
          "arn:aws:iam::aws:policy/AmazonS3FullAccess"
        ]
      },
      "effects": [
        "iam-role"
      ]
    }
  ],
  "edges": [
    {
      "type": "depends",
      "from": "PublicSubnet",
      "to": "VPC"
    },
    {
      "type": "depends",
      "from": "VPCGatewayAttachment",
      "to": "VPC"
    },
    {
      "type": "depends",
      "from": "VPCGatewayAttachment",
      "to": "InternetGateway"
    },
    {
      "type": "depends",
      "from": "RouteTable",
      "to": "VPC"
    },
    {
      "type": "depends",
      "from": "Route",
      "to": "RouteTable"
    },
    {
      "type": "depends",
      "from": "Route",
      "to": "InternetGateway"
    },
    {
      "type": "depends",
      "from": "SubnetRouteTableAssociation",
      "to": "PublicSubnet"
    },
    {
      "type": "depends",
      "from": "SubnetRouteTableAssociation",
      "to": "RouteTable"
    },
    {
      "type": "depends",
      "from": "ComputeEnvironment",
      "to": "PublicSubnet"
    },
    {
      "type": "depends",
      "from": "ComputeEnvironment",
      "to": "SecurityGroup"
    },
    {
      "type": "depends",
      "from": "ComputeEnvironment",
      "to": "BatchServiceRole"
    },
    {
      "type": "depends",
      "from": "JobQueue",
      "to": "ComputeEnvironment"
    },
    {
      "type": "depends",
      "from": "JobDefinition",
      "to": "S3Bucket"
    },
    {
      "type": "depends",
      "from": "SecurityGroupIngress",
      "to": "SecurityGroup"
    },
    {
      "type": "depends",
      "from": "EC2InstanceProfile",
      "to": "EC2Role"
    },
    {
      "type": "depends",
      "from": "ComputeEnvironment",
      "to": "EC2InstanceProfile"
    }
  ],
  "invariants": [
    "VPC must have public internet access",
    "Batch compute environment requires IAM roles for service and EC2 instances",
    "S3 bucket must be accessible from Batch jobs",
    "Security group must allow outbound internet access for package installation"
  ]
}