{
  "resources": [
    {
      "id": "VPC",
      "kind": "AWS::EC2::VPC",
      "fields": {
        "CidrBlock": "10.0.0.0/16",
        "EnableDnsSupport": true,
        "EnableDnsHostnames": true
      },
      "effects": [
        "vpc"
      ]
    },
    {
      "id": "InternetGateway",
      "kind": "AWS::EC2::InternetGateway",
      "fields": {},
      "effects": [
        "internet-access"
      ]
    },
    {
      "id": "VPCGatewayAttachment",
      "kind": "AWS::EC2::VPCGatewayAttachment",
      "fields": {
        "VpcId": "VPC",
        "InternetGatewayId": "InternetGateway"
      },
      "effects": []
    },
    {
      "id": "PublicRouteTable",
      "kind": "AWS::EC2::RouteTable",
      "fields": {
        "VpcId": "VPC"
      },
      "effects": [
        "public-routing"
      ]
    },
    {
      "id": "PublicRoute",
      "kind": "AWS::EC2::Route",
      "fields": {
        "RouteTableId": "PublicRouteTable",
        "DestinationCidrBlock": "0.0.0.0/0",
        "GatewayId": "InternetGateway"
      },
      "effects": [
        "internet-route"
      ]
    },
    {
      "id": "PublicSubnet1",
      "kind": "AWS::EC2::Subnet",
      "fields": {
        "VpcId": "VPC",
        "CidrBlock": "10.0.1.0/24",
        "AvailabilityZone": "us-east-1a",
        "MapPublicIpOnLaunch": true
      },
      "effects": [
        "public-subnet",
        "az-1a"
      ]
    },
    {
      "id": "PublicSubnet2",
      "kind": "AWS::EC2::Subnet",
      "fields": {
        "VpcId": "VPC",
        "CidrBlock": "10.0.2.0/24",
        "AvailabilityZone": "us-east-1b",
        "MapPublicIpOnLaunch": true
      },
      "effects": [
        "public-subnet",
        "az-1b"
      ]
    },
    {
      "id": "SubnetRouteTableAssociation1",
      "kind": "AWS::EC2::SubnetRouteTableAssociation",
      "fields": {
        "SubnetId": "PublicSubnet1",
        "RouteTableId": "PublicRouteTable"
      },
      "effects": []
    },
    {
      "id": "SubnetRouteTableAssociation2",
      "kind": "AWS::EC2::SubnetRouteTableAssociation",
      "fields": {
        "SubnetId": "PublicSubnet2",
        "RouteTableId": "PublicRouteTable"
      },
      "effects": []
    },
    {
      "id": "RDSSecurityGroup",
      "kind": "AWS::EC2::SecurityGroup",
      "fields": {
        "GroupDescription": "RDS security group",
        "VpcId": "VPC",
        "SecurityGroupIngress": [
          {
            "IpProtocol": "tcp",
            "FromPort": 3306,
            "ToPort": 3306,
            "CidrIp": "0.0.0.0/0"
          }
        ],
        "SecurityGroupEgress": [
          {
            "IpProtocol": "tcp",
            "FromPort": 0,
            "ToPort": 65535,
            "CidrIp": "0.0.0.0/0"
          }
        ]
      },
      "effects": [
        "rds-access"
      ]
    },
    {
      "id": "RDSSubnetGroup",
      "kind": "AWS::RDS::DBSubnetGroup",
      "fields": {
        "DBSubnetGroupDescription": "RDS subnet group",
        "SubnetIds": [
          "PublicSubnet1",
          "PublicSubnet2"
        ]
      },
      "effects": [
        "rds-subnet-group"
      ]
    },
    {
      "id": "RDSInstance",
      "kind": "AWS::RDS::DBInstance",
      "fields": {
        "AllocatedStorage": "20",
        "DBInstanceClass": "db.t3.micro",
        "Engine": "mysql",
        "MasterUsername": "admin",
        "MasterUserPassword": "password123",
        "VpcSecurityGroupIds": [
          "RDSSecurityGroup"
        ],
        "DBSubnetGroupName": "RDSSubnetGroup",
        "BackupRetentionPeriod": "7",
        "MultiAZ": false,
        "StorageEncrypted": true
      },
      "effects": [
        "mysql-db",
        "encrypted",
        "automated-snapshots"
      ]
    }
  ],
