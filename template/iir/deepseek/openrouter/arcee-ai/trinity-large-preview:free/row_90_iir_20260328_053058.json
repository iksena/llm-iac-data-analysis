{
  "resources": [
    {
      "id": "ImageBuilderIAMRole",
      "kind": "AWS::IAM::Role",
      "fields": {
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "ec2.amazonaws.com"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "ManagedPolicyArns": [
          "arn:aws:iam::aws:policy/AmazonSSMManagedInstanceCore",
          "arn:aws:iam::aws:policy/AWSImageBuilderFullAccess"
        ]
      },
      "effects": [
        "encrypted"
      ]
    },
    {
      "id": "ImageBuilderInstanceProfile",
      "kind": "AWS::IAM::InstanceProfile",
      "fields": {
        "Roles": [
          {
            "Ref": "ImageBuilderIAMRole"
          }
        ]
      },
      "effects": [
        "encrypted"
      ]
    },
    {
      "id": "LogsBucket",
      "kind": "AWS::S3::Bucket",
      "fields": {
        "BucketName": "image-builder-logs-bucket",
        "PublicAccessBlockConfiguration": {
          "BlockPublicAcls": true,
          "BlockPublicPolicy": true,
          "IgnorePublicAcls": true,
          "RestrictPublicBuckets": true
        },
        "Tags": [
          {
            "Key": "Owner",
            "Value": "u12345678@anu.edu.au"
          }
        ]
      },
      "effects": [
        "public-access-disabled",
        "encrypted",
        "versioned"
      ]
    },
    {
      "id": "LogsBucketPolicy",
      "kind": "AWS::S3::BucketPolicy",
      "fields": {
        "Bucket": {
          "Ref": "LogsBucket"
        },
        "PolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "AWS": {
                  "Fn::GetAtt": [
                    "ImageBuilderIAMRole",
                    "Arn"
                  ]
                }
              },
              "Action": [
                "s3:PutObject",
                "s3:GetObject",
                "s3:ListBucket"
              ],
              "Resource": [
                {
                  "Fn::GetAtt": [
                    "LogsBucket",
                    "Arn"
                  ]
                },
                {
                  "Fn::Join": [
                    "",
                    [
                      {
                        "Fn::GetAtt": [
                          "LogsBucket",
                          "Arn"
                        ]
                      },
                      "/*"
                    ]
                  ]
                }
              ]
            }
          ]
        }
      },
      "effects": [
        "encrypted"
      ]
    }
  ],
  "edges": [
    {
      "type": "depends",
      "from": "ImageBuilderInstanceProfile",
      "to": "ImageBuilderIAMRole"
    },
    {
      "type": "depends",
      "from": "LogsBucketPolicy",
      "to": "LogsBucket"
    },
    {
      "type": "depends",
      "from": "LogsBucketPolicy",
      "to": "ImageBuilderIAMRole"
    }
  ],
  "invariants": [
    "IAM role must have SSM and Image Builder permissions",
    "S3 bucket must have public access blocked and be encrypted",
    "IAM role must have read/write access to logs bucket",
    "Instance profile must reference the IAM role",
    "Logs bucket must be tagged with owner email for accountability"
  ]
}