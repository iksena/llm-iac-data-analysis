{
  "resources": [
    {
      "id": "DynamoDBTable",
      "kind": "AWS::DynamoDB::Table",
      "fields": {
        "TableName": "UserProfiles",
        "KeySchema": [
          {
            "AttributeName": "userId",
            "KeyType": "HASH"
          }
        ],
        "AttributeDefinitions": [
          {
            "AttributeName": "userId",
            "AttributeType": "S"
          }
        ],
        "BillingMode": "PAY_PER_REQUEST",
        "StreamSpecification": {
          "StreamEnabled": true,
          "StreamViewType": "NEW_AND_OLD_IMAGES"
        }
      },
      "effects": [
        "versioned"
      ]
    },
    {
      "id": "EventBridgePipe",
      "kind": "AWS::EventBridge::Pipe",
      "fields": {
        "Name": "DynamoDBToEventBridge",
        "Source": "AWS::DynamoDB",
        "Target": {
          "Arn": {
            "Ref": "EventBridgeBus"
          },
          "RoleArn": {
            "Fn::GetAtt": [
              "PipeRole",
              "Arn"
            ]
          }
        },
        "Enrichment": {
          "Type": "AWS::Lambda",
          "Parameters": {
            "FunctionArn": {
              "Ref": "EnrichmentFunction"
            },
            "InputTemplate": "{ \"source\": \"AWS::DynamoDB\", \"detail\": <input> }"
          }
        },
        "Filter": {
          "Pattern": {
            "detail": {
              "eventName": [
                "MODIFY"
              ],
              "dynamodb": {
                "NewImage": {
                  "avatarUrl": {
                    "endsWith": ".png"
                  }
                }
              }
            }
          }
        }
      },
      "effects": [
        "public-read"
      ]
    },
    {
      "id": "PipeRole",
      "kind": "AWS::IAM::Role",
      "fields": {
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "pipes.amazonaws.com"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "Policies": [
          {
            "PolicyName": "DynamoDBAccess",
            "PolicyDocument": {
              "Version": "2012-10-17",
              "Statement": [
                {
                  "Effect": "Allow",
                  "Action": "dynamodb:DescribeStream",
                  "Resource": {
                    "Fn::GetAtt": [
                      "DynamoDBTable",
                      "StreamArn"
                    ]
                  }
                }
              ]
            }
          },
          {
            "PolicyName": "EventBridgeAccess",
            "PolicyDocument": {
              "Version": "2012-10-17",
              "Statement": [
                {
                  "Effect": "Allow",
                  "Action": "events:PutEvents",
                  "Resource": {
                    "Ref": "EventBridgeBus"
                  }
                }
              ]
            }
          }
        ]
      },
      "effects": [
        "encrypted"
      ]
    },
    {
      "id": "EnrichmentFunction",
      "kind": "AWS::Lambda::Function",
      "fields": {
        "Handler": "index.handler",
        "Runtime": "nodejs18.x",
        "Code": {
          "ZipFile": "exports.handler = async (event) => { return { detailType: 'UserProfileUpdated', source: 'com.example.userprofile' }; };"
        },
        "Timeout": 30,
        "Role": {
          "Fn::GetAtt": [
            "LambdaRole",
            "Arn"
          ]
        }
      },
      "effects": [
        "encrypted"
      ]
    },
    {
      "id": "LambdaRole",
      "kind": "AWS::IAM::Role",
      "fields": {
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "lambda.amazonaws.com"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "Policies": [
          {
            "PolicyName": "EventBridgeEnrichment",
            "PolicyDocument": {
              "Version": "2012-10-17",
              "Statement": [
                {
                  "Effect": "Allow",
                  "Action": "events:PutEvents",
                  "Resource": "*"
                }
              ]
            }
          }
        ]
      },
      "effects": [
        "encrypted"
      ]
    },
    {
      "id": "EventBridgeBus",
      "kind": "AWS::Events::EventBus",
      "fields": {
        "Name": "UserEventBus"
      },
      "effects": [
        "public-read"
      ]
    }
  ],
  "edges": [
    {
      "type": "depends",
      "from": "EventBridgePipe",
      "to": "DynamoDBTable"
    },
    {
      "type": "depends",
      "from": "EventBridgePipe",
      "to": "PipeRole"
    },
    {
      "type": "depends",
      "from": "EventBridgePipe",
      "to": "EnrichmentFunction"
    },
    {
      "type": "depends",
      "from": "EventBridgePipe",
      "to": "EventBridgeBus"
    },
    {
      "type": "depends",
      "from": "EnrichmentFunction",
      "to": "LambdaRole"
    },
    {
      "type": "connects",
      "from": "EventBridgePipe",
      "to": "EventBridgeBus",
      "proto": "https",
      "port": 443
    }
  ],
  "invariants": [
    "DynamoDB stream must be enabled with NEW_AND_OLD_IMAGES view type",
    "EventBridge Pipe must filter for MODIFY events where avatarUrl ends with .png",
    "Enrichment Lambda must add DetailType and Source metadata to events",
    "IAM roles must have least-privilege access to DynamoDB streams and EventBridge"
  ]
}