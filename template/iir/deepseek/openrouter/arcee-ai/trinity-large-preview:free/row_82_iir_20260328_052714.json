{
  "resources": [
    {
      "id": "ALBAccessLogsBucket",
      "kind": "AWS::S3::Bucket",
      "fields": {
        "BucketEncryption": {
          "ServerSideEncryptionConfiguration": [
            {
              "ServerSideEncryptionByDefault": {
                "SSEAlgorithm": "AES256"
              }
            }
          ]
        },
        "BucketName": "alb-access-logs-bucket",
        "PublicAccessBlockConfiguration": {
          "BlockPublicAcls": true,
          "IgnorePublicAcls": true,
          "BlockPublicPolicy": true,
          "RestrictPublicBuckets": true
        },
        "OwnershipControls": {
          "Rules": [
            {
              "ObjectOwnership": "BucketOwnerEnforced"
            }
          ]
        },
        "LifecycleConfiguration": {
          "Rules": [
            {
              "Status": "Enabled",
              "ExpirationInDays": 90
            }
          ]
        }
      },
      "effects": [
        "encrypted",
        "private",
        "versioned",
        "retention-90"
      ]
    },
    {
      "id": "ALBAccessLogsBucketPolicy",
      "kind": "AWS::S3::BucketPolicy",
      "fields": {
        "Bucket": "ALBAccessLogsBucket",
        "PolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "AWS": [
                  "arn:aws:iam::552958791618:root",
                  "arn:aws:iam::602026542331:root",
                  "arn:aws:iam::617741335675:root",
                  "arn:aws:iam::800080808080:root",
                  "arn:aws:iam::858058791618:root",
                  "arn:aws:iam::896398065558:root",
                  "arn:aws:iam::975596993436:root"
                ]
              },
              "Action": [
                "s3:PutObject"
              ],
              "Resource": [
                "arn:aws:s3:::alb-access-logs-bucket/AWSLogs/123456789012/*"
              ]
            },
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "delivery.logs.amazonaws.com"
              },
              "Action": "s3:PutObject",
              "Resource": "arn:aws:s3:::alb-access-logs-bucket/AWSLogs/123456789012/*",
              "Condition": {
                "StringEquals": {
                  "s3:x-amz-acl": "bucket-owner-full-control"
                }
              }
            },
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "delivery.logs.amazonaws.com"
              },
              "Action": "s3:GetBucketAcl",
              "Resource": "arn:aws:s3:::alb-access-logs-bucket"
            }
          ]
        }
      },
      "effects": [
        "elb-access",
        "delivery-service"
      ]
    }
  ],
  "edges": [
    {
      "type": "depends",
      "from": "ALBAccessLogsBucketPolicy",
      "to": "ALBAccessLogsBucket"
    }
  ],
  "invariants": [
    "Bucket must be encrypted with AES256",
    "Public access must be blocked",
    "Bucket ownership must be enforced",
    "Logs must be retained for 90 days",
    "ELB accounts must have write access",
    "delivery.logs.amazonaws.com must have write access with proper ACL"
  ]
}