{
  "resources": [
    {
      "id": "VPC",
      "kind": "AWS::EC2::VPC",
      "fields": {
        "CidrBlock": "10.0.0.0/16",
        "EnableDnsSupport": true,
        "EnableDnsHostnames": true
      },
      "effects": [
        "isolated-network"
      ]
    },
    {
      "id": "PublicSubnet",
      "kind": "AWS::EC2::Subnet",
      "fields": {
        "VpcId": "VPC",
        "CidrBlock": "10.0.1.0/24",
        "AvailabilityZone": "us-east-1a"
      },
      "effects": [
        "public-facing"
      ]
    },
    {
      "id": "InternetGateway",
      "kind": "AWS::EC2::InternetGateway",
      "fields": {},
      "effects": [
        "internet-access"
      ]
    },
    {
      "id": "VPCGatewayAttachment",
      "kind": "AWS::EC2::VPCGatewayAttachment",
      "fields": {
        "VpcId": "VPC",
        "InternetGatewayId": "InternetGateway"
      },
      "effects": [
        "internet-access"
      ]
    },
    {
      "id": "RouteTable",
      "kind": "AWS::EC2::RouteTable",
      "fields": {
        "VpcId": "VPC"
      },
      "effects": [
        "routing"
      ]
    },
    {
      "id": "Route",
      "kind": "AWS::EC2::Route",
      "fields": {
        "RouteTableId": "RouteTable",
        "DestinationCidrBlock": "0.0.0.0/0",
        "GatewayId": "InternetGateway"
      },
      "effects": [
        "routing"
      ]
    },
    {
      "id": "SubnetRouteTableAssociation",
      "kind": "AWS::EC2::SubnetRouteTableAssociation",
      "fields": {
        "SubnetId": "PublicSubnet",
        "RouteTableId": "RouteTable"
      },
      "effects": [
        "routing"
      ]
    },
    {
      "id": "SecurityGroup",
      "kind": "AWS::EC2::SecurityGroup",
      "fields": {
        "GroupDescription": "Allow HTTP access",
        "VpcId": "VPC",
        "SecurityGroupIngress": [
          {
            "IpProtocol": "tcp",
            "FromPort": 80,
            "ToPort": 80,
            "CidrIp": "0.0.0.0/0"
          }
        ]
      },
      "effects": [
        "http-access"
      ]
    },
    {
      "id": "WebServerInstance",
      "kind": "AWS::EC2::Instance",
      "fields": {
        "ImageId": "ami-0c55b159cbfafe0f0",
        "InstanceType": "t2.micro",
        "SubnetId": "PublicSubnet",
        "SecurityGroupIds": [
          "SecurityGroup"
        ],
        "KeyName": "my-key-pair",
        "UserData": {
          "Fn::Base64": {
            "Fn::Join": [
              "",
              [
                "#!/bin/bash\n",
                "yum update -y\n",
                "yum install -y httpd php\n",
                "service httpd start\n",
                "chkconfig httpd on\n",
                "aws s3 cp s3://my-sample-content/sample.zip /tmp/\n",
                "unzip /tmp/sample.zip -d /var/www/html/\n"
              ]
            ]
          }
        }
      },
      "effects": [
        "web-server",
        "auto-configured"
      ]
    }
  ],
  "edges": [
    {
      "type": "depends",
      "from": "PublicSubnet",
      "to": "VPC"
    },
    {
      "type": "depends",
      "from": "VPCGatewayAttachment",
      "to": "VPC"
    },
    {
      "type": "depends",
      "from": "VPCGatewayAttachment",
      "to": "InternetGateway"
    },
    {
      "type": "depends",
      "from": "RouteTable",
      "to": "VPC"
    },
    {
      "type": "depends",
      "from": "Route",
      "to": "RouteTable"
    },
    {
      "type": "depends",
      "from": "Route",
      "to": "InternetGateway"
    },
    {
      "type": "depends",
      "from": "SubnetRouteTableAssociation",
      "to": "PublicSubnet"
    },
    {
      "type": "depends",
      "from": "SubnetRouteTableAssociation",
      "to": "RouteTable"
    },
    {
      "type": "depends",
      "from": "SecurityGroup",
      "to": "VPC"
    },
    {
      "type": "depends",
      "from": "WebServerInstance",
      "to": "PublicSubnet"
    },
    {
      "type": "depends",
      "from": "WebServerInstance",
      "to": "SecurityGroup"
    }
  ],
  "invariants": [
    "VPC provides isolated network environment",
    "Public subnet enables internet-facing resources",
    "Security group restricts HTTP access to port 80",
    "EC2 instance automatically installs and configures web server",
    "User data script retrieves and deploys content from S3"
  ]
}