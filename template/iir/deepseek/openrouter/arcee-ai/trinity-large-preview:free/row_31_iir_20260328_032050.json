  "invariants": [
    "VPC must be created before subnets",
    "Internet gateway must be attached to VPC before route creation",
    "Security groups must be created before launch template",
    "RDS instance must be created after DB subnet group and security group",
    "CodeDeploy resources must be created after S3 bucket",
    "SSM parameters must be created after RDS instance",
    "Auto Scaling Group must be created after Launch Template",
    "Load Balancer must be created after subnets and security group",
