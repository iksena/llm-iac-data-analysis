{
  "resources": [
    {
      "id": "CognitoUserPool",
      "kind": "AWS::Cognito::UserPool",
      "fields": {
        "UserPoolName": "SecureUserPool",
        "Policies": {
          "PasswordPolicy": {
            "MinimumLength": 8,
            "RequireLowercase": true,
            "RequireNumbers": true,
            "RequireSymbols": true,
            "RequireUppercase": true
          }
        },
        "AdminCreateUserConfig": {
          "AllowAdminCreateUserOnly": true
        },
        "AutoVerifiedAttributes": [
          "email"
        ],
        "EmailVerificationMessage": "Your verification code is {####}",
        "EmailVerificationSubject": "Your verification code",
        "Schema": [
          {
            "Name": "email",
            "AttributeDataType": "String",
            "DeveloperOnlyAttribute": false,
            "Mutable": false,
            "Required": true,
            "StringAttributeConstraints": {
              "MinLength": "0",
              "MaxLength": "2048"
            }
          }
        ]
      },
      "effects": [
        "encrypted",
        "versioned"
      ]
    },
    {
      "id": "CognitoUserPoolClient",
      "kind": "AWS::Cognito::UserPoolClient",
      "fields": {
        "UserPoolId": "CognitoUserPool",
        "ClientName": "SecureAppClient",
        "ExplicitAuthFlows": [
          "ADMIN_NO_SRP_AUTH",
          "USER_PASSWORD_AUTH",
          "ALLOW_REFRESH_TOKEN_AUTH"
        ],
        "PreventUserExistenceErrors": "ENABLED",
        "WriteAttributes": [
          "email"
        ],
        "ReadAttributes": [
          "email"
        ]
      },
      "effects": [
        "encrypted"
      ]
    },
    {
      "id": "CognitoUserPoolDomain",
      "kind": "AWS::Cognito::UserPoolDomain",
      "fields": {
        "Domain": "secure-auth-domain",
        "UserPoolId": "CognitoUserPool"
      },
      "effects": [
        "public"
      ]
    }
  ],
  "edges": [
    {
      "type": "depends",
      "from": "CognitoUserPoolClient",
      "to": "CognitoUserPool"
    },
    {
      "type": "depends",
      "from": "CognitoUserPoolDomain",
      "to": "CognitoUserPool"
    }
  ],
  "invariants": [
    "User pool must enforce strong password policies",
    "Only administrators can create users",
    "Email verification is required for authentication",
    "User pool must be encrypted at rest",
    "Client must prevent user existence errors",
    "Domain must be publicly accessible for authentication flows"
  ]
}