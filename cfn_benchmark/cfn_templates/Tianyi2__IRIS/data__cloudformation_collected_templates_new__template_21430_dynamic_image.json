{
  "Resources": {
    "taskdef": {
      "Type": "AWS::ECS::TaskDefinition",
      "Properties": {
        "RequiresCompatibilities": [
          "FARGATE"
        ],
        "Tags": [
          {
            "Key": "antani",
            "Value": "sbiribuda"
          },
          {
            "Key": "kiltinclude",
            "Value": "itisignored"
          }
        ],
        "ContainerDefinitions": [
          {
            "Name": "app",
            "Image": {
              "Fn::Join": [
                "",
                [
                  "quak.io/gimme/",
                  {
                    "Fn::GetAtt": [
                      "fried",
                      "chicken"
                    ]
                  }
                ]
              ]
            },
            "Command": ["/bin/sh"]
          }
        ]
      }
    }
  }
}