{
  "resources": [
    {
      "id": "EC2Role",
      "kind": "AWS::IAM::Role",
      "fields": {
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "ec2.amazonaws.com"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "Path": "/"
      },
      "effects": [
        "cloudwatch-integration",
        "ssm-integration"
      ]
    },
    {
      "id": "CloudWatchPolicy",
      "kind": "AWS::IAM::ManagedPolicy",
      "fields": {
        "PolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Action": [
                "cloudwatch:PutMetricData",
                "cloudwatch:GetMetricStatistics",
                "cloudwatch:ListMetrics",
                "ec2:DescribeTags"
              ],
              "Resource": "*"
            }
          ]
        },
        "Description": "Managed policy for CloudWatch integration"
      },
      "effects": [
        "cloudwatch-policy"
      ]
    },
    {
      "id": "SSMManagedPolicy",
      "kind": "AWS::IAM::ManagedPolicy",
      "fields": {
        "PolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Action": [
                "ssm:UpdateInstanceInformation",
                "ssmmessages:CreateControlChannel",
                "ssmmessages:CreateDataChannel",
                "ssmmessages:OpenControlChannel",
                "ssmmessages:OpenDataChannel"
              ],
              "Resource": "*"
            }
          ]
        },
        "Description": "Managed policy for SSM integration"
      },
      "effects": [
        "ssm-policy"
      ]
    },
    {
      "id": "EC2InstanceProfile",
      "kind": "AWS::IAM::InstanceProfile",
      "fields": {
        "Path": "/",
        "Roles": [
          {
            "Ref": "EC2Role"
          }
        ]
      },
      "effects": [
        "instance-profile"
      ]
    }
  ],
  "edges": [
    {
      "type": "depends",
      "from": "CloudWatchPolicy",
      "to": "EC2Role"
    },
    {
      "type": "depends",
      "from": "SSMManagedPolicy",
      "to": "EC2Role"
    },
    {
      "type": "depends",
      "from": "EC2InstanceProfile",
      "to": "EC2Role"
    }
  ],
  "invariants": [
    "EC2 instances must have permissions to integrate with CloudWatch and SSM",
    "Instance profile must be created for EC2 instances to assume the role",
    "Managed policies should be attached to the IAM role for separation of concerns"
  ]
}