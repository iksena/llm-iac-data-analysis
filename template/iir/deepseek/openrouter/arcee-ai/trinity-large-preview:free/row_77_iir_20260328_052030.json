{
  "resources": [
    {
      "id": "SupporterProductData",
      "kind": "AWS::DynamoDB::Table",
      "fields": {
        "TableName": {
          "Fn::Sub": "SupporterProductData-${Stage}"
        },
        "BillingMode": {
          "Fn::If": [
            "IsProd",
            "PROVISIONED",
            "PAY_PER_REQUEST"
          ]
        },
        "ProvisionedThroughput": {
          "Fn::If": [
            "IsProd",
            {
              "ReadCapacityUnits": 20,
              "WriteCapacityUnits": 5
            },
            {
              "Ref": "AWS::NoValue"
            }
          ]
        },
        "SSESpecification": {
          "Enabled": true
        },
        "TimeToLiveSpecification": {
          "AttributeName": "expiryDate",
          "Enabled": true
        },
        "Tags": [
          {
            "Key": "Backup",
            "Value": "true"
          }
        ],
        "KeySchema": [
          {
            "AttributeName": "id",
            "KeyType": "HASH"
          }
        ],
        "AttributeDefinitions": [
          {
            "AttributeName": "id",
            "AttributeType": "S"
          }
        ]
      },
      "effects": [
        "encrypted",
        "ttl-enabled",
        "backup-tagged"
      ]
    },
    {
      "id": "AutoScalingWriteCapacity",
      "kind": "AWS::ApplicationAutoScaling::ScalingPolicy",
      "fields": {
        "PolicyName": "WriteCapacityAutoScaling",
        "PolicyType": "TargetTrackingScaling",
        "ScalingTargetId": {
          "Ref": "SupporterProductData"
        },
        "TargetTrackingScalingPolicyConfiguration": {
          "TargetValue": 70,
          "ScaleInCooldown": 60,
          "ScaleOutCooldown": 60,
          "PredefinedMetricSpecification": {
            "PredefinedMetricType": "DynamoDBWriteCapacityUtilization"
          }
        }
      },
      "effects": [
        "auto-scaling"
      ]
    }
  ],
  "edges": [
    {
      "type": "depends",
      "from": "AutoScalingWriteCapacity",
      "to": "SupporterProductData"
    }
  ],
  "invariants": [
    "DynamoDB table must be encrypted with SSE",
    "TTL must be enabled for expiryDate attribute",
    "Backup tagging must be applied",
    "Auto-scaling only for PROD environment",
    "On-demand billing for CODE environment"
  ]
}