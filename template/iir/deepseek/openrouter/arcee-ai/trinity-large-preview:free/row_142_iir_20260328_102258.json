    },
    {
      "type": "depends",
      "from": "RouteTable",
      "to": "VPC"
    },
    {
      "type": "depends",
      "from": "InternetRoute",
      "to": "RouteTable"
    },
    {
      "type": "depends",
      "from": "InternetRoute",
      "to": "InternetGateway"
    },
    {
      "type": "depends",
      "from": "SubnetRouteTableAssociation1",
      "to": "PublicSubnet1"
    },
    {
      "type": "depends",
      "from": "SubnetRouteTableAssociation1",
      "to": "RouteTable"
    },
    {
      "type": "depends",
      "from": "SubnetRouteTableAssociation2",
      "to": "PublicSubnet2"
    },
    {
      "type": "depends",
      "from": "SubnetRouteTableAssociation2",
      "to": "RouteTable"
    },
    {
      "type": "depends",
      "from": "SSMSecurityGroup",
      "to": "VPC"
    },
    {
      "type": "depends",
      "from": "SSMInstanceProfile",
      "to": "SSMRole"
    },
    {
      "type": "depends",
      "from": "LinuxLaunchTemplate",
      "to": "LinuxAMIFunction"
    },
    {
      "type": "depends",
      "from": "LinuxLaunchTemplate",
      "to": "SSMInstanceProfile"
    },
    {
      "type": "depends",
      "from": "LinuxLaunchTemplate",
      "to": "SSMSecurityGroup"
    },
    {
      "type": "depends",
      "from": "WindowsLaunchTemplate",
      "to": "WindowsAMIFunction"
    },
    {
      "type": "depends",
      "from": "WindowsLaunchTemplate",
      "to": "SSMInstanceProfile"
    },
    {
      "type": "depends",
      "from": "WindowsLaunchTemplate",
      "to": "SSMSecurityGroup"
    },
    {
      "type": "depends",
      "from": "LinuxAutoScalingGroup",
      "to": "PublicSubnet1"
    },
    {
      "type": "depends",
      "from": "LinuxAutoScalingGroup",
      "to": "PublicSubnet2"
