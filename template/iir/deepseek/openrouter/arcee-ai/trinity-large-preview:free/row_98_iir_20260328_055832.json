{
  "resources": [
    {
      "id": "AmplifyApp",
      "kind": "AWS::Amplify::App",
      "fields": {
        "Name": "TodoApp",
        "Repository": "https://github.com/example/todoapp.git",
        "OauthToken": "ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx",
        "IAMServiceRole": "arn:aws:iam::123456789012:role/AmplifyServiceRole"
      },
      "effects": [
        "versioned",
        "encrypted"
      ]
    },
    {
      "id": "ProductionBranch",
      "kind": "AWS::Amplify::Branch",
      "fields": {
        "AppName": "TodoApp",
        "BranchName": "production",
        "PullRequestEnvironmentEnabled": false,
        "Stage": "PRODUCTION"
      },
      "effects": [
        "auto-deploy"
      ]
    },
    {
      "id": "AmplifyDomain",
      "kind": "AWS::Amplify::Domain",
      "fields": {
        "AppName": "TodoApp",
        "DomainName": "todoapp.example.com",
        "SubDomainSettings": [
          {
            "BranchName": "production",
            "Prefix": "www"
          }
        ]
      },
      "effects": [
        "public"
      ]
    }
  ],
  "edges": [
    {
      "type": "depends",
      "from": "ProductionBranch",
      "to": "AmplifyApp"
    },
    {
      "type": "depends",
      "from": "AmplifyDomain",
      "to": "AmplifyApp"
    }
  ],
  "invariants": [
    "Amplify app must be connected to GitHub repository",
    "Production branch must auto-deploy on push",
    "Domain must point to production branch",
    "IAM service role must have Amplify permissions"
  ]
}