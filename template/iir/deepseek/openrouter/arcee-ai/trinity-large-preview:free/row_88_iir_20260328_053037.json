{
  "resources": [
    {
      "id": "ServiceCatalogRole",
      "kind": "AWS::IAM::Role",
      "fields": {
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "servicecatalog.amazonaws.com"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "ManagedPolicyArns": [
          "arn:aws:iam::aws:policy/AmazonS3FullAccess",
          "arn:aws:iam::aws:policy/service-role/AWSLambdaBasicExecutionRole"
        ]
      },
      "effects": [
        "service-catalog-assumable"
      ]
    },
    {
      "id": "ServiceCatalogPolicy",
      "kind": "AWS::IAM::Policy",
      "fields": {
        "PolicyName": "ServiceCatalogCustomPolicy",
        "PolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Action": [
                "servicecatalog:*",
                "iam:CreateRole",
                "iam:CreatePolicy",
                "iam:AttachRolePolicy",
                "iam:PassRole",
                "lambda:CreateFunction",
                "lambda:InvokeFunction",
                "lambda:UpdateFunctionConfiguration",
                "lambda:DeleteFunction",
                "cloudformation:CreateStack",
                "cloudformation:DescribeStacks",
                "cloudformation:UpdateStack",
                "cloudformation:DeleteStack",
                "sns:CreateTopic",
                "sns:Publish"
              ],
              "Resource": "*"
            }
          ]
        },
        "Roles": [
          {
            "Ref": "ServiceCatalogRole"
          }
        ]
      },
      "effects": [
        "granular-permissions"
      ]
    }
  ],
  "edges": [
    {
      "type": "depends",
      "from": "ServiceCatalogPolicy",
      "to": "ServiceCatalogRole"
    }
  ],
  "invariants": [
    "IAM role must be assumable by Service Catalog",
    "Managed policies for S3 full access and Lambda basic execution must be attached",
    "Granular permissions must cover Service Catalog, IAM, Lambda, CloudFormation, and SNS operations",
    "Policy must be attached to the Service Catalog role"
  ]
}