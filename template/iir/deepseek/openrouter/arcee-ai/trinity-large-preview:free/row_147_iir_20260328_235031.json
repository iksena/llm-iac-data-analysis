{
  "resources": [
    {
      "id": "SlotMachineBucket",
      "kind": "AWS::S3::Bucket",
      "fields": {
        "AccessControl": "PublicRead",
        "WebsiteConfiguration": {
          "IndexDocument": "index.html",
          "ErrorDocument": "error.html"
        }
      },
      "effects": [
        "public-read",
        "static-website"
      ]
    },
    {
      "id": "LambdaExecutionRole",
      "kind": "AWS::IAM::Role",
      "fields": {
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "lambda.amazonaws.com"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "Policies": [
          {
            "PolicyName": "LambdaExecutionPolicy",
            "PolicyDocument": {
              "Version": "2012-10-17",
              "Statement": [
                {
                  "Effect": "Allow",
                  "Action": [
                    "logs:CreateLogGroup",
                    "logs:CreateLogStream",
                    "logs:PutLogEvents"
                  ],
                  "Resource": "arn:aws:logs:*:*:*"
                }
              ]
            }
          }
        ]
      },
      "effects": [
        "lambda-execution"
      ]
    },
    {
      "id": "SlotMachineFunction",
      "kind": "AWS::Lambda::Function",
      "fields": {
        "Handler": "index.handler",
        "Runtime": "nodejs18.x",
        "Role": {
          "Fn::GetAtt": [
            "LambdaExecutionRole",
            "Arn"
          ]
        },
        "Code": {
          "ZipFile": "exports.handler = async (event) => { /* slot machine logic */ };"
        }
      },
      "effects": [
        "slot-machine-logic"
      ]
    },
    {
      "id": "CognitoIdentityPool",
      "kind": "AWS::Cognito::IdentityPool",
      "fields": {
        "AllowUnauthenticatedIdentities": true
      },
      "effects": [
        "cognito-identity"
      ]
    },
    {
      "id": "CognitoIdentityPoolRoleMap",
      "kind": "AWS::Cognito::IdentityPoolRoleAttachment",
      "fields": {
        "IdentityPoolId": {
          "Ref": "CognitoIdentityPool"
        },
        "Roles": {
          "unauthenticated": {
            "Fn::GetAtt": [
              "CognitoUnauthRole",
              "Arn"
            ]
          }
        }
      },
      "effects": [
        "cognito-role-mapping"
      ]
    },
    {
      "id": "CognitoUnauthRole",
      "kind": "AWS::IAM::Role",
      "fields": {
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Federated": "cognito-identity.amazonaws.com"
              },
              "Action": "sts:AssumeRoleWithWebIdentity",
              "Condition": {
                "StringEquals": {
                  "cognito-identity.amazonaws.com:aud": {
                    "Ref": "CognitoIdentityPool"
                  }
                },
                "ForAnyValue:StringLike": {
                  "cognito-identity.amazonaws.com:amr": "unauthenticated"
                }
              }
            }
          ]
        },
        "Policies": [
          {
            "PolicyName": "CognitoUnauthPolicy",
            "PolicyDocument": {
              "Version": "2012-10-17",
              "Statement": [
                {
                  "Effect": "Allow",
                  "Action": [
                    "lambda:InvokeFunction"
                  ],
                  "Resource": {
                    "Fn::GetAtt": [
                      "SlotMachineFunction",
                      "Arn"
                    ]
                  }
                }
              ]
            }
          }
        ]
      },
      "effects": [
        "cognito-unauthenticated"
      ]
    },
    {
      "id": "DeployWebsiteFunction",
      "kind": "AWS::Lambda::Function",
      "fields": {
        "Handler": "index.handler",
        "Runtime": "nodejs18.x",
        "Role": {
          "Fn::GetAtt": [
            "LambdaExecutionRole",
            "Arn"
          ]
        },
        "Code": {
          "ZipFile": "exports.handler = async (event) => { /* deployment logic */ };"
        }
      },
      "effects": [
        "website-deployment"
      ]
    },
    {
      "id": "DeployWebsiteCustomResource",
      "kind": "AWS::CloudFormation::CustomResource",
      "fields": {
        "ServiceToken": {
          "Fn::GetAtt": [
            "DeployWebsiteFunction",
            "Arn"
          ]
        },
        "BucketName": {
          "Ref": "SlotMachineBucket"
        }
      },
      "effects": [
        "custom-resource"
      ]
    }
  ],
  "edges": [
    {
      "type": "depends",
      "from": "LambdaExecutionRole",
      "to": "SlotMachineFunction"
    },
    {
      "type": "depends",
      "from": "CognitoIdentityPool",
      "to": "CognitoIdentityPoolRoleMap"
    },
    {
      "type": "depends",
      "from": "CognitoUnauthRole",
      "to": "CognitoIdentityPoolRoleMap"
    },
    {
      "type": "depends",
      "from": "DeployWebsiteFunction",
      "to": "DeployWebsiteCustomResource"
    },
    {
      "type": "depends",
      "from": "LambdaExecutionRole",
      "to": "DeployWebsiteFunction"
    }
  ],
  "invariants": [
    "S3 bucket must be publicly accessible for static website hosting",
    "Lambda function must have logging permissions",
    "Cognito unauthenticated role must only allow Lambda invocation",
    "Custom resource must deploy website content after bucket creation",
    "Frontend must be configured with correct Cognito and region settings"
  ]
}