{
  "resources": [
    {
      "id": "APIGatewayRestApi",
      "kind": "AWS::ApiGateway::RestApi",
      "fields": {
        "Name": "SecureEmailAPI"
      },
      "effects": [
        "encrypted"
      ]
    },
    {
      "id": "APIGatewayResource",
      "kind": "AWS::ApiGateway::Resource",
      "fields": {
        "ParentId": "APIGatewayRestApi.RootResourceId",
        "PathPart": "email",
        "RestApiId": "APIGatewayRestApi"
      },
      "effects": []
    },
    {
      "id": "APIGatewayMethod",
      "kind": "AWS::ApiGateway::Method",
      "fields": {
        "HttpMethod": "POST",
        "ResourceId": "APIGatewayResource",
        "RestApiId": "APIGatewayRestApi",
        "AuthorizationType": "AWS_IAM",
        "ApiKeyRequired": true,
        "RequestValidatorId": "APIGatewayRequestValidator"
      },
      "effects": [
        "public-read"
      ]
    },
    {
      "id": "APIGatewayRequestValidator",
      "kind": "AWS::ApiGateway::RequestValidator",
      "fields": {
        "Name": "EmailRequestValidator",
        "RestApiId": "APIGatewayRestApi",
        "ValidateRequestBody": true,
        "ValidateRequestParameters": true
      },
      "effects": []
    },
    {
      "id": "APIGatewayIntegration",
      "kind": "AWS::ApiGateway::Integration",
      "fields": {
        "HttpMethod": "POST",
        "ResourceId": "APIGatewayResource",
        "RestApiId": "APIGatewayRestApi",
        "Type": "AWS",
        "IntegrationHttpMethod": "POST",
        "Uri": "arn:aws:apigateway:us-east-1:ses:action/SendEmail",
        "Credentials": "APIGatewayIAMRole.Arn",
        "RequestTemplates": {
          "application/json": "#set($allParams = $input.path('$'))\n{\n  \"Source\": \"$input.path('$.from')\",\n  \"Destination\": {\n    \"ToAddresses\": [\"$input.path('$.to')\"]\n  },\n  \"Message\": {\n    \"Subject\": {\n      \"Data\": \"$input.path('$.subject')\"\n    },\n    \"Body\": {\n      \"Text\": {\n        \"Data\": \"$input.path('$.text')\"\n      },\n      \"Html\": {\n        \"Data\": \"$input.path('$.html')\"\n      }\n    }\n  }\n}"
        }
      },
      "effects": []
    },
    {
      "id": "APIGatewayDeployment",
      "kind": "AWS::ApiGateway::Deployment",
      "fields": {
        "RestApiId": "APIGatewayRestApi",
        "StageName": "prod"
      },
      "effects": []
    },
    {
      "id": "APIGatewayUsagePlan",
      "kind": "AWS::ApiGateway::UsagePlan",
      "fields": {
        "Name": "EmailUsagePlan",
        "ApiStages": [
          {
            "ApiId": "APIGatewayRestApi",
            "Stage": "prod"
          }
        ],
        "Throttle": {
          "BurstLimit": 500,
          "RateLimit": 500
        },
        "Quota": {
          "Limit": 10000,
          "Period": "MONTH"
        }
      },
      "effects": []
    },
    {
      "id": "APIGatewayApiKey",
      "kind": "AWS::ApiGateway::ApiKey",
      "fields": {
        "Name": "EmailAPIKey",
        "Description": "API Key for Email Service",
        "Enabled": true
      },
      "effects": [
        "encrypted"
      ]
    },
    {
      "id": "APIGatewayUsagePlanKey",
      "kind": "AWS::ApiGateway::UsagePlanKey",
      "fields": {
        "KeyId": "APIGatewayApiKey",
        "KeyType": "API_KEY",
        "UsagePlanId": "APIGatewayUsagePlan"
      },
      "effects": []
    },
    {
      "id": "APIGatewayIAMRole",
      "kind": "AWS::IAM::Role",
      "fields": {
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "apigateway.amazonaws.com"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "Path": "/",
        "Policies": [
          {
            "PolicyName": "APIGatewaySESPolicy",
            "PolicyDocument": {
              "Version": "2012-10-17",
              "Statement": [
                {
                  "Effect": "Allow",
                  "Action": [
                    "ses:SendEmail"
                  ],
                  "Resource": "*"
                }
              ]
            }
          }
        ]
      },
      "effects": [
        "encrypted"
      ]
    }
  ],
  "edges": [
    {
      "type": "depends",
      "from": "APIGatewayResource",
      "to": "APIGatewayRestApi"
    },
    {
      "type": "depends",
      "from": "APIGatewayMethod",
      "to": "APIGatewayResource"
    },
    {
      "type": "depends",
      "from": "APIGatewayMethod",
      "to": "APIGatewayRequestValidator"
    },
    {
      "type": "depends",
      "from": "APIGatewayIntegration",
      "to": "APIGatewayMethod"
    },
    {
      "type": "depends",
      "from": "APIGatewayDeployment",
      "to": "APIGatewayRestApi"
    },
    {
      "type": "depends",
      "from": "APIGatewayUsagePlan",
      "to": "APIGatewayRestApi"
    },
    {
      "type": "depends",
      "from": "APIGatewayUsagePlanKey",
      "to": "APIGatewayApiKey"
    },
    {
      "type": "depends",
      "from": "APIGatewayUsagePlanKey",
      "to": "APIGatewayUsagePlan"
    },
    {
      "type": "depends",
      "from": "APIGatewayIntegration",
      "to": "APIGatewayIAMRole"
    }
  ],
  "invariants": [
    "API Gateway must have IAM permissions to invoke SES SendEmail action",
    "Request validation must enforce JSON schema compliance",
    "API key authentication must be enabled with encryption",
    "Rate limiting must enforce 500 requests/second and 10,000 requests/month quotas",
    "All API keys must be encrypted at rest"
  ]
}