{
  "resources": [
    {
      "id": "EC2LinuxInstance",
      "kind": "AWS::EC2::Instance",
      "fields": {
        "ImageId": "ami-0123456789abcdef0",
        "InstanceType": "t3.micro",
        "IamInstanceProfile": "EC2SSMRole",
        "Tags": [
          {
            "Key": "HelloWorld",
            "Value": "true"
          }
        ]
      },
      "effects": [
        "linux",
        "ssm-agent",
        "tagged"
      ]
    },
    {
      "id": "EC2WindowsInstance",
      "kind": "AWS::EC2::Instance",
      "fields": {
        "ImageId": "ami-0abcdef1234567890",
        "InstanceType": "t3.micro",
        "IamInstanceProfile": "EC2SSMRole",
        "Tags": [
          {
            "Key": "HelloWorld",
            "Value": "true"
          }
        ]
      },
      "effects": [
        "windows",
        "ssm-agent",
        "tagged"
      ]
    },
    {
      "id": "EC2SSMRole",
      "kind": "AWS::IAM::Role",
      "fields": {
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "ec2.amazonaws.com"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "ManagedPolicyArns": [
          "arn:aws:iam::aws:policy/service-role/AmazonEC2RoleforSSM"
        ]
      },
      "effects": [
        "ssm-access",
        "s3-access"
      ]
    },
    {
      "id": "EC2SSMInstanceProfile",
      "kind": "AWS::IAM::InstanceProfile",
      "fields": {
        "Roles": [
          "EC2SSMRole"
        ]
      }
    },
    {
      "id": "SSMDocument",
      "kind": "AWS::SSM::Document",
      "fields": {
        "Content": {
          "schemaVersion": "1.2",
          "description": "Cross-platform Hello World script",
          "parameters": {},
          "mainSteps": [
            {
              "action": "aws:runShellScript",
              "name": "linuxStep",
              "inputs": {
                "runCommand": [
                  "echo 'Hello World! (Linux)'"
                ]
              },
              "precondition": {
                "StringEquals": [
                  "platformType",
                  "Linux"
                ],
                "type": "Platform"
              }
            },
            {
              "action": "aws:runPowerShellScript",
              "name": "windowsStep",
              "inputs": {
                "runCommand": [
                  "Write-Host 'Hello World! (Windows)'"
                ]
              },
              "precondition": {
                "StringEquals": [
                  "platformType",
                  "Windows"
                ],
                "type": "Platform"
              }
            }
          ]
        }
      },
      "effects": [
        "cross-platform",
        "os-specific-commands"
      ]
    },
    {
      "id": "SSMAssociation",
      "kind": "AWS::SSM::Association",
      "fields": {
        "Name": "SSMDocument",
        "Targets": [
          {
            "Key": "tag:HelloWorld",
            "Values": [
              "true"
            ]
          }
        ],
        "ScheduleExpression": "rate(15 minutes)"
      },
      "effects": [
        "scheduled-execution",
        "tagged-targets"
      ]
    },
    {
      "id": "EventBridgeSchedule",
      "kind": "AWS::Scheduler::Schedule",
      "fields": {
        "FlexibleTimeWindow": {
          "Mode": "OFF"
        },
        "Name": "SSMSyncSchedule",
        "ScheduleExpression": "rate(15 minutes)",
        "Target": {
          "Arn": "arn:aws:ssm:us-east-1:123456789012:state-manager-run-association",
          "RoleArn": "EventBridgeInvokeSSMIAMRole",
          "Input": "{}"
        }
      },
      "effects": [
        "event-driven",
        "15min-interval"
      ]
    },
    {
      "id": "EventBridgeInvokeSSMIAMRole",
      "kind": "AWS::IAM::Role",
      "fields": {
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "scheduler.amazonaws.com"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "Policies": [
          {
            "PolicyName": "InvokeSSM",
            "PolicyDocument": {
              "Version": "2012-10-17",
              "Statement": [
                {
                  "Effect": "Allow",
                  "Action": [
                    "ssm:SendCommand",
                    "ssm:ListCommands",
                    "ssm:ListCommandInvocations"
                  ],
                  "Resource": "*"
                }
              ]
            }
          }
        ]
      },
      "effects": [
        "eventbridge-permission",
        "ssm-invocation"
      ]
    },
    {
      "id": "S3LogBucket",
      "kind": "AWS::S3::Bucket",
      "fields": {
        "BucketName": "ssm-automation-logs-123456789012"
      },
      "effects": [
        "logging",
        "s3-storage"
      ]
    },
    {
      "id": "S3LogBucketPolicy",
      "kind": "AWS::S3::BucketPolicy",
      "fields": {
        "Bucket": "S3LogBucket",
        "PolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": "*",
              "Action": "s3:PutObject",
              "Resource": "arn:aws:s3:::ssm-automation-logs-123456789012/*"
            }
          ]
        }
      }
    }
  ],
  "edges": [
    {
      "type": "depends",
      "from": "EC2LinuxInstance",
      "to": "EC2SSMInstanceProfile"
    },
    {
      "type": "depends",
      "from": "EC2WindowsInstance",
      "to": "EC2SSMInstanceProfile"
    },
    {
      "type": "depends",
      "from": "EC2SSMInstanceProfile",
      "to": "EC2SSMRole"
    },
    {
      "type": "depends",
      "from": "SSMAssociation",
      "to": "SSMDocument"
    },
    {
      "type": "depends",
      "from": "EventBridgeSchedule",
      "to": "EventBridgeInvokeSSMIAMRole"
    },
    {
      "type": "connects",
      "from": "EventBridgeSchedule",
      "to": "SSMAssociation",
      "proto": "https",
      "port": 443
    }
  ],
  "invariants": [
    "EC2 instances must have SSM agent installed and proper IAM role",
    "SSMDocument must support both Linux and Windows platforms",
    "EventBridge Schedule must trigger SSM Association every 15 minutes",
    "S3 bucket must store execution logs securely",
    "IAM roles must have least-privilege permissions for SSM and S3 access"
  ]
}