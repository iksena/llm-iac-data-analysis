{
  "resources": [
    {
      "id": "EC2Instance",
      "kind": "AWS::EC2::Instance",
      "fields": {
        "ImageId": "ami-0c55b159cbfafe0f0",
        "InstanceType": "t3.micro",
        "IamInstanceProfile": {
          "Ref": "InstanceProfile"
        },
        "UserData": {
          "Fn::Base64": {
            "Fn::Join": [
              "",
              [
                "#!/bin/bash\n",
                "sudo yum update -y\n",
                "sudo yum install -y nginx\n",
                "sudo systemctl start nginx\n",
                "sudo systemctl enable nginx\n"
              ]
            ]
          }
        }
      },
      "effects": [
        "encrypted",
        "monitored"
      ]
    },
    {
      "id": "IAMRole",
      "kind": "AWS::IAM::Role",
      "fields": {
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "ec2.amazonaws.com"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "ManagedPolicyArns": [
          "arn:aws:iam::aws:policy/service-role/AmazonEC2RoleforSSM",
          "arn:aws:iam::aws:policy/AmazonS3FullAccess",
          "arn:aws:iam::aws:policy/CloudWatchAgentServerPolicy"
        ]
      },
      "effects": [
        "least-privilege"
      ]
    },
    {
      "id": "InstanceProfile",
      "kind": "AWS::IAM::InstanceProfile",
      "fields": {
        "Roles": [
          {
            "Ref": "IAMRole"
          }
        ]
      }
    },
    {
      "id": "SSMAutomationDocument",
      "kind": "AWS::SSM::Document",
      "fields": {
        "Content": {
          "schemaVersion": "1.0",
          "description": "Update OS, install Nginx, validate",
          "parameters": {},
          "mainSteps": [
            {
              "name": "UpdateOS",
              "action": "aws:runShellScript",
              "inputs": {
                "runCommand": [
                  "sudo yum update -y"
                ]
              }
            },
            {
              "name": "InstallNginx",
              "action": "aws:runShellScript",
              "inputs": {
                "runCommand": [
                  "sudo yum install -y nginx",
                  "sudo systemctl start nginx"
                ]
              }
            },
            {
              "name": "Validate",
              "action": "aws:runShellScript",
              "inputs": {
                "runCommand": [
                  "curl -f http://localhost || exit 1"
                ]
              }
            }
          ]
        },
        "DocumentType": "Automation"
      },
      "effects": [
        "orchestrated"
      ]
    },
    {
      "id": "S3Bucket",
      "kind": "AWS::S3::Bucket",
      "fields": {
        "BucketName": "ssm-automation-logs",
        "VersioningConfiguration": {
          "Status": "Enabled"
        },
        "LoggingConfiguration": {
          "DestinationBucketName": {
            "Ref": "S3Bucket"
          },
          "LogFilePrefix": "logs/"
        }
      },
      "effects": [
        "versioned",
        "auditable"
      ]
    },
    {
      "id": "SSMAutomationAssociation",
      "kind": "AWS::SSM::Association",
      "fields": {
        "Name": {
          "Ref": "SSMAutomationDocument"
        },
        "Targets": [
          {
            "Key": "InstanceIds",
            "Values": [
              {
                "Ref": "EC2Instance"
              }
            ]
          }
        ]
      }
    }
  ],
  "edges": [
    {
      "type": "depends",
      "from": "InstanceProfile",
      "to": "IAMRole"
    },
    {
      "type": "depends",
      "from": "EC2Instance",
      "to": "InstanceProfile"
    },
    {
      "type": "depends",
      "from": "SSMAutomationAssociation",
      "to": "SSMAutomationDocument"
    },
    {
      "type": "depends",
      "from": "SSMAutomationAssociation",
      "to": "EC2Instance"
    }
  ],
  "invariants": [
    "EC2 instance must have SSM permissions for command execution",
    "S3 bucket must be versioned for auditability",
    "IAM role must enforce least-privilege access",
    "Automation document must orchestrate multi-step process with validation"
  ]
}