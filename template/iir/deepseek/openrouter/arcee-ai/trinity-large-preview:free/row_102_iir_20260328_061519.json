      "fields": {
        "DisplayName": "RiskManagementNotifications"
      },
      "effects": [
        "public-read"
      ]
    },
    {
      "id": "SNSTopicPolicy",
      "kind": "AWS::SNS::TopicPolicy",
      "fields": {
        "PolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "ssm-opscenter.amazonaws.com"
              },
              "Action": "sns:Publish",
              "Resource": "SNSTopic.Arn"
            }
          ]
        },
        "Topics": [
          "SNSTopic"
        ]
      }
    }
