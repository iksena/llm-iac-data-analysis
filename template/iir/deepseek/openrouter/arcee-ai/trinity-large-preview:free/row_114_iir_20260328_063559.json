{
  "resources": [
    {
      "id": "B2BIPipeline",
      "kind": "AWS::B2BI::Pipeline",
      "fields": {
        "Name": "EDI-X12-214-Transformer",
        "Description": "Pipeline for transforming EDI X12_214 documents to JSON"
      },
      "effects": [
        "b2bi-pipeline"
      ]
    },
    {
      "id": "B2BIPartnerProfile",
      "kind": "AWS::B2BI::PartnerProfile",
      "fields": {
        "Name": "BusinessPartner",
        "BusinessContact": {
          "Name": "John Doe",
          "Email": "john.doe@example.com",
          "Phone": "+1-555-0123"
        }
      },
      "effects": [
        "b2bi-partner"
      ]
    },
    {
      "id": "EDITransformer",
      "kind": "AWS::B2BI::Transformer",
      "fields": {
        "Name": "X12_214_to_JSON",
        "MappingLogic": "EDI X12_214 to JSON transformation rules",
        "InputFormat": "EDI",
        "OutputFormat": "JSON"
      },
      "effects": [
        "b2bi-transformer"
      ]
    },
    {
      "id": "InputBucket",
      "kind": "AWS::S3::Bucket",
      "fields": {
        "BucketName": "edi-x12-214-input",
        "AccessControl": "Private"
      },
      "effects": [
        "input-bucket"
      ]
    },
    {
      "id": "OutputBucket",
      "kind": "AWS::S3::Bucket",
      "fields": {
        "BucketName": "edi-x12-214-output",
        "AccessControl": "Private"
      },
      "effects": [
        "output-bucket"
      ]
    }
  ],
  "edges": [
    {
      "type": "depends",
      "from": "B2BIPipeline",
      "to": "B2BIPartnerProfile"
    },
    {
      "type": "depends",
      "from": "B2BIPipeline",
      "to": "EDITransformer"
    },
    {
      "type": "depends",
      "from": "B2BIPipeline",
      "to": "InputBucket"
    },
    {
      "type": "depends",
      "from": "B2BIPipeline",
      "to": "OutputBucket"
    },
    {
      "type": "connects",
      "from": "InputBucket",
      "to": "EDITransformer",
      "proto": "s3",
      "port": 443
    },
    {
      "type": "connects",
      "from": "EDITransformer",
      "to": "OutputBucket",
      "proto": "s3",
      "port": 443
    }
  ],
  "invariants": [
    "B2BI pipeline must be created with partner profile and transformer",
    "Input S3 bucket must be private and receive EDI files",
    "Output S3 bucket must be private and store transformed JSON",
    "Transformer must convert EDI X12_214 to JSON format",
    "Business contact details must be included in partner profile"
  ]
}