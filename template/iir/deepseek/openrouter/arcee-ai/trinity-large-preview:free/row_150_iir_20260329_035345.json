{
  "resources": [
    {
      "id": "RedisSubnetGroup",
      "kind": "AWS::ElastiCache::SubnetGroup",
      "fields": {
        "Description": "Subnet group for Redis cluster",
        "SubnetIds": [
          "Ref::PrivateSubnet1",
          "Ref::PrivateSubnet2"
        ]
      },
      "effects": [
        "vpc-integrated"
      ]
    },
    {
      "id": "RedisSecurityGroup",
      "kind": "AWS::EC2::SecurityGroup",
      "fields": {
        "GroupDescription": "Security group for Redis cluster",
        "VpcId": "Ref::VPC"
      },
      "effects": [
        "vpc-integrated"
      ]
    },
    {
      "id": "RedisSecurityGroupIngress",
      "kind": "AWS::EC2::SecurityGroupIngress",
      "fields": {
        "GroupId": "Ref::RedisSecurityGroup",
        "IpProtocol": "tcp",
        "FromPort": 6379,
        "ToPort": 6379,
        "SourceSecurityGroupId": "Ref::EC2SecurityGroup"
      },
      "effects": [
        "network-access"
      ]
    },
    {
      "id": "RedisCluster",
      "kind": "AWS::ElastiCache::ReplicationGroup",
      "fields": {
        "AtRestEncryptionEnabled": true,
        "AuthToken": "Ref::RedisAuthToken",
        "AutomaticFailoverEnabled": true,
        "CacheNodeType": "cache.t3.micro",
        "CacheSubnetGroupName": "Ref::RedisSubnetGroup",
        "Engine": "redis",
        "NumCacheClusters": 2,
        "Port": 6379,
        "SecurityGroupIds": [
          "Ref::RedisSecurityGroup"
        ],
        "TransitEncryptionEnabled": true
      },
      "effects": [
        "encrypted",
        "high-availability",
        "vpc-integrated"
      ]
    },
    {
      "id": "EC2InstanceRole",
      "kind": "AWS::IAM::Role",
      "fields": {
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "ec2.amazonaws.com"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "ManagedPolicyArns": [
          "arn:aws:iam::aws:policy/AmazonSSMManagedInstanceCore"
        ]
      },
      "effects": [
        "ssm-enabled"
      ]
    },
    {
      "id": "EC2InstanceProfile",
      "kind": "AWS::IAM::InstanceProfile",
      "fields": {
        "Roles": [
          "Ref::EC2InstanceRole"
        ]
      },
      "effects": [
        "ssm-enabled"
      ]
    },
    {
      "id": "EC2SecurityGroup",
      "kind": "AWS::EC2::SecurityGroup",
      "fields": {
        "GroupDescription": "Security group for EC2 instance",
        "VpcId": "Ref::VPC"
      },
      "effects": [
        "vpc-integrated",
        "ssm-enabled"
      ]
    },
    {
      "id": "EC2SecurityGroupIngressSSH",
      "kind": "AWS::EC2::SecurityGroupIngress",
      "fields": {
        "GroupId": "Ref::EC2SecurityGroup",
        "IpProtocol": "tcp",
        "FromPort": 22,
        "ToPort": 22,
        "CidrIp": "0.0.0.0/0"
      },
      "effects": [
        "public-ssh-access"
      ]
    },
    {
      "id": "EC2Instance",
      "kind": "AWS::EC2::Instance",
      "fields": {
        "ImageId": "Ref::AMI",
        "InstanceType": "t3.micro",
        "IamInstanceProfile": "Ref::EC2InstanceProfile",
        "NetworkInterfaces": [
          {
            "AssociatePublicIpAddress": true,
            "DeviceIndex": 0,
            "GroupSet": [
              "Ref::EC2SecurityGroup"
            ],
            "SubnetId": "Ref::PublicSubnet"
          }
        ],
        "UserData": "Ref::EC2UserData"
      },
      "effects": [
        "ssm-enabled",
        "public-subnet"
      ]
    }
  ],
  "edges": [
    {
      "type": "depends",
      "from": "RedisSecurityGroupIngress",
      "to": "RedisSecurityGroup"
    },
    {
      "type": "depends",
      "from": "RedisSecurityGroupIngress",
      "to": "EC2SecurityGroup"
    },
    {
      "type": "depends",
      "from": "RedisCluster",
      "to": "RedisSubnetGroup"
    },
    {
      "type": "depends",
      "from": "RedisCluster",
      "to": "RedisSecurityGroup"
    },
    {
      "type": "depends",
      "from": "EC2InstanceProfile",
      "to": "EC2InstanceRole"
    },
    {
      "type": "depends",
      "from": "EC2Instance",
      "to": "EC2InstanceProfile"
    },
    {
      "type": "depends",
      "from": "EC2Instance",
      "to": "EC2SecurityGroup"
    }
  ],
  "invariants": [
    "Redis cluster must be encrypted at rest and in transit",
    "EC2 instance must have SSM access for management",
    "Redis cluster must be deployed in private subnets with high availability",
    "EC2 instance must be in public subnet with SSH access",
    "Redis cluster must only accept connections from EC2 instance"
  ]
}