{
  "resources": [
    {
      "id": "TaskRole",
      "kind": "AWS::IAM::Role",
      "fields": {
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "ecs-tasks.amazonaws.com"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "ManagedPolicyArns": [
          "arn:aws:iam::aws:policy/AmazonSSMManagedInstanceCore"
        ]
      },
      "effects": [
        "ssm-session-management"
      ]
    },
    {
      "id": "TaskExecutionRole",
      "kind": "AWS::IAM::Role",
      "fields": {
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "ecs-tasks.amazonaws.com"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "ManagedPolicyArns": [
          "arn:aws:iam::aws:policy/service-role/AmazonECSTaskExecutionRolePolicy"
        ]
      },
      "effects": [
        "ecr-pull",
        "cloudwatch-logging"
      ]
    },
    {
      "id": "LogGroup",
      "kind": "AWS::Logs::LogGroup",
      "fields": {
        "RetentionInDays": 7
      },
      "effects": [
        "encrypted",
        "7-day-retention"
      ]
    },
    {
      "id": "TaskDefinition",
      "kind": "AWS::ECS::TaskDefinition",
      "fields": {
        "Cpu": "256",
        "Memory": "512",
        "NetworkMode": "awsvpc",
        "RequiresCompatibilities": [
          "FARGATE"
        ],
        "ExecutionRoleArn": {
          "Fn::GetAtt": [
            "TaskExecutionRole",
            "Arn"
          ]
        },
        "TaskRoleArn": {
          "Fn::GetAtt": [
            "TaskRole",
            "Arn"
          ]
        },
        "ContainerDefinitions": [
          {
            "Name": "nginx",
            "Image": "nginx:latest",
            "PortMappings": [
              {
                "ContainerPort": 80
              }
            ],
            "LogConfiguration": {
              "LogDriver": "awslogs",
              "Options": {
                "awslogs-group": {
                  "Ref": "LogGroup"
                },
                "awslogs-region": {
                  "Ref": "AWS::Region"
                },
                "awslogs-stream-prefix": "ecs"
              }
            }
          }
        ]
      },
      "effects": [
        "fargate",
        "nginx-container",
        "port-80",
        "cloudwatch-logging"
      ]
    }
  ],
  "edges": [
    {
      "type": "depends",
      "from": "TaskDefinition",
      "to": "TaskRole"
    },
    {
      "type": "depends",
      "from": "TaskDefinition",
      "to": "TaskExecutionRole"
    },
    {
      "type": "depends",
      "from": "TaskDefinition",
      "to": "LogGroup"
    }
  ],
  "invariants": [
    "Task role requires SSM session management permissions",
    "Task execution role requires ECR pull and CloudWatch Logs permissions",
    "Container must use NGINX image and expose port 80",
    "CloudWatch Logs retention set to 7 days",
    "Fargate launch type with awsvpc network mode"
  ]
}