{
  "resources": [
    {
      "id": "IPAM",
      "kind": "AWS::EC2::IPAM",
      "fields": {
        "Description": "Managed IP Address Manager for VPC and subnet allocation",
        "OperatingRegions": [
          {
            "RegionName": "us-east-1"
          }
        ]
      },
      "effects": [
        "encrypted"
      ]
    },
    {
      "id": "PublicScope",
      "kind": "AWS::EC2::IPAMPool",
      "fields": {
        "IpamId": "IPAM",
        "Description": "Default public IP scope for internet-facing resources",
        "PoolDepth": 0,
        "IsDefault": true,
        "AddressFamily": "ipv4"
      },
      "effects": [
        "public"
      ]
    },
    {
      "id": "PrivateScope",
      "kind": "AWS::EC2::IPAMPool",
      "fields": {
        "IpamId": "IPAM",
        "Description": "Default private IP scope for internal resources",
        "PoolDepth": 0,
        "IsDefault": true,
        "AddressFamily": "ipv4"
      },
      "effects": [
        "private"
      ]
    }
  ],
  "edges": [
    {
      "type": "depends",
      "from": "PublicScope",
      "to": "IPAM"
    },
    {
      "type": "depends",
      "from": "PrivateScope",
      "to": "IPAM"
    }
  ],
  "invariants": [
    "IPAM must be created before any IPAMPools",
    "Public and private scopes must be default scopes for cross-stack VPC references",
    "Critical identifiers (ARN, ID, scope IDs) must be exported as stack outputs"
  ]
}