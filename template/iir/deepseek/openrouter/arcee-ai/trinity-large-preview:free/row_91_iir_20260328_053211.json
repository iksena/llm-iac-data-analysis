{
  "resources": [
    {
      "id": "VPCFlowLogBucket",
      "kind": "AWS::S3::Bucket",
      "fields": {
        "BucketName": {
          "Ref": "BucketName"
        },
        "AccessControl": "BucketOwnerFullControl",
        "VersioningConfiguration": {
          "Status": {
            "Ref": "EnableVersioning"
          }
        },
        "BucketEncryption": {
          "ServerSideEncryptionConfiguration": [
            {
              "ServerSideEncryptionByDefault": {
                "SSEAlgorithm": "AES256"
              }
            }
          ]
        },
        "LifecycleConfiguration": {
          "Rules": [
            {
              "Id": "TransitionToGlacier",
              "Status": "Enabled",
              "Transition": [
                {
                  "Days": {
                    "Ref": "TransitionDays"
                  },
                  "StorageClass": "GLACIER"
                }
              ],
              "Expiration": {
                "Days": {
                  "Ref": "ExpirationDays"
                }
              }
            }
          ]
        }
      },
      "effects": [
        "encrypted",
        "versioned"
      ]
    },
    {
      "id": "VPCFlowLogBucketPolicy",
      "kind": "AWS::S3::BucketPolicy",
      "fields": {
        "Bucket": {
          "Ref": "VPCFlowLogBucket"
        },
        "PolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "delivery.logs.amazonaws.com"
              },
              "Action": "s3:PutObject",
              "Resource": {
                "Fn::Join": [
                  "",
                  [
                    "arn:aws:s3:::",
                    {
                      "Ref": "VPCFlowLogBucket"
                    },
                    "/*"
                  ]
                ]
              },
              "Condition": {
                "StringEquals": {
                  "s3:x-amz-acl": "bucket-owner-full-control"
                }
              }
            },
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "delivery.logs.amazonaws.com"
              },
              "Action": "s3:GetBucketAcl",
              "Resource": {
                "Fn::Join": [
                  "",
                  [
                    "arn:aws:s3:::",
                    {
                      "Ref": "VPCFlowLogBucket"
                    }
                  ]
                ]
              }
            }
          ]
        }
      },
      "effects": [
        "public-read"
      ]
    }
  ],
  "edges": [
    {
      "type": "depends",
      "from": "VPCFlowLogBucketPolicy",
      "to": "VPCFlowLogBucket"
    }
  ],
  "invariants": [
    "AES256 encryption required",
    "Only delivery.logs.amazonaws.com can write to bucket",
    "Bucket-owner-full-control ACL required",
    "Lifecycle rules for cost optimization",
    "Versioning configurable via parameter"
  ]
}