{
  "resources": [
    {
      "id": "VPC",
      "kind": "AWS::EC2::VPC",
      "fields": {
        "CidrBlock": "10.0.0.0/16",
        "EnableDnsSupport": true,
        "EnableDnsHostnames": true
      },
      "effects": [
        "isolated"
      ]
    },
    {
      "id": "PublicSubnet1",
      "kind": "AWS::EC2::Subnet",
      "fields": {
        "VpcId": "VPC",
        "CidrBlock": "10.0.1.0/24",
        "AvailabilityZone": "us-east-1a"
      },
      "effects": [
        "public"
      ]
    },
    {
      "id": "PublicSubnet2",
      "kind": "AWS::EC2::Subnet",
      "fields": {
        "VpcId": "VPC",
        "CidrBlock": "10.0.2.0/24",
        "AvailabilityZone": "us-east-1b"
      },
      "effects": [
        "public"
      ]
    },
    {
      "id": "InternetGateway",
      "kind": "AWS::EC2::InternetGateway",
      "fields": {},
      "effects": [
        "internet-access"
      ]
    },
    {
      "id": "VPCGatewayAttachment",
      "kind": "AWS::EC2::VPCGatewayAttachment",
      "fields": {
        "VpcId": "VPC",
        "InternetGatewayId": "InternetGateway"
      },
      "effects": [
        "internet-access"
      ]
    },
    {
      "id": "PublicRouteTable",
      "kind": "AWS::EC2::RouteTable",
      "fields": {
        "VpcId": "VPC"
      },
      "effects": [
        "internet-access"
      ]
    },
    {
      "id": "PublicRoute",
      "kind": "AWS::EC2::Route",
      "fields": {
        "RouteTableId": "PublicRouteTable",
        "DestinationCidrBlock": "0.0.0.0/0",
        "GatewayId": "InternetGateway"
      },
      "effects": [
        "internet-access"
      ]
    },
    {
      "id": "PublicSubnet1RouteTableAssociation",
      "kind": "AWS::EC2::SubnetRouteTableAssociation",
      "fields": {
        "SubnetId": "PublicSubnet1",
        "RouteTableId": "PublicRouteTable"
      },
      "effects": [
        "internet-access"
      ]
    },
    {
      "id": "PublicSubnet2RouteTableAssociation",
      "kind": "AWS::EC2::SubnetRouteTableAssociation",
      "fields": {
        "SubnetId": "PublicSubnet2",
        "RouteTableId": "PublicRouteTable"
      },
      "effects": [
        "internet-access"
      ]
    },
    {
      "id": "SecurityGroup",
      "kind": "AWS::EC2::SecurityGroup",
      "fields": {
        "GroupDescription": "Allow HTTP and SSH",
        "VpcId": "VPC",
        "SecurityGroupIngress": [
          {
            "IpProtocol": "tcp",
            "FromPort": 80,
            "ToPort": 80,
            "CidrIp": "0.0.0.0/0"
          },
          {
            "IpProtocol": "tcp",
            "FromPort": 22,
            "ToPort": 22,
            "CidrIp": "0.0.0.0/0"
          }
        ],
        "SecurityGroupEgress": [
          {
            "IpProtocol": "-1",
            "FromPort": -1,
            "ToPort": -1,
            "CidrIp": "0.0.0.0/0"
          }
        ]
      },
      "effects": [
        "allow-http",
        "allow-ssh"
      ]
    },
    {
      "id": "LaunchTemplate",
      "kind": "AWS::EC2::LaunchTemplate",
      "fields": {
        "LaunchTemplateName": "EtherpadLaunchTemplate",
        "LaunchTemplateData": {
          "ImageId": "ami-0c02fb55956c7d316",
          "InstanceType": "t3.micro",
          "KeyName": "my-key-pair",
          "SecurityGroupIds": [
            "SecurityGroup"
          ],
          "IamInstanceProfile": {
            "Name": "EC2InstanceProfile"
          },
          "UserData": {
            "Fn::Base64": {
              "Fn::Join": [
                "",
                [
                  "#!/bin/bash\n",
                  "yum update -y\n",
                  "amazon-linux-extras install -y epel\n",
                  "yum install -y nodejs npm\n",
                  "curl -o- https://raw.githubusercontent.com/nvm-sh/nvm/v0.39.0/install.sh | bash\n",
                  ". ~/.nvm/nvm.sh\n",
                  "nvm install node\n",
                  "npm install -g pm2\n",
                  "wget https://github.com/ether/etherpad-lite/archive/refs/tags/1.8.14.tar.gz\n",
                  "tar -xzf 1.8.14.tar.gz\n",
                  "cd etherpad-lite-1.8.14\n",
                  "npm install\n",
                  "pm2 start node_modules/ep_etherpad-lite/node/server.js --name etherpad\n",
                  "pm2 startup\n",
                  "pm2 save\n",
                  "aws s3 cp s3://my-codedeploy-bucket/latest/install . --region us-east-1\n",
                  "chmod +x ./install\n",
                  "./install auto\n",
                  "cd /home/ec2-user\n",
                  "wget https://s3.amazonaws.com/aws-codedeploy-us-east-1/latest/codedeploy-agent.noarch.rpm\n",
                  "yum -y install codedeploy-agent.noarch.rpm\n",
                  "systemctl enable codedeploy-agent\n",
                  "systemctl start codedeploy-agent\n",
                  "echo 'Deployment completed' > /home/ec2-user/deployment_status.txt\n",
                  "aws cloudformation signal-resource --stack-name ",
                  {
                    "Ref": "AWS::StackName"
                  },
                  " --resource-type 'AWS::CloudFormation::WaitCondition' --region us-east-1 --status SUCCESS\n"
                ]
              ]
            }
          }
        }
      },
      "effects": [
        "auto-scaling",
        "codedeploy-ready"
      ]
    },
    {
      "id": "AutoScalingGroup",
      "kind": "AWS::AutoScaling::AutoScalingGroup",
      "fields": {
        "LaunchTemplate": {
          "LaunchTemplateId": "LaunchTemplate",
          "Version": {
            "Fn::GetAtt": [
              "LaunchTemplate",
              "LatestVersionNumber"
            ]
          }
        },
        "MinSize": "2",
        "MaxSize": "4",
        "DesiredCapacity": "2",
        "VPCZoneIdentifier": [
          "PublicSubnet1",
          "PublicSubnet2"
        ],
        "TargetGroupARNs": [
          "TargetGroup"
        ]
      },
      "effects": [
        "auto-scaling",
        "high-availability"
      ]
    },
    {
      "id": "TargetGroup",
      "kind": "AWS::ElasticLoadBalancingV2::TargetGroup",
      "fields": {
        "HealthCheckIntervalSeconds": 30,
        "HealthCheckPath": "/",
        "HealthCheckPort": "80",
        "HealthCheckProtocol": "HTTP",
        "HealthCheckTimeoutSeconds": 5,
        "HealthyThresholdCount": 2,
        "Matcher": {
          "HttpCode": "200"
        },
        "Name": "EtherpadTargetGroup",
        "Port": 80,
        "Protocol": "HTTP",
        "TargetType": "instance",
        "VpcId": "VPC",
        "UnhealthyThresholdCount": 2
      },
      "effects": [
        "load-balancing",
        "health-check"
      ]
    },
    {
      "id": "LoadBalancer",
      "kind": "AWS::ElasticLoadBalancingV2::LoadBalancer",
      "fields": {
        "Name": "EtherpadLoadBalancer",
        "Scheme": "internet-facing",
        "Subnets": [
          "PublicSubnet1",
          "PublicSubnet2"
        ],
        "Type": "application",
        "SecurityGroups": [
          "SecurityGroup"
        ]
      },
      "effects": [
        "internet-facing",
        "load-balancing"
      ]
    },
    {
      "id": "Listener",
      "kind": "AWS::ElasticLoadBalancingV2::Listener",
      "fields": {
        "DefaultActions": [
          {
            "Type": "forward",
            "TargetGroupArn": "TargetGroup"
          }
        ],
        "LoadBalancerArn": "LoadBalancer",
        "Port": 80,
        "Protocol": "HTTP"
      },
      "effects": [
        "load-balancing",
        "http-routing"
      ]
    },
    {
      "id": "DBSubnetGroup",
      "kind": "AWS::RDS::DBSubnetGroup",
      "fields": {
        "DBSubnetGroupDescription": "Subnets for RDS instance",
        "SubnetIds": [
          "PublicSubnet1",
          "PublicSubnet2"
        ]
      },
      "effects": [
        "database",
        "multi-az"
      ]
    },
    {
      "id": "DBSecurityGroup",
      "kind": "AWS::EC2::SecurityGroup",
      "fields": {
        "GroupDescription": "RDS security group",
        "VpcId": "VPC",
        "SecurityGroupIngress": [
          {
            "IpProtocol": "tcp",
            "FromPort": 3306,
            "ToPort": 3306,
            "SourceSecurityGroupId": "SecurityGroup"
          }
        ],
        "SecurityGroupEgress": [
          {
            "IpProtocol": "-1",
            "FromPort": -1,
            "ToPort": -1,
            "CidrIp": "0.0.0.0/0"
          }
        ]
      },
      "effects": [
        "database",
        "mysql"
      ]
    },
    {
      "id": "RDSSecurityGroupIngress",
      "kind": "AWS::EC2::SecurityGroupIngress",
      "fields": {
        "GroupId": "DBSecurityGroup",
        "IpProtocol": "tcp",
        "FromPort": 3306,
        "ToPort": 3306,
        "SourceSecurityGroupId": "SecurityGroup"
      },
      "effects": [
        "database",
        "mysql"
      ]
    },
    {
      "id": "DBInstance",
      "kind": "AWS::RDS::DBInstance",
      "fields": {
        "AllocatedStorage": "20",
        "DBInstanceClass": "db.t3.micro",
        "DBName": "etherpad",
        "Engine": "MySQL",
        "MasterUsername": "admin",
        "MasterUserPassword": "password123",
        "DBSubnetGroupName": "DBSubnetGroup",
        "VPCSecurityGroups": [
          "DBSecurityGroup"
        ],
        "BackupRetentionPeriod": 7,
        "MultiAZ": false
      },
      "effects": [
        "database",
        "mysql",
        "encrypted"
      ]
    },
    {
      "id": "S3Bucket",
      "kind": "AWS::S3::Bucket",
      "fields": {
        "BucketName": "etherpad-codedeploy-artifacts",
        "VersioningConfiguration": {
          "Status": "Enabled"
        },
        "PublicAccessBlockConfiguration": {
          "BlockPublicAcls": true,
          "BlockPublicPolicy": true,
          "IgnorePublicAcls": true,
          "RestrictPublicBuckets": true
        }
      },
      "effects": [
        "artifact-storage",
        "versioned",
        "private"
      ]
    },
    {
      "id": "CodeDeployApplication",
      "kind": "AWS::CodeDeploy::Application",
      "fields": {
