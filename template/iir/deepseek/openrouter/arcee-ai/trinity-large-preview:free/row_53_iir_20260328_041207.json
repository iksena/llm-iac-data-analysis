{
  "resources": [
    {
      "id": "EMRServerlessRole",
      "kind": "AWS::IAM::Role",
      "fields": {
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "emr-serverless.amazonaws.com"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "ManagedPolicyArns": [
          "arn:aws:iam::aws:policy/service-role/AmazonEMRServerlessRole"
        ],
        "Policies": [
          {
            "PolicyName": "EMRServerlessS3Access",
            "PolicyDocument": {
              "Version": "2012-10-17",
              "Statement": [
                {
                  "Effect": "Allow",
                  "Action": [
                    "s3:GetObject",
                    "s3:PutObject",
                    "s3:ListBucket"
                  ],
                  "Resource": [
                    {
                      "Ref": "ScriptsBucket"
                    },
                    {
                      "Fn::Join": [
                        "",
                        [
                          "arn:aws:s3:::",
                          {
                            "Ref": "ScriptsBucket"
                          },
                          "/*"
                        ]
                      ]
                    }
                  ]
                }
              ]
            }
          },
          {
            "PolicyName": "EMRServerlessCloudWatchAccess",
            "PolicyDocument": {
              "Version": "2012-10-17",
              "Statement": [
                {
                  "Effect": "Allow",
                  "Action": [
                    "logs:CreateLogGroup",
                    "logs:CreateLogStream",
                    "logs:PutLogEvents"
                  ],
                  "Resource": "*"
                }
              ]
            }
          }
        ]
      },
      "effects": [
        "emr-serverless"
      ]
    },
    {
      "id": "ScriptsBucket",
      "kind": "AWS::S3::Bucket",
      "fields": {
        "BucketName": {
          "Fn::Join": [
            "-",
            [
              "emr-serverless-scripts",
              {
                "Ref": "AWS::AccountId"
              },
              {
                "Ref": "AWS::Region"
              }
            ]
          ]
        },
        "AccessControl": "Private",
        "VersioningConfiguration": {
          "Status": "Enabled"
        },
        "BucketEncryption": {
          "ServerSideEncryptionConfiguration": [
            {
              "ServerSideEncryptionByDefault": {
                "SSEAlgorithm": "AES256"
              }
            }
          ]
        }
      },
      "effects": [
        "private",
        "encrypted",
        "versioned"
      ]
    },
    {
      "id": "EMRServerlessApplication",
      "kind": "AWS::EMR::ServerlessApplication",
      "fields": {
        "Name": "EMRServerlessSparkApp",
        "ReleaseLabel": "emr-6.15.0",
        "Type": "SPARK",
        "InitialCapacity": {
          "Worker": {
            "WorkerCount": {
              "Value": 1
            },
            "WorkerConfiguration": {
              "CPU": "2 vCPU",
              "Memory": "4 GB",
              "Disk": "10 GB"
            }
          }
        },
        "MaximumCapacity": {
          "CPU": "16 vCPU",
          "Memory": "32 GB",
          "Disk": "100 GB"
        },
        "NetworkConfiguration": {
          "SubnetIds": [
            {
              "Ref": "SubnetId"
            }
          ]
        },
        "Architecture": "ARM64",
        "AutoStartConfig": {
          "Enabled": true,
          "IdleTimeoutMinutes": 5
        },
        "AutoStopConfig": {
          "Enabled": true,
          "IdleTimeoutMinutes": 10
        },
        "ImageConfiguration": {
          "ImageUri": "public.ecr.aws/lambda/provided:al2-arm64"
        },
        "RoleArn": {
          "Fn::GetAtt": [
            "EMRServerlessRole",
            "Arn"
          ]
        },
        "WorkerTypeSpecifications": {
          "Worker": {
            "WorkerCount": {
              "Value": 1
            },
            "WorkerConfiguration": {
              "CPU": "2 vCPU",
              "Memory": "4 GB",
              "Disk": "10 GB"
            }
          }
        }
      },
      "effects": [
        "auto-start",
        "auto-stop",
        "spark"
      ]
    },
    {
      "id": "SubnetId",
      "kind": "AWS::EC2::Subnet::Id",
      "fields": {
        "Ref": "SubnetId"
      }
    }
  ],
  "edges": [
    {
      "type": "depends",
      "from": "EMRServerlessRole",
      "to": "EMRServerlessApplication"
    },
    {
      "type": "depends",
      "from": "ScriptsBucket",
      "to": "EMRServerlessApplication"
    }
  ],
  "invariants": [
    "IAM role must grant EMR Serverless permissions to S3 and CloudWatch Logs",
    "S3 bucket must be private, encrypted, and versioned",
    "EMR Serverless application must use auto-start/auto-stop to minimize idle costs",
    "Application must use Spark runtime with EMR 6.15.0",
    "Network configuration must specify a valid subnet"
  ]
}