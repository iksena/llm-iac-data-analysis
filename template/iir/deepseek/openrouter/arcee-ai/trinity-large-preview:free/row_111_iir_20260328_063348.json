{
  "resources": [
    {
      "id": "MyDataDogAppEventBus",
      "kind": "AWS::Events::EventBus",
      "fields": {
        "Name": "MyDataDogApp"
      },
      "effects": [
        "centralized-logging"
      ]
    },
    {
      "id": "DataDogApiDestination",
      "kind": "AWS::Events::ApiDestination",
      "fields": {
        "Name": "DataDogLogIngestion",
        "Description": "API destination for DataDog log ingestion",
        "InvocationEndpoint": "https://http-intake.logs.datadoghq.com",
        "HttpMethod": "POST",
        "ConnectionArn": "DataDogApiConnection",
        "InvocationRateLimitPerSecond": 10
      },
      "effects": [
        "public-api",
        "encrypted"
      ]
    },
    {
      "id": "DataDogApiConnection",
      "kind": "AWS::Events::Connection",
      "fields": {
        "Name": "DataDogApiConnection",
        "Description": "Connection to DataDog API",
        "AuthorizationType": "API_KEY",
        "ApiKeyAuthParameters": {
          "ApiKeyName": "DD-API-KEY",
          "ApiKeyValue": "testanu"
        }
      },
      "effects": [
        "secure",
        "authenticated"
      ]
    },
    {
      "id": "EventBridgeToDataDogRole",
      "kind": "AWS::IAM::Role",
      "fields": {
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "events.amazonaws.com"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "Policies": [
          {
            "PolicyName": "InvokeApiDestination",
            "PolicyDocument": {
              "Version": "2012-10-17",
              "Statement": [
                {
                  "Effect": "Allow",
                  "Action": "events:InvokeApiDestination",
                  "Resource": "DataDogApiDestination"
                }
              ]
            }
          }
        ]
      },
      "effects": [
        "least-privilege",
        "secure"
      ]
    },
    {
      "id": "DeadLetterQueue",
      "kind": "AWS::SQS::Queue",
      "fields": {
        "QueueName": "DataDogLogDeliveryDLQ"
      },
      "effects": [
        "fault-tolerant",
        "encrypted"
      ]
    },
    {
      "id": "EventBridgeRule",
      "kind": "AWS::Events::Rule",
      "fields": {
        "EventBusName": "MyDataDogAppEventBus",
        "EventPattern": {
          "source": [
            "MyDataDogApp"
          ]
        },
        "Targets": [
          {
            "Arn": "DataDogApiDestination",
            "Id": "DataDogTarget",
            "RoleArn": "EventBridgeToDataDogRole",
            "DeadLetterConfig": {
              "Arn": "DeadLetterQueue"
            }
          }
        ]
      },
      "effects": [
        "automated",
        "fault-tolerant"
      ]
    }
  ],
  "edges": [
    {
      "type": "depends",
      "from": "DataDogApiDestination",
      "to": "DataDogApiConnection"
    },
    {
      "type": "depends",
      "from": "EventBridgeRule",
      "to": "MyDataDogAppEventBus"
    },
    {
      "type": "depends",
      "from": "EventBridgeRule",
      "to": "DataDogApiDestination"
    },
    {
      "type": "depends",
      "from": "EventBridgeRule",
      "to": "EventBridgeToDataDogRole"
    },
    {
      "type": "depends",
      "from": "EventBridgeRule",
      "to": "DeadLetterQueue"
    }
  ],
  "invariants": [
    "Centralized log forwarding to DataDog",
    "Secure API key authentication",
    "Fault tolerance with dead-letter queue",
    "Least privilege IAM permissions",
    "Encrypted data in transit"
  ]
}