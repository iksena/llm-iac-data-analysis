{
  "resources": [
    {
      "id": "VPC",
      "kind": "AWS::EC2::VPC",
      "fields": {
        "CidrBlock": "10.0.0.0/16",
        "EnableDnsSupport": true,
        "EnableDnsHostnames": true
      },
      "effects": [
        "private-subnets"
      ]
    },
    {
      "id": "PrivateSubnetA",
      "kind": "AWS::EC2::Subnet",
      "fields": {
        "VpcId": "VPC",
        "CidrBlock": "10.0.1.0/24",
        "AvailabilityZone": "us-east-1a"
      },
      "effects": [
        "private-subnet"
      ]
    },
    {
      "id": "PrivateSubnetB",
      "kind": "AWS::EC2::Subnet",
      "fields": {
        "VpcId": "VPC",
        "CidrBlock": "10.0.2.0/24",
        "AvailabilityZone": "us-east-1b"
      },
      "effects": [
        "private-subnet"
      ]
    },
    {
      "id": "PrivateSubnetC",
      "kind": "AWS::EC2::Subnet",
      "fields": {
        "VpcId": "VPC",
        "CidrBlock": "10.0.3.0/24",
        "AvailabilityZone": "us-east-1c"
      },
      "effects": [
        "private-subnet"
      ]
    },
    {
      "id": "DBSecurityGroup",
      "kind": "AWS::EC2::SecurityGroup",
      "fields": {
        "VpcId": "VPC",
        "GroupDescription": "Security group for Aurora cluster",
        "SecurityGroupIngress": [
          {
            "IpProtocol": "tcp",
            "FromPort": 3306,
            "ToPort": 3306,
            "SourceSecurityGroupId": "LambdaSecurityGroup"
          }
        ]
      },
      "effects": [
        "database-security"
      ]
    },
    {
      "id": "LambdaSecurityGroup",
      "kind": "AWS::EC2::SecurityGroup",
      "fields": {
        "VpcId": "VPC",
        "GroupDescription": "Security group for Lambda functions"
      },
      "effects": [
        "lambda-security"
      ]
    },
    {
      "id": "AuroraCluster",
      "kind": "AWS::RDS::DBCluster",
      "fields": {
        "Engine": "aurora-mysql",
        "EngineVersion": "5.7.mysql_aurora.2.07.2",
        "DatabaseName": "mydb",
        "MasterUsername": "admin",
        "MasterUserPassword": "dummy",
        "BackupRetentionPeriod": 7,
        "PreferredBackupWindow": "03:00-04:00",
        "PreferredMaintenanceWindow": "sun:05:00-sun:06:00",
        "Port": 3306,
        "VpcSecurityGroupIds": [
          "DBSecurityGroup"
        ],
        "DBSubnetGroupName": "DBSubnetGroup",
        "StorageEncrypted": true,
        "EnableIAMDatabaseAuthentication": true,
        "EnableHttpEndpoint": true,
        "EnablePerformanceInsights": true,
        "DeletionProtection": true,
        "EnableCloudwatchLogsExports": [
          "audit",
          "error",
          "general",
          "slowquery"
        ]
      },
      "effects": [
        "encrypted",
        "iam-auth",
        "cloudwatch-logs",
        "performance-insights"
      ]
    },
    {
      "id": "DBSubnetGroup",
      "kind": "AWS::RDS::DBSubnetGroup",
      "fields": {
        "DBSubnetGroupDescription": "Subnets for Aurora cluster",
        "SubnetIds": [
          "PrivateSubnetA",
          "PrivateSubnetB",
          "PrivateSubnetC"
        ]
      },
      "effects": [
        "subnet-group"
      ]
    },
    {
      "id": "AuroraInstance1",
      "kind": "AWS::RDS::DBInstance",
      "fields": {
        "DBClusterIdentifier": "AuroraCluster",
        "DBInstanceClass": "db.r6g.large",
        "Engine": "aurora-mysql",
        "EngineVersion": "5.7.mysql_aurora.2.07.2",
        "DBSubnetGroupName": "DBSubnetGroup",
        "PubliclyAccessible": false,
        "DBName": "mydb",
        "EnableIAMDatabaseAuthentication": true,
        "EnablePerformanceInsights": true,
        "MonitoringInterval": 60,
        "MonitoringRoleArn": "RDSMonitoringRole",
        "EnableCloudwatchLogsExports": [
          "audit",
          "error",
          "general",
          "slowquery"
        ]
      },
      "effects": [
        "reader-instance"
      ]
    },
    {
      "id": "AuroraInstance2",
      "kind": "AWS::RDS::DBInstance",
      "fields": {
        "DBClusterIdentifier": "AuroraCluster",
        "DBInstanceClass": "db.r6g.large",
        "Engine": "aurora-mysql",
        "EngineVersion": "5.7.mysql_aurora.2.07.2",
        "DBSubnetGroupName": "DBSubnetGroup",
        "PubliclyAccessible": false,
        "DBName": "mydb",
        "EnableIAMDatabaseAuthentication": true,
        "EnablePerformanceInsights": true,
        "MonitoringInterval": 60,
        "MonitoringRoleArn": "RDSMonitoringRole",
        "EnableCloudwatchLogsExports": [
          "audit",
          "error",
          "general",
          "slowquery"
        ]
      },
      "effects": [
        "reader-instance"
      ]
    },
    {
      "id": "RDSProxy",
      "kind": "AWS::RDS::DBProxy",
      "fields": {
        "DBProxyName": "MyRDSProxy",
        "EngineFamily": "MYSQL",
        "RoleArn": "RDSProxyRole",
        "VpcSubnetIds": [
          "PrivateSubnetA",
          "PrivateSubnetB",
          "PrivateSubnetC"
        ],
        "Auth": [
          {
            "AuthScheme": "SECRETS",
            "IAMAuth": "DISABLED",
            "SecretArn": "AuroraClusterSecret"
          }
        ],
        "RequireTLS": true,
        "IdleClientTimeout": 1800,
        "MaxConnectionsPercent": 100,
        "MaxIdleConnectionsPercent": 50,
        "ConnectionBorrowTimeout": 120,
        "InitQuery": "SELECT 1",
        "DebugLogging": true,
        "SecurityGroups": [
          "DBSecurityGroup"
        ]
      },
      "effects": [
        "rds-proxy",
        "tls-enforced",
        "connection-pooling"
      ]
    },
    {
      "id": "RDSProxyTargetGroup",
      "kind": "AWS::RDS::DBProxyTargetGroup",
      "fields": {
        "DBProxyName": "RDSProxy",
        "TargetGroupName": "AuroraTargetGroup",
        "DBClusterIdentifiers": [
          "AuroraCluster"
        ],
        "ConnectionPoolConfig": {
          "MaxConnectionsPercent": 100,
          "MaxIdleConnectionsPercent": 50,
          "ConnectionBorrowTimeout": 120
        }
      },
      "effects": [
        "proxy-target-group"
      ]
    },
    {
      "id": "AuroraClusterSecret",
      "kind": "AWS::SecretsManager::Secret",
      "fields": {
        "Name": "AuroraClusterSecret",
        "Description": "Secret for Aurora cluster credentials",
        "SecretString": "dummy"
      },
      "effects": [
        "credential-secret"
      ]
    },
    {
      "id": "RDSMonitoringRole",
      "kind": "AWS::IAM::Role",
      "fields": {
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "monitoring.rds.amazonaws.com"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "ManagedPolicyArns": [
          "arn:aws:iam::aws:policy/service-role/AmazonRDSEnhancedMonitoringRole"
        ]
      },
      "effects": [
        "monitoring-role"
      ]
    },
    {
      "id": "RDSProxyRole",
      "kind": "AWS::IAM::Role",
      "fields": {
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "rds.amazonaws.com"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "Policies": [
          {
            "PolicyName": "RDSProxyPolicy",
            "PolicyDocument": {
              "Version": "2012-10-17",
              "Statement": [
                {
                  "Effect": "Allow",
                  "Action": [
                    "secretsmanager:GetSecretValue",
                    "kms:Decrypt"
                  ],
                  "Resource": "AuroraClusterSecret"
                }
              ]
            }
          }
        ]
      },
      "effects": [
        "proxy-role"
      ]
    }
  ],
  "edges": [
    {
      "type": "depends",
      "from": "PrivateSubnetA",
      "to": "VPC"
    },
    {
      "type": "depends",
      "from": "PrivateSubnetB",
      "to": "VPC"
    },
    {
      "type": "depends",
      "from": "PrivateSubnetC",
      "to": "VPC"
    },
    {
      "type": "depends",
      "from": "DBSecurityGroup",
      "to": "VPC"
    },
    {
      "type": "depends",
      "from": "LambdaSecurityGroup",
      "to": "VPC"
    },
    {
      "type": "depends",
      "from": "AuroraCluster",
      "to": "DBSecurityGroup"
    },
    {
      "type": "depends",
      "from": "AuroraCluster",
      "to": "DBSubnetGroup"
    },
    {
      "type": "depends",
      "from": "AuroraInstance1",
      "to": "AuroraCluster"
    },
    {
      "type": "depends",
      "from": "AuroraInstance2",
      "to": "AuroraCluster"
    },
    {
      "type": "depends",
      "from": "AuroraInstance1",
      "to": "DBSubnetGroup"
    },
    {
      "type": "depends",
      "from": "AuroraInstance2",
      "to": "DBSubnetGroup"
    },
    {
      "type": "depends",
      "from": "AuroraInstance1",
      "to": "RDSMonitoringRole"
    },
    {
      "type": "depends",
      "from": "AuroraInstance2",
      "to": "RDSMonitoringRole"
    },
    {
      "type": "depends",
      "from": "RDSProxy",
      "to": "RDSProxyRole"
    },
    {
      "type": "depends",
      "from": "RDSProxy",
      "to": "DBSecurityGroup"
    },
    {
      "type": "depends",
      "from": "RDSProxy",
      "to": "DBSubnetGroup"
    },
    {
      "type": "depends",
      "from": "RDSProxyTargetGroup",
      "to": "RDSProxy"
    },
    {
      "type": "depends",
      "from": "RDSProxyTargetGroup",
      "to": "AuroraCluster"
    },
    {
      "type": "depends",
      "from": "RDSProxy",
      "to": "AuroraClusterSecret"
    }
  ],
  "invariants": [
    "VPC with private subnets across multiple AZs",
    "Aurora MySQL cluster with primary and reader instances",
    "RDS Proxy with TLS enforcement and connection pooling",
    "Encrypted storage and IAM database authentication",
    "Secrets Manager for credential management",
    "Security groups restricting access to authorized resources",
    "CloudWatch logging, enhanced monitoring, and performance insights"
  ]
}