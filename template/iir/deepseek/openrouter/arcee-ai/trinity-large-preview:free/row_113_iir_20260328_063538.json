{
  "resources": [
    {
      "id": "EventBridgeRule",
      "kind": "AWS::Events::Rule",
      "fields": {
        "EventPattern": {
          "source": [
            "demo.cli"
          ]
        },
        "State": "ENABLED",
        "Targets": [
          {
            "Id": "Target0",
            "Arn": {
              "Ref": "SNSTopic"
            }
          }
        ]
      },
      "effects": [
        "event-forwarding"
      ]
    },
    {
      "id": "SNSTopic",
      "kind": "AWS::SNS::Topic",
      "fields": {},
      "effects": [
        "messaging"
      ]
    },
    {
      "id": "TopicPolicy",
      "kind": "AWS::SNS::TopicPolicy",
      "fields": {
        "Topics": [
          {
            "Ref": "SNSTopic"
          }
        ],
        "PolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "events.amazonaws.com"
              },
              "Action": "sns:Publish",
              "Resource": {
                "Ref": "SNSTopic"
              }
            }
          ]
        }
      },
      "effects": [
        "permissions"
      ]
    }
  ],
  "edges": [
    {
      "type": "depends",
      "from": "EventBridgeRule",
      "to": "SNSTopic"
    },
    {
      "type": "depends",
      "from": "TopicPolicy",
      "to": "SNSTopic"
    }
  ],
  "invariants": [
    "EventBridge rule must match events from source 'demo.cli'",
    "EventBridge must have permission to publish to SNS topic",
    "SNS topic must be created before EventBridge rule and topic policy"
  ]
}