{
  "resources": [
    {
      "id": "EventBus",
      "kind": "AWS::Events::EventBus",
      "fields": {
        "Name": "MyShopifyAppBus"
      },
      "effects": [
        "event-bus"
      ]
    },
    {
      "id": "ApiDestination",
      "kind": "AWS::Events::ApiDestination",
      "fields": {
        "Name": "ShopifyProductCreation",
        "ApiDestinationArn": "arn:aws:events::123456789012:api-destination/ShopifyProductCreation",
        "ConnectionArn": "arn:aws:events::123456789012:connection/ShopifyConnection",
        "InvocationEndpoint": "https://testanu.myshopify.com/admin/api/2023-04/products.json",
        "HttpMethod": "POST",
        "InvocationRateLimitPerSecond": 1
      },
      "effects": [
        "api-destination"
      ]
    },
    {
      "id": "Connection",
      "kind": "AWS::Events::Connection",
      "fields": {
        "Name": "ShopifyConnection",
        "AuthorizationType": "API_KEY",
        "ApiKeyAuthParameters": {
          "ApiKeyName": "X-Shopify-Access-Token",
          "ApiKeyValue": "MyShopifyAppApiKey"
        }
      },
      "effects": [
        "api-connection"
      ]
    },
    {
      "id": "Rule",
      "kind": "AWS::Events::Rule",
      "fields": {
        "EventBusName": "MyShopifyAppBus",
        "EventPattern": {
          "source": [
            "MyShopifyApp"
          ],
          "detail-type": [
            "ProductCreated"
          ]
        },
        "Targets": [
          {
            "Arn": "arn:aws:events::123456789012:api-destination/ShopifyProductCreation",
            "Id": "ShopifyProductCreationTarget"
          }
        ]
      },
      "effects": [
        "event-rule"
      ]
    }
  ],
  "edges": [
    {
      "type": "depends",
      "from": "ApiDestination",
      "to": "Connection"
    },
    {
      "type": "depends",
      "from": "Rule",
      "to": "EventBus"
    },
    {
      "type": "depends",
      "from": "Rule",
      "to": "ApiDestination"
    }
  ],
  "invariants": [
    "EventBridge event bus captures events from MyShopifyApp source",
    "API destination targets Shopify's product creation endpoint with authentication",
    "Rule triggers API destination when ProductCreated events are detected"
  ]
}