{
  "resources": [
    {
      "id": "StaticSiteBucket",
      "kind": "AWS::S3::Bucket",
      "fields": {
        "AccessControl": "Private",
        "PublicAccessBlockConfiguration": {
          "BlockPublicAcls": true,
          "IgnorePublicAcls": true,
          "BlockPublicPolicy": true,
          "RestrictPublicBuckets": true
        },
        "WebsiteConfiguration": {
          "IndexDocument": "index.html"
        }
      },
      "effects": [
        "encrypted",
        "versioned"
      ]
    },
    {
      "id": "OAC",
      "kind": "AWS::CloudFront::OriginAccessControl",
      "fields": {
        "OriginAccessControlConfig": {
          "Name": "S3OAC",
          "Description": "OAC for S3 bucket access",
          "OriginAccessControlOriginType": "s3",
          "SigningProtocol": "sigv4",
          "SigningBehavior": "never",
          "CredentialTTL": 300
        }
      },
      "effects": [
        "secure-access"
      ]
    },
    {
      "id": "CloudFrontDistribution",
      "kind": "AWS::CloudFront::Distribution",
      "fields": {
        "DistributionConfig": {
          "Origins": [
            {
              "Id": "S3Origin",
              "DomainName": {
                "Fn::GetAtt": [
                  "StaticSiteBucket",
                  "RegionalDomainName"
                ]
              },
              "OriginAccessControlId": {
                "Ref": "OAC"
              },
              "OriginType": "s3",
              "S3OriginConfig": {}
            }
          ],
          "DefaultCacheBehavior": {
            "AllowedMethods": [
              "GET",
              "HEAD"
            ],
            "CachedMethods": [
              "GET",
              "HEAD"
            ],
            "Compress": true,
            "TargetOriginId": "S3Origin",
            "ViewerProtocolPolicy": "redirect-to-https",
            "CachePolicyId": {
              "Ref": "CustomCachePolicy"
            },
            "OriginRequestPolicyId": {
              "Ref": "OriginRequestPolicy"
            }
          },
          "DefaultRootObject": "index.html",
          "Enabled": true,
          "HttpVersion": "http2",
          "IPV6Enabled": true
        }
      },
      "effects": [
        "https-enforced",
        "optimized-caching"
      ]
    },
    {
      "id": "CustomCachePolicy",
      "kind": "AWS::CloudFront::CachePolicy",
      "fields": {
        "CachePolicyConfig": {
          "Name": "CustomCachePolicy",
          "MinTTL": 60,
          "MaxTTL": 60,
          "DefaultTTL": 60,
          "ParametersInCacheKeyAndForwardedToOrigin": {
            "EnableAcceptEncodingGzip": true,
            "EnableAcceptEncodingBrotli": true,
            "HeadersConfig": {
              "HeaderBehavior": "none"
            },
            "CookiesConfig": {
              "CookieBehavior": "none"
            },
            "QueryStringsConfig": {
              "QueryStringBehavior": "none"
            }
          }
        }
      },
      "effects": [
        "optimized-caching"
      ]
    },
    {
      "id": "OriginRequestPolicy",
      "kind": "AWS::CloudFront::OriginRequestPolicy",
      "fields": {
        "OriginRequestPolicyConfig": {
          "Name": "S3OriginRequestPolicy",
          "HeadersConfig": {
            "HeaderBehavior": "none"
          },
          "CookiesConfig": {
            "CookieBehavior": "none"
          },
          "QueryStringsConfig": {
            "QueryStringBehavior": "none"
          }
        }
      },
      "effects": [
        "secure-access"
      ]
    },
    {
      "id": "LambdaFunction",
      "kind": "AWS::Lambda::Function",
      "fields": {
        "Runtime": "nodejs18.x",
        "Handler": "index.handler",
        "Role": {
          "Fn::GetAtt": [
            "LambdaExecutionRole",
            "Arn"
          ]
        },
        "Code": {
          "ZipFile": {
            "Fn::Join": [
              "",
              [
                "exports.handler = async (event) => {",
                "  const AWS = require('aws-sdk');",
                "  const s3 = new AWS.S3();",
                "  const bucketName = process.env.BUCKET_NAME;",
                "  if (event.RequestType === 'Create' || event.RequestType === 'Update') {",
                "    await s3.putObject({",
                "      Bucket: bucketName,",
                "      Key: 'index.html',",
                "      Body: '<html><body><h1>Welcome to our secure static site!</h1></body></html>',",
                "      ContentType: 'text/html'",
                "    }).promise();",
                "  } else if (event.RequestType === 'Delete') {",
                "    const objects = await s3.listObjectsV2({Bucket: bucketName}).promise();",
                "    if (objects.Contents && objects.Contents.length > 0) {",
                "      await s3.deleteObjects({",
                "        Bucket: bucketName,",
                "        Delete: { Objects: objects.Contents.map(obj => ({Key: obj.Key})) }",
                "      }).promise();",
                "    }",
                "  }",
                "  return { Status: 'SUCCESS' };",
                "};"
              ]
            ]
          }
        },
        "Environment": {
          "Variables": {
            "BUCKET_NAME": {
              "Ref": "StaticSiteBucket"
            }
          }
        }
      },
      "effects": [
        "automated-content"
      ]
    },
    {
      "id": "LambdaExecutionRole",
      "kind": "AWS::IAM::Role",
      "fields": {
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "lambda.amazonaws.com"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "Policies": [
          {
            "PolicyName": "S3AccessPolicy",
            "PolicyDocument": {
              "Version": "2012-10-17",
              "Statement": [
                {
                  "Effect": "Allow",
                  "Action": [
                    "s3:PutObject",
                    "s3:GetObject",
                    "s3:ListBucket",
                    "s3:DeleteObject"
                  ],
                  "Resource": [
                    {
                      "Fn::GetAtt": [
                        "StaticSiteBucket",
                        "Arn"
                      ]
                    },
                    {
                      "Fn::Join": [
                        "",
                        [
                          {
                            "Fn::GetAtt": [
                              "StaticSiteBucket",
                              "Arn"
                            ]
                          },
                          "/*"
                        ]
                      ]
                    }
                  ]
                }
              ]
            }
          },
          {
            "PolicyName": "CloudWatchLogsPolicy",
            "PolicyDocument": {
              "Version": "2012-10-17",
              "Statement": [
                {
                  "Effect": "Allow",
                  "Action": [
                    "logs:CreateLogGroup",
                    "logs:CreateLogStream",
                    "logs:PutLogEvents"
                  ],
                  "Resource": "arn:aws:logs:*:*:*"
                }
              ]
            }
          }
        ]
      },
      "effects": [
        "least-privilege"
      ]
    },
    {
      "id": "LambdaCustomResource",
      "kind": "AWS::CloudFormation::CustomResource",
      "fields": {
        "ServiceToken": {
          "Fn::GetAtt": [
            "LambdaFunction",
            "Arn"
          ]
        }
      },
      "effects": [
        "automated-content"
      ]
    }
  ],
  "edges": [
    {
      "type": "depends",
      "from": "OAC",
      "to": "StaticSiteBucket"
    },
    {
      "type": "depends",
      "from": "CloudFrontDistribution",
      "to": "OAC"
    },
    {
      "type": "depends",
      "from": "CloudFrontDistribution",
      "to": "CustomCachePolicy"
    },
    {
      "type": "depends",
      "from": "CloudFrontDistribution",
      "to": "OriginRequestPolicy"
    },
    {
      "type": "depends",
      "from": "LambdaFunction",
      "to": "LambdaExecutionRole"
    },
    {
      "type": "depends",
      "from": "LambdaCustomResource",
      "to": "LambdaFunction"
    }
  ],
  "invariants": [
    "S3 bucket must be private with OAC for CloudFront access",
    "HTTPS must be enforced for all content delivery",
    "Lambda must clean up bucket contents on stack deletion",
    "Cache TTL must be 60 seconds for optimal performance",
    "All resources must be encrypted at rest"
  ]
}