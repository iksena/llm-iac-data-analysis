{
  "resources": [
    {
      "id": "ClientVPNAnalyticsDashboard",
      "kind": "AWS::CloudWatch::Dashboard",
      "fields": {
        "DashboardName": "ClientVPNAnalyticsDashboard",
        "DashboardBody": {
          "widgets": [
            {
              "type": "metric",
              "x": 0,
              "y": 0,
              "width": 12,
              "height": 6,
              "properties": {
                "metrics": [
                  [
                    "AWS/ClientVPN",
                    "ClientVPNConnectionCount",
                    "EndpointId",
                    "endpoint-*"
                  ]
                ],
                "period": 300,
                "stat": "Average",
                "region": "us-east-1",
                "title": "Active Client VPN Connections"
              }
            },
            {
              "type": "text",
              "x": 0,
              "y": 6,
              "width": 12,
              "height": 1,
              "properties": {
                "markdown": "# Client VPN Usage Analytics"
              }
            },
            {
              "type": "table",
              "x": 0,
              "y": 7,
              "width": 12,
              "height": 8,
              "properties": {
                "view": "timeSeries",
                "stacked": false,
                "metrics": [
                  [
                    "AWS/ClientVPN",
                    "ClientVPNDataTransfer",
                    "EndpointId",
                    "endpoint-*"
                  ]
                ],
                "region": "us-east-1",
                "title": "Data Transfer by Endpoint"
              }
            }
          ]
        }
      },
      "effects": [
        "monitoring",
        "analytics"
      ]
    },
    {
      "id": "ConnectionDurationQuery",
      "kind": "AWS::CloudWatch::InsightQuery",
      "fields": {
        "QueryName": "ConnectionDurationAnalysis",
        "QueryString": "fields @timestamp, @message | filter @message like /connection.*established/ | stats avg(@duration) as avgDuration by @endpointId | sort avgDuration desc",
        "LogGroupName": "/aws/client-vpn"
      },
      "effects": [
        "analytics",
        "duration-metrics"
      ]
    },
    {
      "id": "DataTransferQuery",
      "kind": "AWS::CloudWatch::InsightQuery",
      "fields": {
        "QueryName": "DataTransferAnalysis",
        "QueryString": "fields @timestamp, @message | filter @message like /data.*transfer/ | stats sum(@bytesIn) as totalIngress, sum(@bytesOut) as totalEgress by @endpointId, @userId | sort totalIngress desc",
        "LogGroupName": "/aws/client-vpn"
      },
      "effects": [
        "analytics",
        "data-transfer"
      ]
    },
    {
      "id": "UserActivityQuery",
      "kind": "AWS::CloudWatch::InsightQuery",
      "fields": {
        "QueryName": "UserActivityAnalysis",
        "QueryString": "fields @timestamp, @message | filter @message like /authentication/ | stats count(*) as connectionCount by @userId, @authMethod | sort connectionCount desc",
        "LogGroupName": "/aws/client-vpn"
      },
      "effects": [
        "analytics",
        "user-activity"
      ]
    },
    {
      "id": "AuthMethodBreakdownQuery",
      "kind": "AWS::CloudWatch::InsightQuery",
      "fields": {
        "QueryName": "AuthMethodBreakdown",
        "QueryString": "fields @timestamp, @message | filter @message like /authentication/ | stats count(*) as authCount by @authMethod | sort authCount desc",
        "LogGroupName": "/aws/client-vpn"
      },
      "effects": [
        "analytics",
        "auth-breakdown"
      ]
    }
  ],
  "edges": [
    {
      "type": "depends",
      "from": "ConnectionDurationQuery",
      "to": "ClientVPNAnalyticsDashboard"
    },
    {
      "type": "depends",
      "from": "DataTransferQuery",
      "to": "ClientVPNAnalyticsDashboard"
    },
    {
      "type": "depends",
      "from": "UserActivityQuery",
      "to": "ClientVPNAnalyticsDashboard"
    },
    {
      "type": "depends",
      "from": "AuthMethodBreakdownQuery",
      "to": "ClientVPNAnalyticsDashboard"
    }
  ],
  "invariants": [
    "All queries must reference the same log group /aws/client-vpn",
    "Dashboard must aggregate results from all queries",
    "Queries must be organized by logical function: duration, data transfer, user activity, authentication breakdown"
  ]
}