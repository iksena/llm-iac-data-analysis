{
  "resources": [
    {
      "id": "SecretsManagerMonitorTopic",
      "kind": "AWS::SNS::Topic",
      "fields": {},
      "effects": [
        "public-read"
      ]
    },
    {
      "id": "SecretsManagerMonitorPolicy",
      "kind": "AWS::SNS::TopicPolicy",
      "fields": {
        "PolicyDocument": {
          "Version": "2012-10-17",
          "Id": "SecretsManagerMonitorPolicy",
          "Statement": [
            {
              "Sid": "SecretsManagerPublish",
              "Effect": "Allow",
              "Principal": "*",
              "Action": "SNS:Publish",
              "Resource": {
                "Ref": "SecretsManagerMonitorTopic"
              },
              "Condition": {
                "ArnLike": {
                  "AWS:SourceArn": {
                    "Fn::Join": [
                      ":",
                      [
                        "arn",
                        {
                          "Ref": "AWS::Partition"
                        },
                        "secretsmanager",
                        {
                          "Ref": "AWS::Region"
                        },
                        {
                          "Ref": "AWS::AccountId"
                        },
                        "*"
                      ]
                    ]
                  }
                }
              }
            }
          ]
        },
        "Topics": [
          {
            "Ref": "SecretsManagerMonitorTopic"
          }
        ]
      },
      "effects": [
        "encrypted"
      ]
    },
    {
      "id": "SecretsManagerMonitorFunction",
      "kind": "AWS::Lambda::Function",
      "fields": {
        "Handler": "index.handler",
        "Runtime": "nodejs18.x",
        "Code": {
          "ZipFile": "exports.handler = async (event) => { console.log(JSON.stringify(event)); };"
        },
        "Timeout": 30,
        "Role": {
          "Fn::GetAtt": [
            "SecretsManagerMonitorFunctionRole",
            "Arn"
          ]
        }
      },
      "effects": [
        "encrypted"
      ]
    },
    {
      "id": "SecretsManagerMonitorFunctionRole",
      "kind": "AWS::IAM::Role",
      "fields": {
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "lambda.amazonaws.com"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "ManagedPolicyArns": [
          "arn:aws:iam::aws:policy/service-role/AWSLambdaBasicExecutionRole"
        ]
      },
      "effects": [
        "encrypted"
      ]
    },
    {
      "id": "SecretsManagerMonitorFunctionPermission",
      "kind": "AWS::Lambda::Permission",
      "fields": {
        "Action": "lambda:InvokeFunction",
        "FunctionName": {
          "Fn::GetAtt": [
            "SecretsManagerMonitorFunction",
            "Arn"
          ]
        },
        "Principal": "secretsmanager.amazonaws.com"
      },
      "effects": []
    },
    {
      "id": "SecretsManagerMonitorRule",
      "kind": "AWS::Events::Rule",
      "fields": {
        "EventPattern": {
          "source": [
            "aws.secretsmanager"
          ],
          "detail-type": [
            "AWS API Call via CloudTrail"
          ],
          "detail": {
            "eventSource": [
              "secretsmanager.amazonaws.com"
            ],
            "eventName": [
              "CreateSecret",
              "UpdateSecret",
              "GetSecretValue"
            ]
          }
        },
        "Targets": [
          {
            "Arn": {
              "Fn::GetAtt": [
                "SecretsManagerMonitorFunction",
                "Arn"
              ]
            },
            "Id": "SecretsManagerMonitorTarget"
          }
        ]
      },
      "effects": [
        "encrypted"
      ]
    }
  ],
  "edges": [
    {
      "type": "depends",
      "from": "SecretsManagerMonitorPolicy",
      "to": "SecretsManagerMonitorTopic"
    },
    {
      "type": "depends",
      "from": "SecretsManagerMonitorFunction",
      "to": "SecretsManagerMonitorFunctionRole"
    },
    {
      "type": "depends",
      "from": "SecretsManagerMonitorFunctionPermission",
      "to": "SecretsManagerMonitorFunction"
    },
    {
      "type": "depends",
      "from": "SecretsManagerMonitorRule",
      "to": "SecretsManagerMonitorFunction"
    }
  ],
  "invariants": [
    "Secrets Manager events must be monitored for CreateSecret, UpdateSecret, and GetSecretValue operations",
    "Notifications must be sent via SNS topic",
    "Lambda function must have appropriate IAM permissions",
    "EventBridge rule must capture relevant API calls via CloudTrail"
  ]
}