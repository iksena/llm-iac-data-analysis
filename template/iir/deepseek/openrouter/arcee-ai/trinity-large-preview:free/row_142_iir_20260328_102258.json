{
  "resources": [
    {
      "id": "VPC",
      "kind": "AWS::EC2::VPC",
      "fields": {
        "CidrBlock": "10.0.0.0/16",
        "EnableDnsSupport": true,
        "EnableDnsHostnames": true
      },
      "effects": [
        "vpc"
      ]
    },
    {
      "id": "InternetGateway",
      "kind": "AWS::EC2::InternetGateway",
      "fields": {},
      "effects": [
        "public"
      ]
    },
    {
      "id": "VPCGatewayAttachment",
      "kind": "AWS::EC2::VPCGatewayAttachment",
      "fields": {
        "VpcId": "VPC",
        "InternetGatewayId": "InternetGateway"
      },
      "effects": []
    },
    {
      "id": "PublicSubnet1",
      "kind": "AWS::EC2::Subnet",
      "fields": {
        "VpcId": "VPC",
        "CidrBlock": "10.0.1.0/24",
        "AvailabilityZone": "us-east-1a"
      },
      "effects": [
        "public"
      ]
    },
    {
      "id": "PublicSubnet2",
      "kind": "AWS::EC2::Subnet",
      "fields": {
        "VpcId": "VPC",
        "CidrBlock": "10.0.2.0/24",
        "AvailabilityZone": "us-east-1b"
      },
      "effects": [
        "public"
      ]
    },
    {
      "id": "RouteTable",
      "kind": "AWS::EC2::RouteTable",
      "fields": {
        "VpcId": "VPC"
      },
      "effects": [
        "public"
      ]
    },
    {
      "id": "InternetRoute",
      "kind": "AWS::EC2::Route",
      "fields": {
        "RouteTableId": "RouteTable",
        "DestinationCidrBlock": "0.0.0.0/0",
        "GatewayId": "InternetGateway"
      },
      "effects": [
        "public"
      ]
    },
    {
      "id": "SubnetRouteTableAssociation1",
      "kind": "AWS::EC2::SubnetRouteTableAssociation",
      "fields": {
        "SubnetId": "PublicSubnet1",
        "RouteTableId": "RouteTable"
      },
      "effects": []
    },
    {
      "id": "SubnetRouteTableAssociation2",
      "kind": "AWS::EC2::SubnetRouteTableAssociation",
      "fields": {
        "SubnetId": "PublicSubnet2",
        "RouteTableId": "RouteTable"
      },
      "effects": []
    },
    {
      "id": "SSMSecurityGroup",
      "kind": "AWS::EC2::SecurityGroup",
      "fields": {
        "GroupDescription": "Allow HTTP and SSM access",
        "VpcId": "VPC",
        "SecurityGroupIngress": [
          {
            "IpProtocol": "tcp",
            "FromPort": 80,
            "ToPort": 80,
            "CidrIp": "0.0.0.0/0"
          },
          {
            "IpProtocol": "tcp",
            "FromPort": 443,
            "ToPort": 443,
            "CidrIp": "0.0.0.0/0"
          }
        ]
      },
      "effects": [
        "public"
      ]
    },
    {
      "id": "SSMRole",
      "kind": "AWS::IAM::Role",
      "fields": {
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "ec2.amazonaws.com"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "ManagedPolicyArns": [
          "arn:aws:iam::aws:policy/AmazonEC2RoleforSSM"
        ]
      },
      "effects": [
        "iam"
      ]
    },
    {
      "id": "SSMInstanceProfile",
      "kind": "AWS::IAM::InstanceProfile",
      "fields": {
        "Roles": [
          "SSMRole"
        ]
      },
      "effects": [
        "iam"
      ]
    },
    {
      "id": "LinuxLaunchTemplate",
      "kind": "AWS::EC2::LaunchTemplate",
      "fields": {
        "LaunchTemplateName": "LinuxSSM",
        "LaunchTemplateData": {
          "ImageId": {
            "Fn::ImportValue": "LinuxAMIFunction"
          },
          "InstanceType": "t3.micro",
          "IamInstanceProfile": {
            "Name": "SSMInstanceProfile"
          },
          "SecurityGroupIds": [
            {
              "Ref": "SSMSecurityGroup"
            }
          ],
          "UserData": {
            "Fn::Base64": {
              "Fn::Join": [
                "",
                [
                  "#!/bin/bash\n",
                  "sudo yum update -y\n",
                  "sudo yum install -y https://s3.amazonaws.com/ec2-downloads-windows/SSMAgent/latest/linux_amd64/amazon-ssm-agent.rpm\n",
                  "sudo systemctl enable amazon-ssm-agent\n",
                  "sudo systemctl start amazon-ssm-agent\n"
                ]
              ]
            }
          }
        }
      },
      "effects": [
        "linux",
        "ssm"
      ]
    },
    {
      "id": "WindowsLaunchTemplate",
      "kind": "AWS::EC2::LaunchTemplate",
      "fields": {
        "LaunchTemplateName": "WindowsSSM",
        "LaunchTemplateData": {
          "ImageId": {
            "Fn::ImportValue": "WindowsAMIFunction"
          },
          "InstanceType": "t3.micro",
          "IamInstanceProfile": {
            "Name": "SSMInstanceProfile"
          },
          "SecurityGroupIds": [
            {
              "Ref": "SSMSecurityGroup"
            }
          ]
        }
      },
      "effects": [
        "windows",
        "ssm"
      ]
    },
    {
      "id": "LinuxAutoScalingGroup",
      "kind": "AWS::AutoScaling::AutoScalingGroup",
      "fields": {
        "VPCZoneIdentifier": [
          {
            "Ref": "PublicSubnet1"
          },
          {
            "Ref": "PublicSubnet2"
          }
        ],
        "LaunchTemplate": {
          "LaunchTemplateId": {
            "Ref": "LinuxLaunchTemplate"
          },
          "Version": {
            "Fn::GetAtt": [
              "LinuxLaunchTemplate",
              "LatestVersionNumber"
            ]
          }
        },
        "MinSize": "1",
        "MaxSize": "3",
        "DesiredCapacity": "2"
      },
      "effects": [
        "auto-scaling",
        "linux"
      ]
    },
    {
      "id": "WindowsAutoScalingGroup",
      "kind": "AWS::AutoScaling::AutoScalingGroup",
      "fields": {
        "VPCZoneIdentifier": [
          {
            "Ref": "PublicSubnet1"
          },
          {
            "Ref": "PublicSubnet2"
          }
        ],
        "LaunchTemplate": {
          "LaunchTemplateId": {
            "Ref": "WindowsLaunchTemplate"
          },
          "Version": {
            "Fn::GetAtt": [
              "WindowsLaunchTemplate",
              "LatestVersionNumber"
            ]
          }
        },
        "MinSize": "1",
        "MaxSize": "3",
        "DesiredCapacity": "2"
      },
      "effects": [
        "auto-scaling",
        "windows"
      ]
    }
  ],
  "edges": [
    {
      "type": "depends",
      "from": "InternetGateway",
