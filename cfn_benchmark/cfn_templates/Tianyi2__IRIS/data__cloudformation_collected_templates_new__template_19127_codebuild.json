{
    "Resources": {
        "Project": {
          "Type": "AWS::CodeBuild::Project",
          "Properties": {
            "Name": "PartyHandlerResponse",
            "Description": "Party handler response api",
            "ServiceRole": "arn:aws:iam::706907344409:role/customer_codebuild_service_role",
            "Artifacts": {
              "Type": "no_artifacts"
            },
            "Environment": {
              "Type": "LINUX_CONTAINER",
              "ComputeType": "BUILD_GENERAL1_SMALL",
              "Image": "aws/codebuild/standard:4.0"
            },
            "Source": {
              "Type": "CODEPIPELINE"
            },
            "TimeoutInMinutes": 5,
            "Tags": [
              {
                "Key": "AppName",
                "Value": "iop"
              }
            ]
          }
        }
    }
}