{
  "resources": [
    {
      "id": "VPC",
      "kind": "AWS::EC2::VPC",
      "fields": {
        "CidrBlock": "10.0.0.0/16",
        "EnableDnsSupport": true,
        "EnableDnsHostnames": true
      },
      "effects": [
        "isolated-network"
      ]
    },
    {
      "id": "InternetGateway",
      "kind": "AWS::EC2::InternetGateway",
      "fields": {},
      "effects": [
        "public-access"
      ]
    },
    {
      "id": "VPCGatewayAttachment",
      "kind": "AWS::EC2::VPCGatewayAttachment",
      "fields": {
        "VpcId": "VPC",
        "InternetGatewayId": "InternetGateway"
      },
      "effects": []
    },
    {
      "id": "PublicSubnet",
      "kind": "AWS::EC2::Subnet",
      "fields": {
        "VpcId": "VPC",
        "CidrBlock": "10.0.1.0/24",
        "MapPublicIpOnLaunch": true
      },
      "effects": [
        "public-subnet"
      ]
    },
    {
      "id": "PublicRouteTable",
      "kind": "AWS::EC2::RouteTable",
      "fields": {
        "VpcId": "VPC"
      },
      "effects": [
        "public-routing"
      ]
    },
    {
      "id": "PublicRoute",
      "kind": "AWS::EC2::Route",
      "fields": {
        "RouteTableId": "PublicRouteTable",
        "DestinationCidrBlock": "0.0.0.0/0",
        "GatewayId": "InternetGateway"
      },
      "effects": [
        "internet-access"
      ]
    },
    {
      "id": "PublicSubnetRouteTableAssociation",
      "kind": "AWS::EC2::SubnetRouteTableAssociation",
      "fields": {
        "SubnetId": "PublicSubnet",
        "RouteTableId": "PublicRouteTable"
      },
      "effects": []
    },
    {
      "id": "WebServerSecurityGroup",
      "kind": "AWS::EC2::SecurityGroup",
      "fields": {
        "GroupDescription": "Allow HTTP access",
        "VpcId": "VPC",
        "SecurityGroupIngress": [
          {
            "IpProtocol": "tcp",
            "FromPort": 80,
            "ToPort": 80,
            "CidrIp": "0.0.0.0/0"
          }
        ],
        "SecurityGroupEgress": [
          {
            "IpProtocol": "tcp",
            "FromPort": 0,
            "ToPort": 65535,
            "CidrIp": "0.0.0.0/0"
          }
        ]
      },
      "effects": [
        "http-access",
        "egress-all"
      ]
    },
    {
      "id": "WebServerInstanceProfile",
      "kind": "AWS::IAM::InstanceProfile",
      "fields": {
        "Roles": [
          "WebServerRole"
        ]
      },
      "effects": [
        "iam-instance-profile"
      ]
    },
    {
      "id": "WebServerRole",
      "kind": "AWS::IAM::Role",
      "fields": {
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "ec2.amazonaws.com"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "ManagedPolicyArns": [
          "arn:aws:iam::aws:policy/CloudWatchAgentServerPolicy",
          "arn:aws:iam::aws:policy/AmazonSSMManagedInstanceCore"
        ]
      },
      "effects": [
        "cloudwatch-monitoring",
        "ssm-access"
      ]
    },
    {
      "id": "WebServerInstance",
      "kind": "AWS::EC2::Instance",
      "fields": {
        "ImageId": "ami-0c02fb55956c7d316",
        "InstanceType": "t3.micro",
        "SubnetId": "PublicSubnet",
        "SecurityGroupIds": [
          "WebServerSecurityGroup"
        ],
        "IamInstanceProfile": "WebServerInstanceProfile",
        "UserData": "base64-encoded-user-data-script"
      },
      "effects": [
        "php-apache",
        "cloudwatch-monitoring",
        "ssm-access"
      ]
    },
    {
      "id": "LogBucket",
      "kind": "AWS::S3::Bucket",
      "fields": {
        "BucketName": "cloudwatch-logs-bucket",
        "BucketEncryption": {
          "ServerSideEncryptionConfiguration": [
            {
              "ServerSideEncryptionByDefault": {
                "SSEAlgorithm": "AES256"
              }
            }
          ]
        },
        "PublicAccessBlockConfiguration": {
          "BlockPublicAcls": true,
          "IgnorePublicAcls": true,
          "BlockPublicPolicy": true,
          "RestrictPublicBuckets": true
        }
      },
      "effects": [
        "sse-encryption",
        "restricted-public-access"
      ]
    },
    {
      "id": "LogBucketPolicy",
      "kind": "AWS::S3::BucketPolicy",
      "fields": {
        "Bucket": "LogBucket",
        "PolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "logs.amazonaws.com"
              },
              "Action": [
                "s3:PutObject",
                "s3:GetBucketAcl"
              ],
              "Resource": [
                "arn:aws:s3:::cloudwatch-logs-bucket/*",
                "arn:aws:s3:::cloudwatch-logs-bucket"
              ]
            }
          ]
        }
      },
      "effects": [
        "cloudwatch-log-ingestion"
      ]
    }
  ],
