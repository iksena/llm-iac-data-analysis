  "invariants": [
    "Instances must have IAM roles with SSM permissions",
    "Linux instances require automated SSM agent installation",
    "Windows instances leverage pre-configured SSM integration",
    "Auto Scaling Groups must span multiple availability zones",
    "Security group must allow HTTP access and SSM operations",
    "VPC must provide public internet access for SSM communication"
  ]
